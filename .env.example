# Prefer `pnpm dev:setup`; manual copies are also supported. Never commit real credentials.
DATABASE_URL=postgresql://ticket_system:ticket_system@127.0.0.1:5432/ticket_system
SESSION_SECRET=replace-with-at-least-32-random-characters

# Creation-only, minimum 12 characters. Ignored after the initial admin exists.
# Interactive `pnpm dev:setup` prompts securely instead of storing this value.
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-local-development-password

# Optional PostgreSQL namespace override.
# POSTGRES_SCHEMA=ticket_system

# Optional model-provider settings.
# OPENAI_API_KEY=
# OLLAMA_MODEL=
# OLLAMA_BASE_URL=http://127.0.0.1:11434
