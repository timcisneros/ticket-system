<%
  const viewOperationalOutcome = typeof operationalOutcomeLabel === 'undefined' ? '-' : operationalOutcomeLabel;
  const attentionPartialExecution = ['failed', 'interrupted'].includes(run.status) && partialMutationCount > 0;
  const attentionStateWarning = typeof runStateInconsistency !== 'undefined' && runStateInconsistency;
  const attentionTriage = run.triage && (run.triage.required || run.triage.resolvedAt);
  const attentionFailure = typeof failureSummary !== 'undefined' && failureSummary;
  const attentionReview = typeof reviewStatus !== 'undefined' && reviewStatus && reviewStatus.applicable;
  const hasRunAttention = Boolean(attentionPartialExecution || attentionStateWarning || attentionTriage || attentionFailure || attentionReview);
%>

<section class="zone">
  <div class="zone-head"><span class="zone-eyebrow">At a glance</span></div>
  <div class="hero">
    <div class="hero-top">
      <div>
        <h1 class="hero-title">Run #<%= run.id %>
          <span id="run-live-status" class="status-badge status-<%= run.status %>"><%= typeof runStatusLabel === 'undefined' ? run.status : runStatusLabel %></span>
        </h1>
        <p class="text-muted hero-subtitle">
          Ticket <a href="/tickets/<%= run.ticketId %>">#<%= run.ticketId %></a>
          · <%= run.agentName %>
          <% if (snapshot && (snapshot.provider || snapshot.model)) { %> · <%= snapshot.provider || '-' %> / <%= snapshot.model || '-' %><% } %>
          <% if (run.delegatedPermissionSource === 'auto_retry') { %> · created by automatic retry<% } %>
        </p>
      </div>
      <div class="hero-actions">
        <a class="btn-secondary" href="/tickets/<%= run.ticketId %>">Back to Ticket</a>
        <a class="btn-secondary" href="/logs?runId=<%= run.id %>">Run Logs</a>
        <% if (run.status === 'completed' || (run.triage && run.triage.createdAt)) { %>
          <a class="btn-secondary" href="/inbox?ticket=<%= run.ticketId %>">Inbox Thread</a>
        <% } %>
        <% if (canUpdateRuns && ['pending', 'running'].includes(run.status)) { %>
          <button type="button" class="btn-secondary btn-danger" data-stop-run-id="<%= run.id %>">Stop Run</button>
        <% } %>
        <% if (canUpdateRuns && ['failed', 'interrupted'].includes(run.status)) { %>
          <button type="button" class="btn-secondary" data-retry-run-id="<%= run.id %>">Retry</button>
        <% } %>
      </div>
    </div>
    <dl class="live">
      <div><dt>Run Outcome</dt><dd id="run-live-outcome"><%= viewOperationalOutcome || '-' %></dd></div>
      <div><dt>Started</dt><dd><%= run.startedAt || '-' %></dd></div>
      <div><dt>Completed</dt><dd id="run-live-completed"><%= run.completedAt || '-' %></dd></div>
      <div>
        <dt>Duration</dt>
        <dd id="run-live-duration" data-started-at="<%= run.startedAt || run.createdAt || '' %>" data-completed-at="<%= run.completedAt || '' %>">
          <% if (run.startedAt && run.completedAt) { %>
            <%= typeof formatDurationHuman === 'function' ? formatDurationHuman(Math.max(0, Math.round(new Date(run.completedAt) - new Date(run.startedAt)))) : Math.max(0, Math.round(new Date(run.completedAt) - new Date(run.startedAt))) + 'ms' %>
          <% } else if (['pending', 'running'].includes(run.status) && (run.startedAt || run.createdAt)) { %>
            running for 0 seconds
          <% } else { %>
            -
          <% } %>
        </dd>
      </div>
      <div><dt>Mutations</dt><dd><%= partialMutationCount || 0 %></dd></div>
      <div><dt>Phase</dt><dd><code id="run-live-phase"><%= run.currentPhase || '-' %></code></dd></div>
      <div><dt>Lease</dt><dd id="run-live-lease"><%= run.leaseOwner ? run.leaseOwner + (run.leaseExpiresAt ? ' until ' + run.leaseExpiresAt : '') : '-' %></dd></div>
      <div><dt>Last Heartbeat</dt><dd id="run-live-heartbeat"><%= run.lastHeartbeatAt || '-' %></dd></div>
      <% if (typeof eventSummary !== 'undefined' && eventSummary) { %>
        <div><dt>Event Status</dt><dd id="run-live-event-status"><%= eventSummary.latestStatus ? eventSummary.latestStatus.status : '-' %></dd></div>
        <div>
          <dt>Latest Workflow Step</dt>
          <dd>
            <% if (eventSummary.currentStep) { %>
              <code><%= eventSummary.currentStep.stepId %></code>
              <span class="text-muted"><%= eventSummary.currentStep.action || '' %> <%= eventSummary.currentStep.status || '' %></span>
            <% } else { %>-<% } %>
          </dd>
        </div>
        <div>
          <dt>Latest Workspace Mutation</dt>
          <dd>
            <% if (eventSummary.latestWorkspaceMutation) { %>
              <code><%= eventSummary.latestWorkspaceMutation.operation %></code>
              <% if (eventSummary.latestWorkspaceMutation.path) { %><code class="owned-path"><%= eventSummary.latestWorkspaceMutation.path %></code><% } %>
            <% } else { %>-<% } %>
          </dd>
        </div>
        <div><dt>Latest Event Error</dt><dd id="run-live-event-error"><%= eventSummary.latestError && eventSummary.latestError.message ? eventSummary.latestError.message : '-' %></dd></div>
      <% } %>
      <div style="grid-column:1/-1;"><dt>Current Message</dt><dd id="run-live-message">-</dd></div>
    </dl>

    <% if (snapshot && snapshot.terminalStatus && snapshot.terminalStatus !== run.status) { %>
      <div class="terminal-status-divider">
        <span class="text-muted">Terminal status:</span>
        <span class="status-badge status-<%= snapshot.terminalStatus %>"><%= snapshot.terminalStatus %></span>
      </div>
    <% } %>
    <% if (snapshot && (snapshot.failureReason || run.error)) { %>
      <div class="failure-reason-block">
        <span class="failure-reason"><%= failureSummary && failureSummary.finalBlockingReason ? failureSummary.finalBlockingReason : (snapshot.failureReason || run.error) %></span>
      </div>
    <% } %>
  </div>
</section>

<% if (hasRunAttention) { %>
<section class="zone">
<div class="zone-head" data-attn-zone><span class="zone-eyebrow">Needs your attention</span></div>

<% if (attentionPartialExecution) { %>
  <div class="attn critical partial-execution-banner">
    <h3><span class="sev">Critical</span> Partial execution</h3>
    <p>This run failed after performing <%= partialMutationCount %> workspace mutation<%= partialMutationCount === 1 ? '' : 's' %>.</p>
    <% if (operationHistory && operationHistory.length > 0) { %>
      <% if (failureSummary && !failureSummary.recoveryAvailable) { %>
        <p class="text-muted">This run has replay/evidence data, but no safe automatic recovery action is currently offered. Review Operation History before retrying or applying manual cleanup.</p>
      <% } else { %>
        <p class="text-muted">Review Operation History below for recovery options.</p>
      <% } %>
    <% } %>
  </div>
<% } %>

<% if (attentionStateWarning) { %>
  <div class="attn critical state-inconsistency-warning">
    <h3><span class="sev">Critical</span> State Warning</h3>
    <p><%= runStateInconsistency.message %></p>
    <% if (runStateInconsistency.reasons && runStateInconsistency.reasons.length > 0) { %>
      <ul>
        <% runStateInconsistency.reasons.forEach(reason => { %><li><%= reason %></li><% }) %>
      </ul>
    <% } %>
  </div>
<% } %>

<% if (run.triage && run.triage.required) { %>
  <div class="attn critical failure-summary">
    <h3><span class="sev">Critical</span> Triage Required</h3>
    <dl class="detail-grid">
      <div><dt>Reason</dt><dd><code><%= run.triage.reasonCode %></code></dd></div>
      <div><dt>Required decision</dt><dd><code><%= run.triage.requiredDecision %></code></dd></div>
      <div><dt>Summary</dt><dd><%= run.triage.summary %></dd></div>
      <div><dt>Created</dt><dd><%= run.triage.createdAt || '-' %></dd></div>
      <div><dt>Allowed next actions</dt><dd><%= run.triage.allowedActions.length > 0 ? run.triage.allowedActions.join(', ') : 'none' %></dd></div>
      <div><dt>Prohibited actions</dt><dd><%= run.triage.prohibitedActions.length > 0 ? run.triage.prohibitedActions.join(', ') : 'none' %></dd></div>
    </dl>
    <% if (run.triage.evidenceRefs.length > 0) { %>
      <p class="text-muted">Evidence:
        <% run.triage.evidenceRefs.forEach(ref => { %><code class="owned-path"><%= ref %></code> <% }) %>
      </p>
    <% } %>
    <p><a class="btn-small" href="/inbox?ticket=<%= run.ticketId %>">Respond in Inbox</a> <span class="text-muted">This blocker is a message thread — reply and resolve it there.</span></p>
  </div>
<% } else if (run.triage && run.triage.resolvedAt) { %>
  <div class="attn">
    <h3><span class="sev">Resolved</span> Triage (resolved)</h3>
    <dl class="detail-grid">
      <div><dt>Reason</dt><dd><code><%= run.triage.reasonCode %></code></dd></div>
      <div><dt>Required decision</dt><dd><code><%= run.triage.requiredDecision %></code></dd></div>
      <div><dt>Summary</dt><dd><%= run.triage.summary %></dd></div>
      <div><dt>Resolved by</dt><dd><%= run.triage.resolvedBy || '-' %></dd></div>
      <div><dt>Resolved at</dt><dd><%= run.triage.resolvedAt || '-' %></dd></div>
      <div><dt>Resolution</dt><dd><%= run.triage.resolution || '-' %></dd></div>
    </dl>
  </div>
<% } %>

<% if (attentionFailure) { %>
  <div class="attn critical failure-summary">
    <h3><span class="sev">Critical</span> Failure Summary</h3>
    <% if (failureSummary.retryGuidance) { %>
      <p class="failure-reason"><%= failureSummary.retryGuidance %></p>
    <% } %>
    <dl class="detail-grid">
      <div>
        <dt>Run Ended As</dt>
        <dd><span class="status-badge status-<%= failureSummary.status %>"><%= failureSummary.statusLabel %></span></dd>
      </div>
      <div>
        <dt>Root Cause</dt>
        <dd><span class="failure-reason"><%= failureSummary.rootCause %></span></dd>
      </div>
      <div>
        <dt>Final Blocking Reason</dt>
        <dd><%= failureSummary.finalBlockingReason %></dd>
      </div>
      <div>
        <dt>Last Model Message</dt>
        <dd><%= failureSummary.lastModelMessage %></dd>
      </div>
      <div>
        <dt>Last Proposed Actions</dt>
        <dd>
          <% if (failureSummary.lastProposedActions.length > 0) { %>
            <% failureSummary.lastProposedActions.forEach(action => { %>
              <code class="owned-path"><%= action %></code>
            <% }) %>
          <% } else { %>-<% } %>
        </dd>
      </div>
      <div>
        <dt>Mutations Performed</dt>
        <dd>
          <% if (failureSummary.mutationSummary.length > 0) { %>
            <% failureSummary.mutationSummary.forEach(action => { %>
              <code class="owned-path"><%= action %></code>
            <% }) %>
          <% } else { %>none<% } %>
        </dd>
      </div>
      <div>
        <dt>Output State</dt>
        <dd><%= failureSummary.outputSatisfaction.label %></dd>
      </div>
      <div>
        <dt>Recovery Action</dt>
        <dd><span class="badge badge--<%= failureSummary.recoveryAvailable ? 'recovery-recoverable' : 'outcome-noop' %>"><%= failureSummary.recoveryAvailable ? 'Available' : 'Not currently offered' %></span></dd>
      </div>
      <div>
        <dt>Debug Details</dt>
        <dd>
          <details class="collapsible">
            <summary>Raw failure details</summary>
            <div class="collapsible__content">
              <dl class="detail-grid">
                <div>
                  <dt>Blocking Code</dt>
                  <dd><code><%= failureSummary.blockingErrorCode %></code></dd>
                </div>
                <div>
                  <dt>Code Meaning</dt>
                  <dd><%= failureSummary.blockingErrorExplanation %></dd>
                </div>
                <div>
                  <dt>First Failed Operation</dt>
                  <dd><code class="owned-path"><%= failureSummary.firstFailedOperation %></code></dd>
                </div>
                <div>
                  <dt>Bounded Rejections</dt>
                  <dd><%= failureSummary.boundedTransitionRejectionCount %></dd>
                </div>
              </dl>
            </div>
          </details>
        </dd>
      </div>
    </dl>
  </div>
<% } %>

<% if (attentionReview) { %>
  <div class="attn <%= reviewStatus.needsReview ? '' : 'attn--calm' %>">
    <h3><span class="sev"><%= reviewStatus.needsReview ? 'Needs review' : 'Reviewed' %></span> Review status</h3>
    <% if (reviewStatus.needsReview) { %>
      <p><strong>Needs review</strong> — execution completed, but the result should be checked.</p>
      <p class="text-muted">The system verified declared postconditions / workspace evidence, not the full ticket objective.</p>
      <ul class="text-muted">
        <% reviewStatus.reasons.forEach(reason => { %>
          <li><%= reason %></li>
        <% }) %>
      </ul>
    <% } else { %>
      <p><strong>No review flag</strong> — no evidence warnings were detected.</p>
      <p class="text-muted">Completion reflects declared postconditions / workspace evidence, not independent verification of the full ticket objective.</p>
    <% } %>
  </div>
<% } %>
</section>
<% } %>

<div class="zone-head"><span class="zone-eyebrow">Outcome &amp; verification</span></div>

<% if (typeof completionSummary !== 'undefined' && completionSummary) { %>
<section class="detail-section completion-summary">
  <h2>Why this run stopped</h2>
  <dl class="detail-grid">
    <div>
      <dt>Outcome</dt>
      <dd><span class="status-badge status-<%= completionSummary.state %>"><%= completionSummary.state %></span></dd>
    </div>
    <div>
      <dt>Completion source</dt>
      <dd><code><%= completionSummary.source %></code></dd>
    </div>
    <div>
      <dt>Explanation</dt>
      <dd><%= completionSummary.label %></dd>
    </div>
  </dl>
  <% if (completionSummary.checkedPaths && completionSummary.checkedPaths.length > 0) { %>
    <div class="allocation-item-row">
      <span class="allocation-item-label">Checked paths</span>
      <span class="allocation-item-value">
        <% completionSummary.checkedPaths.forEach(check => { %>
          <code class="owned-path"><%= check.path %></code><%= check.type ? ' (' + check.type + ')' : '' %>
        <% }) %>
      </span>
    </div>
  <% } %>
  <% if (completionSummary.capNote) { %>
    <p class="completion-summary__cap-note"><%= completionSummary.capNote %></p>
  <% } %>
  <% if (completionSummary.timeoutNote) { %>
    <p class="completion-summary__cap-note"><%= completionSummary.timeoutNote %></p>
  <% } %>
  <% if (completionSummary.modelCallNote) { %>
    <p class="completion-summary__cap-note"><%= completionSummary.modelCallNote %></p>
  <% } %>
  <% if (completionSummary.progressNote) { %>
    <p class="completion-summary__cap-note"><%= completionSummary.progressNote %></p>
  <% } %>
  <p class="text-muted completion-summary__evidence">Evidence captured:
    <%= completionSummary.evidence.providerRequests %> provider request(s),
    <%= completionSummary.evidence.modelResponses %> model response(s),
    <%= completionSummary.evidence.workspaceOperations %> workspace action(s),
    <%= completionSummary.evidence.operationHistory %> operation-history record(s),
    <%= completionSummary.evidence.replayEvents %> replay event(s).</p>
</section>
<% } %>

<% if (run.runConsequence) { %>
<% const consequence = run.runConsequence; %>
<%
  const consequenceCategories = [
    ['created', 'Created'],
    ['updated', 'Updated'],
    ['renamed', 'Renamed'],
    ['deleted', 'Deleted']
  ].map(([key, label]) => [key, label, Array.isArray(consequence[key]) ? consequence[key] : []]);
  const consequenceAttempted = (Array.isArray(consequence.mutations) ? consequence.mutations : []).filter(item => item && item.attempted);
  const consequenceNotifications = Array.isArray(consequence.notifications) ? consequence.notifications : [];
  const consequenceExternalEffects = Array.isArray(consequence.externalEffects) ? consequence.externalEffects : [];
%>
<section class="detail-section" id="run-consequence">
  <h2>Recorded Consequence</h2>
  <p class="text-muted">The authoritative record of what this run changed, derived from operation history at terminalization. Empty categories mean nothing of that kind was recorded.</p>
  <dl class="detail-grid">
    <% consequenceCategories.forEach(([key, label, items]) => { %>
      <div>
        <dt><%= label %> (<%= items.length %>)</dt>
        <dd>
          <% if (items.length === 0) { %>none<% } else { %>
            <% items.forEach(item => { %>
              <div><code class="owned-path"><%= item.path || '-' %></code><% if (item.nextPath) { %> &rarr; <code class="owned-path"><%= item.nextPath %></code><% } %><% if (item.operation) { %> <span class="text-muted">(<%= item.operation %><%= item.historyId != null ? ' · history #' + item.historyId : '' %>)</span><% } %></div>
            <% }) %>
          <% } %>
        </dd>
      </div>
    <% }) %>
    <% if (consequenceAttempted.length > 0) { %>
      <div>
        <dt>Attempted (not committed) (<%= consequenceAttempted.length %>)</dt>
        <dd>
          <% consequenceAttempted.forEach(item => { %>
            <div><code class="owned-path"><%= item.path || '-' %></code><% if (item.operation) { %> <span class="text-muted">(<%= item.operation %>)</span><% } %></div>
          <% }) %>
        </dd>
      </div>
    <% } %>
    <div>
      <dt>Notifications (<%= consequenceNotifications.length %>)</dt>
      <dd><% if (consequenceNotifications.length === 0) { %>none<% } else { %><% consequenceNotifications.forEach(item => { %><div><code><%= JSON.stringify(item) %></code></div><% }) %><% } %></dd>
    </div>
    <div>
      <dt>External effects (<%= consequenceExternalEffects.length %>)</dt>
      <dd><% if (consequenceExternalEffects.length === 0) { %>none<% } else { %><% consequenceExternalEffects.forEach(item => { %><div><code><%= JSON.stringify(item) %></code></div><% }) %><% } %></dd>
    </div>
    <% if (consequence.verification) { %>
      <div>
        <dt>Verification rollup</dt>
        <dd>postconditions <code><%= consequence.verification.postconditionsStatus %></code> · violations <code><%= consequence.verification.violationsStatus %></code></dd>
      </div>
    <% } %>
  </dl>
  <details class="collapsible">
    <summary>Raw consequence record</summary>
    <pre class="code-block"><%= JSON.stringify(consequence, null, 2) %></pre>
  </details>
</section>
<% } %>

<% if (run.runEvaluation) { %>
<% const evaluation = run.runEvaluation; %>
<details class="disclosure">
  <summary>Run Evaluation <span class="sub">effectiveness <%= evaluation.effectiveness ? evaluation.effectiveness.status || 'unknown' : 'unknown' %> · violations <%= evaluation.violations ? evaluation.violations.status || 'unknown' : 'unknown' %></span></summary>
  <div class="body">
    <p class="text-muted">The recorded evaluation of this run: effectiveness against declared postconditions, measured efficiency, and detected violations.</p>
    <dl class="detail-grid">
      <% if (evaluation.effectiveness) { %>
        <div><dt>Effectiveness</dt><dd><code><%= evaluation.effectiveness.status || 'unknown' %></code></dd></div>
        <div><dt>Postconditions</dt><dd><%= evaluation.effectiveness.postconditionsPassed != null ? evaluation.effectiveness.postconditionsPassed + ' passed · ' + (evaluation.effectiveness.postconditionsFailed || 0) + ' failed' : '-' %></dd></div>
      <% } %>
      <% if (evaluation.efficiency) { %>
        <div><dt>Duration</dt><dd><%= evaluation.efficiency.durationMs != null ? (typeof formatDurationHuman === 'function' ? formatDurationHuman(evaluation.efficiency.durationMs) : evaluation.efficiency.durationMs + 'ms') : '-' %></dd></div>
        <div><dt>Provider requests / responses</dt><dd><%= evaluation.efficiency.providerRequests != null ? evaluation.efficiency.providerRequests : '-' %> / <%= evaluation.efficiency.modelResponses != null ? evaluation.efficiency.modelResponses : '-' %></dd></div>
        <div><dt>Workspace operations</dt><dd><%= evaluation.efficiency.workspaceOperations != null ? evaluation.efficiency.workspaceOperations : '-' %> (<%= evaluation.efficiency.mutationCount != null ? evaluation.efficiency.mutationCount : '-' %> mutating)</dd></div>
        <div><dt>Retries</dt><dd><%= evaluation.efficiency.retryCount != null ? evaluation.efficiency.retryCount : '-' %></dd></div>
      <% } %>
      <% if (evaluation.violations) { %>
        <div><dt>Violations</dt><dd><code><%= evaluation.violations.status || 'unknown' %></code><%= Array.isArray(evaluation.violations.items) && evaluation.violations.items.length > 0 ? ' · ' + evaluation.violations.items.length + ' item(s)' : '' %></dd></div>
      <% } %>
    </dl>
    <% if (evaluation.effectiveness && Array.isArray(evaluation.effectiveness.errors) && evaluation.effectiveness.errors.length > 0) { %>
      <p class="text-muted">Effectiveness errors:</p>
      <ul class="text-muted">
        <% evaluation.effectiveness.errors.forEach(error => { %><li><%= error %></li><% }) %>
      </ul>
    <% } %>
    <% if (evaluation.violations && Array.isArray(evaluation.violations.items) && evaluation.violations.items.length > 0) { %>
      <p class="text-muted">Violation items:</p>
      <% evaluation.violations.items.forEach(item => { %>
        <div><code><%= JSON.stringify(item) %></code></div>
      <% }) %>
    <% } %>
    <details class="collapsible">
      <summary>Raw evaluation record</summary>
      <pre class="code-block"><%= JSON.stringify(evaluation, null, 2) %></pre>
    </details>
  </div>
</details>
<% } %>

<section class="detail-section">
  <h2>Workflow Postconditions</h2>
  <% const declaredPostconditions = run.verificationContractSnapshot && Array.isArray(run.verificationContractSnapshot.postconditions) ? run.verificationContractSnapshot.postconditions : []; %>
  <% const checkedEvent = (typeof runEvents !== 'undefined' && runEvents ? runEvents.filter(event => event && event.type === 'run.postconditions_checked').pop() : null); %>
  <% const resultById = {}; %>
  <% if (checkedEvent && checkedEvent.payload && Array.isArray(checkedEvent.payload.results)) { %>
    <% checkedEvent.payload.results.forEach(result => { if (result && result.id) resultById[result.id] = result; }); %>
  <% } %>
  <% if (declaredPostconditions.length === 0) { %>
    <p class="text-muted">No workflow postconditions were declared for this run.</p>
  <% } else { %>
    <p class="text-muted">Deterministic checks declared by the workflow. Checked against recorded workspace/output evidence, not model judgment.</p>
    <ul class="postcondition-list">
      <% declaredPostconditions.forEach(pc => { %>
        <% const result = resultById[pc.id]; %>
        <li class="postcondition-item">
          <% if (result) { %>
            <span class="status-badge status-<%= result.passed ? 'completed' : 'failed' %>"><%= result.passed ? 'passed' : 'failed' %></span>
          <% } else { %>
            <span class="status-badge">not checked</span>
          <% } %>
          <code><%= typeof formatPostconditionAssertion === 'function' ? formatPostconditionAssertion(pc) : pc.type %></code>
          <% if (result && !result.passed && result.expected) { %>
            <div class="text-muted">Expected: <code><%= JSON.stringify(result.expected) %></code></div>
          <% } %>
          <% if (result && !result.passed && result.actual) { %>
            <div class="text-muted">Actual: <code><%= JSON.stringify(result.actual) %></code></div>
          <% } %>
        </li>
      <% }) %>
    </ul>
  <% } %>
  <% if (run.verificationContractSnapshot && run.verificationContractSnapshot.verifierContract) { %>
    <p class="text-muted"><strong>Fixture verifier not executed:</strong> <code><%= run.verificationContractSnapshot.verifierContract.id || 'unnamed' %></code> is offline benchmark metadata. Runtime completion is based only on the deterministic postconditions shown above.</p>
  <% } %>
</section>

<section class="detail-section">
  <h2>Artifact Prediction</h2>
  <% const artifactPrediction = snapshot && snapshot.artifactPrediction ? snapshot.artifactPrediction : null; %>
  <% const predictedArtifacts = artifactPrediction && Array.isArray(artifactPrediction.artifacts) ? artifactPrediction.artifacts : []; %>
  <% const predictionComparison = typeof artifactPredictionComparison === 'undefined' || !artifactPredictionComparison ? { matched: [], missing: [], unexpected: [] } : artifactPredictionComparison; %>
  <% const predictionAccuracy = typeof artifactAccuracy === 'undefined' || !artifactAccuracy ? { scored: false, score: null, percent: null, matched: 0, total: 0, missing: 0, unexpected: 0 } : artifactAccuracy; %>
  <% const runObjectiveSuccess = typeof objectiveSuccess === 'undefined' || !objectiveSuccess ? { scored: false, status: 'unknown', score: null, percent: null, reason: null } : objectiveSuccess; %>
  <% const runObjectivePathCoverage = typeof objectivePathCoverage === 'undefined' || !objectivePathCoverage ? { scored: false, percent: null, covered: 0, total: 0, missing: [], objectivePaths: [], plannedPaths: [] } : objectivePathCoverage; %>
  <% const matchedPredictionKeys = new Set((predictionComparison.matched || []).map(item => item.key)); %>
  <% const missingPredictionKeys = new Set((predictionComparison.missing || []).map(item => item.key)); %>
  <% function predictionKey(item) { const type = item && item.type === 'workflow draft' ? 'workflowDraft' : (item && item.type ? item.type : 'unknown'); const artifact = String(item && item.artifact ? item.artifact : '').trim().replace(/^\.\//, ''); return type + ':' + artifact; } %>
  <p><strong>Objective Success:</strong> <% if (runObjectiveSuccess.scored) { %><%= runObjectiveSuccess.status === 'succeeded' ? 'Yes' : 'No · ' + runObjectiveSuccess.status %><% } else { %><%= runObjectiveSuccess.status === 'unverified' ? 'Unverified' : 'Not scored' %><% } %></p>
  <p><strong>Objective Path Coverage:</strong> <% if (runObjectivePathCoverage.scored) { %><%= runObjectivePathCoverage.percent %>% · <%= runObjectivePathCoverage.covered %>/<%= runObjectivePathCoverage.total %> covered<% } else { %>Not scored<% } %></p>
  <p><strong>Artifact Accuracy:</strong> <% if (predictionAccuracy.scored) { %><%= predictionAccuracy.percent %>% · <%= predictionAccuracy.matched %>/<%= predictionAccuracy.total %> matched<% } else { %>Not scored<% } %></p>
  <% if (predictedArtifacts.length === 0) { %>
    <p class="text-muted">No artifact prediction captured.</p>
  <% } else { %>
    <p class="text-muted">Captured from the first accepted model plan with artifact-producing actions.</p>
    <dl class="detail-grid">
      <div>
        <dt>Matched</dt>
        <dd><%= (predictionComparison.matched || []).length %></dd>
      </div>
      <div>
        <dt>Missing</dt>
        <dd><%= (predictionComparison.missing || []).length %></dd>
      </div>
      <div>
        <dt>Unexpected</dt>
        <dd><%= (predictionComparison.unexpected || []).length %></dd>
      </div>
    </dl>
    <div class="table-scroll-wrap">
      <table class="tickets-table">
        <thead>
          <tr>
            <th>Type</th>
            <th>Artifact</th>
            <th>Operation</th>
            <th>Step</th>
            <th>Actual</th>
          </tr>
        </thead>
        <tbody>
          <% predictedArtifacts.forEach(function(prediction) { %>
            <% const key = predictionKey(prediction); %>
            <% const matched = matchedPredictionKeys.has(key); %>
            <% const missing = missingPredictionKeys.has(key); %>
            <tr>
              <td><%= prediction.type || '-' %></td>
              <td><code class="owned-path"><%= prediction.artifact || '-' %></code></td>
              <td><code><%= prediction.operation || '-' %></code></td>
              <td><%= prediction.step !== undefined ? prediction.step : '-' %></td>
              <td>
                <% if (matched) { %>
                  <span class="badge badge--outcome-success">matched</span>
                <% } else if (missing) { %>
                  <span class="badge badge--outcome-error">missing</span>
                <% } else { %>
                  <span class="badge badge--outcome-noop">unknown</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% if ((predictionComparison.unexpected || []).length > 0) { %>
      <h3>Unexpected Actual Artifacts</h3>
      <div class="table-scroll-wrap">
        <table class="tickets-table">
          <thead>
            <tr>
              <th>Type</th>
              <th>Artifact</th>
              <th>Source</th>
            </tr>
          </thead>
          <tbody>
            <% (predictionComparison.unexpected || []).forEach(function(actual) { %>
              <tr>
                <td><%= actual.type || '-' %></td>
                <td><code class="owned-path"><%= actual.artifact || '-' %></code></td>
                <td><%= actual.source || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <p class="text-muted">
      Source: <code><%= artifactPrediction.source || '-' %></code>
      · Captured: <span><%= artifactPrediction.capturedAt || '-' %></span>
    </p>
  <% } %>
</section>

<% if (snapshot && (snapshot.browserTargetSnapshot || (snapshot.browserOperations && snapshot.browserOperations.length > 0))) { %>
  <% const browserEvidenceStatus = snapshot.browserEvidenceStatus || (run.replaySummary && run.replaySummary.browserEvidenceStatus) || null; %>
  <% const browserEvidenceDetail = snapshot.browserEvidenceDetail || (run.replaySummary && run.replaySummary.browserEvidenceDetail) || null; %>
  <% const browserReport = snapshot.browserReport || run.browserReport || null; %>
  <% if (browserEvidenceStatus) { %>
  <section class="detail-section" id="browser-evidence-status">
    <h2>Browser Evidence Status</h2>
    <dl class="detail-grid">
      <div><dt>Status</dt><dd><strong class="badge badge--outcome-<%= browserEvidenceStatus === 'evidence_available' ? 'success' : browserEvidenceStatus === 'target_blocked_or_redirected' ? 'error' : 'warning' %>"><%= browserEvidenceStatus %></strong></dd></div>
      <% if (browserEvidenceDetail) { %><div><dt>Detail</dt><dd><%= browserEvidenceDetail %></dd></div><% } %>
      <div><dt>Runtime status</dt><dd><%= snapshot.terminalStatus || run.status || '-' %> (independent of browser evidence)</dd></div>
    </dl>
  </section>
  <% } %>
  <% if (browserReport && browserReport.status === 'available') { %>
  <section class="detail-section" id="browser-report">
    <h2>Browser Report</h2>
    <div class="browser-report-text">
      <p><%= browserReport.text %></p>
    </div>
    <dl class="detail-grid">
      <div><dt>Runtime status</dt><dd><%= snapshot.terminalStatus || run.status || '-' %></dd></div>
      <div><dt>Browser evidence status</dt><dd><%= browserEvidenceStatus || '-' %></dd></div>
      <div><dt>Browser report</dt><dd>available</dd></div>
      <div><dt>Objective success</dt><dd>unverified</dd></div>
    </dl>
  </section>
  <% } else { %>
  <section class="detail-section" id="browser-report">
    <h2>Browser Report</h2>
    <p class="text-muted">Browser report: not available.</p>
  </section>
  <% } %>
<% } %>

<% if (typeof attemptUsage !== 'undefined' && attemptUsage) { %>
<details class="disclosure">
  <summary>Usage / Attempt <span class="sub"><%= attemptUsage.attemptNumber === null ? '' : 'attempt ' + attemptUsage.attemptNumber + ' of ' + attemptUsage.attemptCount + ' · ' %><%= attemptUsage.outcome || 'unavailable' %></span></summary>
  <div class="body">
    <p class="text-muted">Measured from this run's recorded evidence. Counts shown as "unavailable" were not observable for this run. Measurement only — no limits are enforced.</p>
    <dl class="detail-grid">
      <div><dt>Attempt</dt><dd><%= attemptUsage.attemptNumber === null ? 'unavailable' : 'attempt ' + attemptUsage.attemptNumber + ' of ' + attemptUsage.attemptCount %></dd></div>
      <div><dt>Outcome</dt><dd><code><%= attemptUsage.outcome || 'unavailable' %></code></dd></div>
      <div><dt>Duration</dt><dd><%= attemptUsage.durationMs === null ? 'unavailable' : (typeof formatDurationHuman === 'function' ? formatDurationHuman(attemptUsage.durationMs) : attemptUsage.durationMs + 'ms') %></dd></div>
      <div><dt>Model requests</dt><dd><%= attemptUsage.modelRequestCount === null ? 'unavailable' : attemptUsage.modelRequestCount %></dd></div>
      <div><dt>Workspace operations</dt><dd><%= attemptUsage.workspaceOperationCount === null ? 'unavailable' : attemptUsage.workspaceOperationCount %></dd></div>
      <div><dt>Mutating workspace operations</dt><dd><%= attemptUsage.mutatingWorkspaceOperationCount === null ? 'unavailable' : attemptUsage.mutatingWorkspaceOperationCount %></dd></div>
      <div><dt>Verification</dt><dd><%= attemptUsage.verificationRequired ? 'required · ' + attemptUsage.verificationOutcome : 'not required' %></dd></div>
      <div><dt>Triage</dt><dd><%= attemptUsage.triageRequired ? 'required' : 'none' %></dd></div>
    </dl>
  </div>
</details>
<% } %>

<% if (typeof runtimeLimitsDisplay !== 'undefined' && runtimeLimitsDisplay) { %>
<%
  function runtimeLimitPair(used, limit, duration) {
    var usedText = used === null || used === undefined
      ? 'unavailable'
      : (duration && typeof formatDurationHuman === 'function' ? formatDurationHuman(used) : used);
    var limitText = duration && typeof formatDurationHuman === 'function' ? formatDurationHuman(limit) : limit;
    return usedText + ' / ' + limitText;
  }
%>
<details class="disclosure">
  <summary>Runtime limits and usage <span class="sub"><%= runtimeLimitsDisplay.limitOutcome %></span></summary>
  <div class="body">
    <p class="text-muted"><%= runtimeLimitsDisplay.sourceLabel %>.</p>
    <dl class="detail-grid">
      <div><dt>Execution turns</dt><dd><%= runtimeLimitPair(runtimeLimitsDisplay.usage.executionTurns, runtimeLimitsDisplay.limits.maxExecutionSteps, false) %></dd></div>
      <div><dt>Runtime</dt><dd><%= runtimeLimitPair(runtimeLimitsDisplay.usage.runtimeMs, runtimeLimitsDisplay.limits.maxRuntimeDurationMs, true) %></dd></div>
      <div><dt>Model requests</dt><dd><%= runtimeLimitPair(runtimeLimitsDisplay.usage.modelRequests, runtimeLimitsDisplay.limits.maxModelRequestsPerRun, false) %></dd></div>
      <div><dt>Workspace operations</dt><dd><%= runtimeLimitPair(runtimeLimitsDisplay.usage.workspaceOperations, runtimeLimitsDisplay.limits.maxWorkspaceOperationsPerRun, false) %></dd></div>
      <div><dt>Limit outcome</dt><dd><code><%= runtimeLimitsDisplay.limitOutcome %></code></dd></div>
      <% if (runtimeLimitsDisplay.providerSymptom) { %>
        <div><dt>Provider symptom</dt><dd><%= runtimeLimitsDisplay.providerSymptom %></dd></div>
      <% } %>
    </dl>
  </div>
</details>
<% } %>

<% if (typeof budgetStatus !== 'undefined' && budgetStatus) { %>
<%
  function budgetCell(m, unit) {
    unit = unit || '';
    if (m.status === 'not_configured') return 'not configured';
    if (m.status === 'unavailable') return 'unavailable';
    var pair = m.usage + unit + ' / ' + m.threshold + unit;
    return m.status === 'exceeded' ? (pair + ' · exceeded (advisory)') : (pair + ' · within limit');
  }
  const budgetExceededCount = ['runtimeMs', 'modelRequests', 'workspaceOperations']
    .filter(key => budgetStatus[key] && budgetStatus[key].status === 'exceeded').length;
%>
<details class="disclosure">
  <summary>Budget (advisory) <span class="sub"><%= budgetExceededCount > 0 ? budgetExceededCount + ' threshold(s) exceeded' : 'within thresholds' %></span></summary>
  <div class="body">
    <p class="text-muted">Advisory only — no execution is blocked. Recorded usage compared against this run's recorded thresholds; an exceeded threshold is a warning, not a limit.</p>
    <dl class="detail-grid">
      <div><dt>Runtime</dt><dd><%= budgetCell(budgetStatus.runtimeMs, 'ms') %></dd></div>
      <div><dt>Model requests</dt><dd><%= budgetCell(budgetStatus.modelRequests, '') %></dd></div>
      <div><dt>Workspace operations</dt><dd><%= budgetCell(budgetStatus.workspaceOperations, '') %></dd></div>
    </dl>
  </div>
</details>
<% } %>

<div class="zone-head"><span class="zone-eyebrow">How it was set up</span></div>

<details class="disclosure">
  <summary>Work Type Snapshot <span class="sub"><%= run.workTypeSnapshot ? run.workTypeSnapshot.name : 'Unspecified' %></span></summary>
  <div class="body">
    <% if (run.workTypeSnapshot) { %>
      <dl class="detail-grid">
        <div><dt>Name</dt><dd><strong><%= run.workTypeSnapshot.name %></strong> · <code><%= run.workTypeSnapshot.id %></code></dd></div>
        <div><dt>Description</dt><dd><%= run.workTypeSnapshot.description %></dd></div>
        <div><dt>Status when captured</dt><dd><code><%= run.workTypeSnapshot.status %></code></dd></div>
        <div><dt>Allowed target kinds</dt><dd><% run.workTypeSnapshot.allowedTargetKinds.forEach(function(kind) { %><code><%= kind %></code> <% }); %></dd></div>
        <div><dt>Captured on ticket</dt><dd><%= run.workTypeSnapshot.capturedAt %></dd></div>
      </dl>
    <% } else { %>
      <p class="text-muted">Unspecified</p>
    <% } %>
    <p class="text-muted">Immutable semantic context copied from the ticket. It is not authority and does not grant operations.</p>
  </div>
</details>

<details class="disclosure">
  <summary>Acceptance Criteria Snapshot <span class="sub"><%= run.acceptanceCriteriaSnapshot ? 'Captured' : 'None captured' %></span></summary>
  <div class="body">
    <% if (run.acceptanceCriteriaSnapshot) { %>
      <p style="white-space:pre-wrap;"><%= run.acceptanceCriteriaSnapshot %></p>
    <% } else { %>
      <p class="text-muted">No acceptance criteria were captured for this run.</p>
      <p class="text-muted">Runs capture acceptance criteria at creation time; this run has no captured criteria.</p>
    <% } %>
    <p class="text-muted">Frozen at run creation and supplied to the agent as part of the requested outcome; arbitrary prose criteria are not automatically verified.</p>
  </div>
</details>

<% if (run.executionPolicySnapshot) { %>
<details class="disclosure">
  <summary>Execution Policy Snapshot <span class="sub">verification <%= run.executionPolicySnapshot.requireVerification %></span></summary>
  <div class="body">
    <p class="text-muted">Policy copied from the ticket when this run was created.</p>
    <p class="text-muted">Verification is enforced when declared. Other fields below are recorded intent and are not enforced in this release unless explicitly noted.</p>
    <dl class="detail-grid">
      <div><dt>Verification</dt><dd><code><%= run.executionPolicySnapshot.requireVerification %></code> · enforced for declared workflow postconditions</dd></div>
      <div><dt>Workspace scope</dt><dd><code><%= run.executionPolicySnapshot.workspaceScope %></code> · enforced by this run's workspace path</dd></div>
      <div><dt>Mode</dt><dd><code><%= run.executionPolicySnapshot.mode %></code> · recorded intent, not enforced</dd></div>
      <div><dt>Workspace writes</dt><dd><%= run.executionPolicySnapshot.allowWorkspaceWrites ? 'requested' : 'not requested' %> · recorded intent, not enforced</dd></div>
      <div><dt>Parallel runs</dt><dd><%= run.executionPolicySnapshot.allowParallelRuns ? 'requested' : 'not requested' %> · recorded intent, not enforced</dd></div>
      <div><dt>Child tickets</dt><dd><%= run.executionPolicySnapshot.allowChildTickets ? 'requested' : 'not requested' %> · recorded intent, not enforced</dd></div>
      <div><dt>Max attempts</dt><dd><%= run.executionPolicySnapshot.maxAttempts === null ? 'unlimited · enforced for manual rerun-from-start when set' : run.executionPolicySnapshot.maxAttempts + ' · enforced for manual rerun-from-start' %></dd></div>
      <div><dt>Max runtime</dt><dd><%= run.executionPolicySnapshot.maxRuntimeMs === null ? 'unspecified' : run.executionPolicySnapshot.maxRuntimeMs + 'ms' %> · recorded intent, not enforced</dd></div>
      <div><dt>Max model requests</dt><dd><%= run.executionPolicySnapshot.maxModelRequests === null ? 'unspecified' : run.executionPolicySnapshot.maxModelRequests %> · recorded intent, not enforced</dd></div>
      <div><dt>Max workspace operations</dt><dd><%= run.executionPolicySnapshot.maxWorkspaceOperations === null ? 'unspecified' : run.executionPolicySnapshot.maxWorkspaceOperations %> · recorded intent, not enforced</dd></div>
    </dl>
  </div>
</details>
<% } %>

<% if (typeof routingDisplay !== 'undefined' && routingDisplay) { %>
<details class="disclosure">
  <summary>Routing decision <span class="sub"><%= routingDisplay.provider || 'unavailable' %> / <%= routingDisplay.model || 'unavailable' %></span></summary>
  <div class="body">
    <p class="text-muted"><%= routingDisplay.sourceLabel %> — may differ from the runtime context.</p>
    <dl class="detail-grid">
      <div><dt>Provider</dt><dd><%= routingDisplay.provider || 'unavailable' %></dd></div>
      <div><dt>Model</dt><dd><%= routingDisplay.model || 'unavailable' %></dd></div>
      <div><dt>Routing reason</dt><dd><code><%= routingDisplay.reason || 'unavailable' %></code></dd></div>
      <div><dt>Fallback used</dt><dd><code><%= routingDisplay.fallbackUsed === true ? 'yes' : (routingDisplay.fallbackUsed === false ? 'no' : 'unavailable') %></code></dd></div>
    </dl>
  </div>
</details>
<% } %>

<details class="disclosure">
  <summary>Authority &amp; Scope <span class="sub"><%= typeof authorityContext !== 'undefined' && authorityContext ? authorityContext.principal.agentName : 'unavailable' %></span></summary>
  <div class="body">
    <% const ac = typeof authorityContext === 'undefined' ? null : authorityContext; %>
    <% if (ac) { %>

    <div class="authority-grid">
      <div class="authority-column">
        <h3 class="authority-column-title">Principal</h3>
        <dl class="authority-dl">
          <div class="authority-row">
            <dt>Agent</dt>
            <dd><%= ac.principal.agentName %></dd>
          </div>
          <% if (ac.principal.allocationPlanId) { %>
            <div class="authority-row">
              <dt>Allocation Plan</dt>
              <dd>#<%= ac.principal.allocationPlanId %></dd>
            </div>
            <div class="authority-row">
              <dt>Allocation Item</dt>
              <dd>#<%= ac.principal.allocationItemId %><% if (ac.principal.allocationSubtask) { %> · <%= ac.principal.allocationSubtask %><% } %></dd>
            </div>
          <% } %>
          <% if (ac.principal.ownedOutputPaths.length > 0) { %>
            <div class="authority-row">
              <dt>Owned Paths</dt>
              <dd>
                <% ac.principal.ownedOutputPaths.forEach(function(p) { %>
                  <code class="owned-path"><%= p %></code>
                <% }) %>
              </dd>
            </div>
          <% } else { %>
            <div class="authority-row">
              <dt>Owned Paths</dt>
              <dd><span class="text-muted">None (full workspace)</span></dd>
            </div>
          <% } %>
        </dl>
      </div>

      <div class="authority-column">
        <h3 class="authority-column-title">Authority</h3>
        <dl class="authority-dl">
          <div class="authority-row">
            <dt>Allowed Ops</dt>
            <dd><code class="auth-code"><%= ac.authority.allowedOperations.join(', ') %></code></dd>
          </div>
          <div class="authority-row">
            <dt>Mutating Ops</dt>
            <dd><code class="auth-code"><%= ac.authority.mutatingOperations.join(', ') %></code></dd>
          </div>
          <div class="authority-row">
            <dt>Max Actions</dt>
            <dd><%= ac.authority.maxActionsPerResponse %> per response · <%= ac.authority.maxMutatingActionsPerResponse %> mutating</dd>
          </div>
          <div class="authority-row">
            <dt>Max Steps</dt>
            <dd><%= ac.authority.maxSteps %></dd>
          </div>
          <div class="authority-row">
            <dt>Max Ops</dt>
            <dd><%= ac.authority.maxWorkspaceOperations %> workspace · <%= ac.authority.maxModelRequests %> model requests</dd>
          </div>
          <div class="authority-row">
            <dt>Max Runtime</dt>
            <dd><%= typeof formatDurationHuman === 'function' ? formatDurationHuman(ac.authority.maxRuntimeDurationMs) : ac.authority.maxRuntimeDurationMs + 'ms' %></dd>
          </div>
          <div class="authority-row">
            <dt>Provider/Model</dt>
            <dd><%= ac.authority.provider %> / <%= ac.authority.model %></dd>
          </div>
          <div class="authority-row">
            <dt>Workspace Type</dt>
            <dd><%= ac.authority.executionWorkspaceType %></dd>
          </div>
          <% if (ac.authority.workspaceRoot !== '-') { %>
            <div class="authority-row">
              <dt>Workspace Root</dt>
              <dd><code class="auth-code"><%= ac.authority.workspaceRoot %></code></dd>
            </div>
          <% } %>
          <% if (ac.provenance) { %>
            <div class="authority-row">
              <dt>Granted By</dt>
              <dd><%= ac.provenance.assignment %></dd>
            </div>
            <div class="authority-row">
              <dt>Agent Groups</dt>
              <dd><%= ac.provenance.groups %></dd>
            </div>
            <div class="authority-row">
              <dt>Runtime Policy</dt>
              <dd><%= ac.provenance.runtimePolicy %></dd>
            </div>
            <div class="authority-row">
              <dt>Scope Source</dt>
              <dd><%= ac.provenance.scope %></dd>
            </div>
          <% } %>
        </dl>
      </div>

      <div class="authority-column">
        <h3 class="authority-column-title">Runtime Controls</h3>
        <dl class="authority-dl">
          <div class="authority-row">
            <dt>Interruptible</dt>
            <dd><span class="badge badge--<%= ac.controls.interruptible ? 'outcome-success' : 'outcome-noop' %>"><%= ac.controls.interruptible ? 'Yes' : 'No' %></span></dd>
          </div>
          <div class="authority-row">
            <dt>Recovery Analysis</dt>
            <dd><span class="badge badge--<%= ac.controls.recoverable ? 'outcome-success' : 'outcome-noop' %>"><%= ac.controls.recoverable ? 'Possible' : 'Not available' %></span></dd>
          </div>
          <div class="authority-row">
            <dt>Replay Evidence</dt>
            <dd><span class="badge badge--<%= ac.controls.replayAvailable ? 'outcome-success' : 'outcome-error' %>"><%= ac.controls.replayAvailable ? 'Available' : 'Not available' %></span></dd>
          </div>
          <div class="authority-row">
            <dt>Recovery Action</dt>
            <dd><% if (ac.controls.recoveryAvailable === true) { %><span class="badge badge--recovery-recoverable">Available</span><% } else if (ac.controls.recoveryAvailable === false) { %><span class="badge badge--outcome-noop">Not currently offered</span><% } else { %><span class="badge badge--outcome-noop">N/A</span><% } %></dd>
          </div>
        </dl>
      </div>
    </div>

    <% } else { %>
      <p class="text-muted">Authority context not available for this run.</p>
    <% } %>
  </div>
</details>

<details class="disclosure">
  <summary>Run Context <span class="sub"><%= run.executionWorkspaceType || (snapshot && snapshot.executionWorkspaceType) || 'main' %> workspace</span></summary>
  <div class="body">
    <dl class="detail-grid">
      <div>
        <dt>Created</dt>
        <dd><%= run.createdAt || '-' %></dd>
      </div>
      <div>
        <dt>Batch Marker</dt>
        <dd><%= run.ticketOpenedAt || '-' %></dd>
      </div>
      <div>
        <dt>Workspace</dt>
        <dd><%= run.executionWorkspaceType || (snapshot && snapshot.executionWorkspaceType) || 'main' %></dd>
      </div>
      <div>
        <dt>Work Split</dt>
        <dd><%= run.allocationPlanId || (snapshot && snapshot.allocationPlanId) || '-' %></dd>
      </div>
      <div>
        <dt>Work Unit</dt>
        <dd><%= run.allocationItemId || (snapshot && snapshot.allocationItemId) || '-' %></dd>
      </div>
      <div>
        <dt>Main Workspace</dt>
        <dd><%= (typeof authorityContext !== 'undefined' && authorityContext && authorityContext.authority) ? authorityContext.authority.workspaceRoot : ((snapshot && snapshot.mainWorkspaceRoot) || '-') %></dd>
      </div>
      <div>
        <dt>Allowed Folders</dt>
        <dd>
          <% const ownedPaths = (run.ownedOutputPaths && run.ownedOutputPaths.length ? run.ownedOutputPaths : (snapshot && snapshot.ownedOutputPaths) || []); %>
          <% if (ownedPaths.length > 0) { %>
            <% ownedPaths.forEach(ownedPath => { %>
              <a class="owned-path-link" href="/workspace?path=<%= encodeURIComponent(String(ownedPath).replace(/^\/+/, '')) %>" title="Open in Workspace environment"><code class="owned-path"><%= ownedPath %></code></a>
            <% }) %>
          <% } else { %>-<% } %>
        </dd>
      </div>
      <div>
        <dt>Subtask</dt>
        <dd><%= run.allocationSubtask || (snapshot && snapshot.allocationSubtask) || '-' %></dd>
      </div>
      <% if (snapshot && snapshot.provider) { %>
        <div>
          <dt>Provider</dt>
          <dd><%= snapshot.provider %></dd>
        </div>
      <% } %>
      <% if (snapshot && snapshot.model) { %>
        <div>
          <dt>Model</dt>
          <dd><%= snapshot.model %></dd>
        </div>
      <% } %>
    </dl>
  </div>
</details>

<% if (snapshot) { %>
  <details class="disclosure">
    <summary>Ticket Objective</summary>
    <div class="body">
      <pre class="run-text"><%= snapshot.ticketObjectiveSnapshot || (ticket && ticket.objective) || '-' %></pre>
    </div>
  </details>

  <details class="disclosure">
    <summary>Prompt Instructions</summary>
    <div class="body">
      <pre class="run-text"><%= snapshot.systemInstructionSnapshot || '-' %></pre>
    </div>
  </details>

  <details class="disclosure">
    <summary><%= snapshot.browserTargetSnapshot ? 'Allowed Browser Actions' : 'Allowed Workspace Actions' %> <span class="sub">primitive contract</span></summary>
    <div class="body">
      <pre class="code-block"><%= JSON.stringify(snapshot.primitiveContract || {}, null, 2) %></pre>
    </div>
  </details>

  <details class="disclosure">
    <summary>Technical Runtime Details <span class="sub">runtime envelope</span></summary>
    <div class="body">
      <pre class="code-block"><%= JSON.stringify(snapshot.runtimeEnvelope || {}, null, 2) %></pre>
    </div>
  </details>
<% } %>

<div class="zone-head"><span class="zone-eyebrow">What the system did</span></div>

<% if (!snapshot) { %>
  <section class="detail-section">
    <h2>Replay Snapshot</h2>
    <p class="text-muted">No replay snapshot is available for this run.</p>
  </section>
<% } else { %>
  <%
    const replayWorkspaceOps = snapshot.workspaceOperations || [];
    const replayEvents = snapshot.events || [];
    const replayMutationOps = ['createFolder', 'writeFile', 'renamePath', 'deletePath'];
    const replayHasMutations = replayWorkspaceOps.some(op => op.operation && replayMutationOps.includes(op.operation.operation));
    const replayHasFailures = replayWorkspaceOps.some(op => op.blocked || op.error)
      || replayEvents.some(ev => ev.type && (ev.type.includes('fail') || ev.type.includes('error') || ev.type.includes('limit')));
  %>
  <div class="replay-nav">
    <span class="replay-nav-label">Replay navigation:</span>
    <button type="button" class="btn-small" data-replay-toggle-all>Expand details</button>
    <% if (snapshot.browserTargetSnapshot) { %>
      <button type="button" class="btn-small" data-replay-jump="browser">Browser operations</button>
    <% } else { %>
      <button type="button" class="btn-small" data-replay-jump="workspace">Workspace actions</button>
    <% } %>
    <% if (replayHasFailures) { %>
      <button type="button" class="btn-small" data-replay-jump="failure">Failures</button>
    <% } else { %>
      <button type="button" class="btn-small" disabled title="No failures in this run">Failures</button>
    <% } %>
    <% if (replayHasMutations) { %>
      <button type="button" class="btn-small" data-replay-jump="mutation">Mutations</button>
    <% } else { %>
      <button type="button" class="btn-small" disabled title="No workspace mutations in this run">Mutations</button>
    <% } %>
  </div>

  <section class="detail-section replay-section" data-replay-section="providerRequests">
    <details class="collapsible">
      <summary>Provider Requests (<%= (snapshot.providerRequests || []).length %>)</summary>
      <div class="collapsible__content">
        <% if (!snapshot.providerRequests || snapshot.providerRequests.length === 0) { %>
          <p class="text-muted">No provider requests captured.</p>
        <% } %>
        <% (snapshot.providerRequests || []).forEach((requestPayload, index) => { %>
          <div class="replay-sub-item">
            <div class="replay-sub-item-header">
              <span class="replay-sub-item-label">Request <%= index + 1 %></span>
              <% if (requestPayload.durationMs !== undefined) { %>
                <span class="badge badge--timing"><%= requestPayload.durationMs %>ms</span>
              <% } %>
            </div>
            <pre class="code-block"><%= JSON.stringify(requestPayload, null, 2) %></pre>
          </div>
        <% }) %>
      </div>
    </details>
  </section>

  <section class="detail-section replay-section" data-replay-section="modelResponses">
    <details class="collapsible">
      <summary>Model Responses (<%= (snapshot.modelResponses || []).length %>)</summary>
      <div class="collapsible__content">
        <% if (!snapshot.modelResponses || snapshot.modelResponses.length === 0) { %>
          <p class="text-muted">No model responses captured.</p>
        <% } %>
        <% (snapshot.modelResponses || []).forEach((responsePayload, index) => { %>
          <div class="replay-sub-item">
            <div class="replay-sub-item-header">
              <span class="replay-sub-item-label">Response <%= index + 1 %></span>
              <% if (responsePayload.durationMs !== undefined) { %>
                <span class="badge badge--timing"><%= responsePayload.durationMs %>ms</span>
              <% } %>
            </div>
            <pre class="code-block"><%= JSON.stringify(responsePayload, null, 2) %></pre>
          </div>
        <% }) %>
      </div>
    </details>
  </section>

  <% if (snapshot.browserTargetSnapshot || (snapshot.browserOperations && snapshot.browserOperations.length > 0)) { %>
  <section class="detail-section replay-section" id="replay-browser-operations" data-replay-section="browserOperations">
    <details class="collapsible">
      <summary>Browser Operations (<%= (snapshot.browserOperations || []).length %>)</summary>
      <div class="collapsible__content">
        <% if (snapshot.browserTargetSnapshot) { const browserSnapshotLimits = snapshot.browserTargetSnapshot.limits || {}; %>
          <div class="replay-sub-item">
            <div class="replay-sub-item-header"><span class="replay-sub-item-label">Browser Target Snapshot</span></div>
            <p class="text-muted">Immutable configuration captured when this run was created.</p>
            <dl class="detail-grid">
              <div><dt>Target</dt><dd><strong><%= snapshot.browserTargetSnapshot.name || '-' %></strong> · <code><%= snapshot.browserTargetSnapshot.id || '-' %></code></dd></div>
              <div><dt>Status</dt><dd><%= snapshot.browserTargetSnapshot.status || '-' %></dd></div>
              <div><dt>Start URL</dt><dd><code><%= snapshot.browserTargetSnapshot.startUrl || '-' %></code></dd></div>
              <div><dt>Allowed origins</dt><dd><% (snapshot.browserTargetSnapshot.allowedOrigins || []).forEach(function(origin) { %><div><code><%= origin %></code></div><% }); %></dd></div>
              <div><dt>Read-only operations</dt><dd><code>navigate</code>, <code>observe</code>, <code>readPageText</code>, <code>screenshot</code>, <code>wait</code></dd></div>
              <div><dt>maxNavigationsPerRun</dt><dd><code><%= browserSnapshotLimits.maxNavigationsPerRun || '-' %></code></dd></div>
              <div><dt>maxActionsPerRun</dt><dd><code><%= browserSnapshotLimits.maxActionsPerRun || '-' %></code></dd></div>
              <div><dt>navTimeoutMs</dt><dd><code><%= browserSnapshotLimits.navTimeoutMs || '-' %></code></dd></div>
              <div><dt>waitTimeoutMsCap</dt><dd><code><%= browserSnapshotLimits.waitTimeoutMsCap || '-' %></code></dd></div>
              <div><dt>maxPageTextBytes</dt><dd><code><%= browserSnapshotLimits.maxPageTextBytes || '-' %></code></dd></div>
              <div><dt>maxScreenshotsPerRun</dt><dd><code><%= browserSnapshotLimits.maxScreenshotsPerRun || '-' %></code></dd></div>
            </dl>
          </div>
        <% } %>
        <% if (!snapshot.browserOperations || snapshot.browserOperations.length === 0) { %>
          <p class="text-muted">No browser operations captured.</p>
        <% } %>
        <% (snapshot.browserOperations || []).forEach((item, index) => { %>
          <% const receipt = item.receipt || {}; const metadata = receipt.metadata || {}; %>
          <div class="replay-sub-item">
            <div class="replay-sub-item-header">
              <span class="replay-sub-item-label">Op <%= index + 1 %> · <%= item.operation && item.operation.operation ? item.operation.operation : '-' %></span>
              <span class="badge badge--outcome-<%= item.status === 'ok' ? 'success' : 'error' %>"><%= item.status || '-' %></span>
              <% if (item.durationMs !== undefined) { %><span class="badge badge--timing"><%= item.durationMs %>ms</span><% } %>
            </div>
            <dl class="detail-grid">
              <div><dt>Operation</dt><dd><code><%= item.operation && item.operation.operation ? item.operation.operation : '-' %></code></dd></div>
              <div><dt>Receipt status</dt><dd><%= item.status || '-' %></dd></div>
              <div><dt>Resource / final URL</dt><dd><code><%= metadata.finalUrl || item.targetResourceId || receipt.resourceUrl || '-' %></code></dd></div>
              <div><dt>Requested URL</dt><dd><code><%= metadata.requestedUrl || (item.operation && item.operation.args && item.operation.args.url) || '-' %></code></dd></div>
              <div><dt>HTTP / operation status</dt><dd><%= metadata.status !== undefined ? metadata.status : (item.status || '-') %></dd></div>
              <div><dt>Duration</dt><dd><%= item.durationMs !== undefined ? item.durationMs + 'ms' : '-' %></dd></div>
              <div><dt>Error code</dt><dd><code><%= item.errorCode || metadata.code || '-' %></code></dd></div>
              <div><dt>Error message</dt><dd><%= item.error || '-' %></dd></div>
              <div><dt>Page state hash</dt><dd><code><%= metadata.pageStateHash || '-' %></code></dd></div>
              <div><dt>Content hash</dt><dd><code><%= metadata.contentHash || '-' %></code></dd></div>
              <div><dt>Screenshot artifact path</dt><dd><code><%= metadata.artifactPath || '-' %></code></dd></div>
              <div><dt>Screenshot SHA-256</dt><dd><code><%= metadata.sha256 || '-' %></code></dd></div>
              <div><dt>Truncated</dt><dd><%= receipt.truncated ? 'yes' : 'no' %></dd></div>
            </dl>
          </div>
        <% }) %>
        <p class="text-muted">Screenshot artifacts remain server-side and are shown by recorded path and SHA-256 only. Phase 1 does not expose a public artifact-serving route, which avoids widening access to captured page content.</p>
      </div>
    </details>
  </section>
  <% } %>

  <% if (typeof permissionedDeleteAuditEvents !== 'undefined' && permissionedDeleteAuditEvents && permissionedDeleteAuditEvents.length > 0) { %>
  <% const dash = v => (v === null || v === undefined || v === '') ? '-' : v; %>
  <section class="detail-section permissioned-delete-section" id="permissioned-cross-ticket-delete">
    <h2>Permissioned Cross-Ticket Delete</h2>
    <p class="text-muted">This run deleted an artifact produced by another ticket using delegated user authority.</p>
    <% permissionedDeleteAuditEvents.forEach(entry => { %>
      <div class="permissioned-delete-item">
        <dl class="detail-grid">
          <div><dt>Operation</dt><dd><code><%= dash(entry.operation) %></code></dd></div>
          <div><dt>Path</dt><dd><code class="owned-path"><%= dash(entry.path) %></code></dd></div>
          <div><dt>Prior owner ticket</dt><dd><%= entry.priorOwnerTicketId != null ? ('#' + entry.priorOwnerTicketId) : '-' %></dd></div>
          <div><dt>Prior owner run</dt><dd><%= entry.priorOwnerRunId != null ? ('#' + entry.priorOwnerRunId) : '-' %></dd></div>
          <div><dt>Prior owner history id</dt><dd><%= dash(entry.priorOwnerHistoryId) %></dd></div>
          <div><dt>Prior owner path</dt><dd><code class="owned-path"><%= dash(entry.priorOwnerPath) %></code></dd></div>
          <div><dt>Requesting ticket</dt><dd><%= entry.requestingTicketId != null ? ('#' + entry.requestingTicketId) : '-' %></dd></div>
          <div><dt>Requesting run</dt><dd><%= entry.requestingRunId != null ? ('#' + entry.requestingRunId) : '-' %></dd></div>
          <div><dt>Delegated actor</dt><dd><%= dash(entry.actorUsername) %><% if (entry.actorUserId != null) { %> (user #<%= entry.actorUserId %>)<% } %></dd></div>
          <div><dt>Delegated permission source</dt><dd><%= dash(entry.delegatedPermissionSource) %></dd></div>
          <div><dt>Permission used</dt><dd><code><%= dash(entry.permissionUsed) %></code></dd></div>
          <div><dt>Audit event type</dt><dd><code><%= dash(entry.type) %></code></dd></div>
          <div><dt>Timestamp</dt><dd><%= dash(entry.ts) %></dd></div>
        </dl>
      </div>
    <% }) %>
  </section>
  <% } %>

  <section class="detail-section replay-section" id="replay-workspace-actions" data-replay-section="workspaceOperations">
    <h2>Workspace Actions</h2>
    <% if (!snapshot.workspaceOperations || snapshot.workspaceOperations.length === 0) { %>
      <p class="text-muted">No workspace operations captured.</p>
    <% } %>
    <% (snapshot.workspaceOperations || []).forEach((op, index) => { %>
      <%
        let opStatusClass = 'op-neutral';
        let opStatusLabel = '';
        const opIsFailure = op.blocked || op.error;
        const opIsMutation = op.operation && ['createFolder','writeFile','renamePath','deletePath'].includes(op.operation.operation);
        if (op.blocked) {
          opStatusClass = 'op-blocked';
          opStatusLabel = 'BLOCKED';
        } else if (op.error) {
          opStatusClass = 'op-error';
          opStatusLabel = 'ERROR';
        } else if (op.result && op.result.status === 'already_exists_noop') {
          opStatusClass = 'op-noop';
          opStatusLabel = 'NO-OP';
        } else if (op.result && op.result.status === 'created') {
          opStatusClass = 'op-created';
          opStatusLabel = 'CREATED';
        } else if (op.result) {
          opStatusClass = 'op-success';
          opStatusLabel = 'OK';
        }
        const opReason = op.reason || (op.error && op.error) || '';
      %>
      <div class="workspace-operation <%= opStatusClass %>" data-op-failure="<%= opIsFailure %>" data-op-mutation="<%= opIsMutation %>">
        <div class="workspace-operation-header">
          <span class="workspace-operation-number">Op <%= index + 1 %></span>
          <span class="workspace-operation-type"><%= op.operation && op.operation.operation || (typeof op.operation === 'string' ? op.operation : '-') %></span>
          <span class="badge badge--outcome-<%= opStatusClass.replace(/^op-/, '') %>"><%= opStatusLabel %></span>
          <% if (op.durationMs !== undefined) { %>
            <span class="badge badge--timing"><%= op.durationMs %>ms</span>
          <% } %>
          <% if (typeof opAllowance !== 'undefined') { %>
            <% const allowKey = op.historyId != null ? 'h:' + op.historyId : 's:' + index; %>
            <% const allow = opAllowance[allowKey]; %>
            <% if (allow) { %>
              <span class="badge badge--allowance badge--allowance-<%= allow.type %>"><%= allow.label %></span>
            <% } %>
          <% } %>
        </div>
        <% if (typeof opErrorInfo !== 'undefined') { %>
          <% const errorKey = op.historyId != null ? 'h:' + op.historyId : 's:' + index; %>
          <% const errorInfo = opErrorInfo[errorKey]; %>
          <% if (errorInfo) { %>
            <div class="operation-error-info">
              <code><%= errorInfo.code %></code>
              <span><%= errorInfo.explanation %></span>
            </div>
          <% } %>
        <% } %>
        <% if (opReason) { %>
          <div class="workspace-operation-reason"><%= opReason %></div>
        <% } %>
        <details class="collapsible">
          <summary>Payload</summary>
          <pre class="code-block"><%= JSON.stringify(op, null, 2) %></pre>
        </details>
      </div>
    <% }) %>
  </section>

  <section class="detail-section replay-section" data-replay-section="events">
    <h2>Events</h2>
    <p class="text-muted">Replay events record notable runtime conditions (limits, truncation, postconditions, no-progress). A clean run can have none even though provider, model, and workspace evidence exist.</p>
    <% if (!snapshot.events || snapshot.events.length === 0) { %>
      <%
        const hasOtherEvidence = (snapshot.providerRequests && snapshot.providerRequests.length > 0)
          || (snapshot.modelResponses && snapshot.modelResponses.length > 0)
          || (snapshot.workspaceOperations && snapshot.workspaceOperations.length > 0);
      %>
      <% if (hasOtherEvidence) { %>
        <p class="text-muted">No replay events for this run. Replay events are a separate category from provider, model, and workspace evidence, which is shown in its own sections above (see the "Why this run stopped" evidence counts). Absent replay events do not mean the other evidence is missing.</p>
      <% } else { %>
        <p class="text-muted">No replay events captured.</p>
      <% } %>
    <% } %>
    <% (snapshot.events || []).forEach((event, index) => { %>
      <%
        let eventClass = 'event-neutral';
        const eventIsFailure = event.type && (event.type.includes('fail') || event.type.includes('error') || event.type.includes('limit'));
        if (event.type && event.type.includes('limit')) eventClass = 'event-limit';
        else if (event.type && event.type.includes('fail')) eventClass = 'event-error';
        else if (event.type && event.type.includes('stalled')) eventClass = 'event-warn';
        else if (event.type && event.type.includes('no_progress')) eventClass = 'event-warn';
        else if (event.type === 'run:completed_noop') eventClass = 'event-noop';
      %>
      <div class="replay-event <%= eventClass %>" data-event-failure="<%= eventIsFailure %>">
        <div class="replay-event-header">
          <span class="replay-event-number">#<%= index + 1 %></span>
          <span class="replay-event-type"><%= event.type %></span>
        </div>
        <details class="collapsible">
          <summary>Payload</summary>
          <pre class="code-block"><%= JSON.stringify(event, null, 2) %></pre>
        </details>
      </div>
    <% }) %>
  </section>
<% } %>

<% if (typeof runEvents !== 'undefined' && runEvents && runEvents.length > 0) { %>
  <section class="detail-section">
    <details class="collapsible">
      <summary>Operational Events (<%= runEvents.length %>)</summary>
      <div class="collapsible__content">
        <pre class="code-block"><%= JSON.stringify(runEvents, null, 2) %></pre>
      </div>
    </details>
  </section>
<% } %>

<% if (operationHistory && operationHistory.length > 0) { %>
<section class="detail-section">
  <h2>Operation History</h2>
  <div class="operation-history">
    <% operationHistory.forEach((record, index) => { %>
      <div class="operation-history-item <%= record.isRecovery ? 'is-recovery' : '' %>">
        <div class="operation-history-header">
          <span class="operation-history-number">#<%= record.id %></span>
          <span class="operation-history-type"><%= record.operation %></span>
          <span class="operation-history-step">step <%= record.step %></span>
          <% if (record.isRecovery) { %>
            <span class="badge badge--recovery-action">RECOVERY</span>
          <% } else if (record.recoveryStatus) { %>
            <% if (record.recoveryStatus.status === 'recoverable') { %>
              <span class="badge badge--recovery-recoverable">RECOVERABLE</span>
            <% } else if (record.recoveryStatus.status === 'unrecoverable') { %>
              <span class="badge badge--recovery-unrecoverable">UNRECOVERABLE</span>
            <% } else if (record.recoveryStatus.status === 'recovery_available') { %>
              <span class="badge badge--recovery-available">RECOVERY AVAILABLE</span>
            <% } %>
          <% } %>
          <% if (record.error) { %>
            <span class="badge badge--outcome-error">ERROR</span>
          <% } else if (record.result && record.result.status === 'already_exists_noop') { %>
            <span class="badge badge--outcome-noop">NO-OP</span>
          <% } else { %>
            <span class="badge badge--outcome-success">OK</span>
          <% } %>
          <% if (record.allowance) { %>
            <span class="badge badge--allowance badge--allowance-<%= record.allowance.type %>"><%= record.allowance.label %></span>
          <% } %>
          <% if (record.errorInfo) { %>
            <span class="badge badge--outcome-error"><%= record.errorInfo.code %></span>
          <% } %>
        </div>
        <div class="operation-history-body">
          <div class="allocation-item-row">
            <span class="allocation-item-label">Path</span>
            <span class="allocation-item-value"><code class="owned-path"><%= record.args.path %></code></span>
          </div>
          <% if (record.args.nextPath) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Next Path</span>
              <span class="allocation-item-value"><code class="owned-path"><%= record.args.nextPath %></code></span>
            </div>
          <% } %>
          <% if (record.isRecovery && record.recoveredHistoryId) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Recovered</span>
              <span class="allocation-item-value">History #<%= record.recoveredHistoryId %></span>
            </div>
          <% } %>
          <% if (record.error) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Error</span>
              <span class="allocation-item-value"><span class="failure-reason"><%= record.error %></span></span>
            </div>
            <% if (record.errorInfo) { %>
              <div class="allocation-item-row">
                <span class="allocation-item-label">Error Code</span>
                <span class="allocation-item-value"><code><%= record.errorInfo.code %></code> · <%= record.errorInfo.explanation %></span>
              </div>
            <% } %>
          <% } %>
          <% if (record.preState) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">State diff</span>
              <span class="allocation-item-value">
                <details class="collapsible">
                  <summary>View diff</summary>
                  <div class="diff-container">
                    <div class="diff-panel">
                      <div class="diff-panel-label">Before</div>
                      <pre class="code-block code-block--diff"><%= JSON.stringify(record.preState, null, 2) %></pre>
                    </div>
                    <div class="diff-panel">
                      <div class="diff-panel-label">After</div>
                      <pre class="code-block code-block--diff"><%= JSON.stringify(record.postState, null, 2) %></pre>
                    </div>
                  </div>
                </details>
              </span>
            </div>
          <% } else if (record.postState) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Post-State</span>
              <span class="allocation-item-value">
                <details class="collapsible">
                  <summary>View Post-State</summary>
                  <pre class="code-block"><%= JSON.stringify(record.postState, null, 2) %></pre>
                </details>
              </span>
            </div>
          <% } %>
          <% if (canUpdateRuns && !record.isRecovery && record.recoveryStatus && record.recoveryStatus.status === 'recoverable') { %>
            <div class="recovery-controls">
              <button type="button" class="btn-small" data-preview-recovery-id="<%= record.id %>">Preview Recovery</button>
            </div>
            <div class="recovery-preview-panel" id="recovery-preview-<%= record.id %>" style="display: none;"></div>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</section>
<% } %>

<% const runRecentLogs = typeof recentLogs === 'undefined' ? [] : recentLogs; %>
<% if (runRecentLogs.length > 0) { %>
<section class="detail-section">
  <h2>Recent Activity</h2>
  <div class="inline-log-list">
    <% runRecentLogs.forEach(log => { %>
      <div class="inline-log-item">
        <span class="inline-log-type"><%= log.displayType || log.type %></span>
        <span class="inline-log-message"><%= log.displayMessage || log.message %></span>
        <% if (log.changedBy || log.requestedBy) { %>
          <span class="audit-meta">Changed by <%= log.changedBy || log.requestedBy %> at <%= log.changedAt || log.timestamp || '-' %></span>
        <% } %>
      </div>
    <% }) %>
  </div>
</section>
<% } %>

<% if (typeof runDiagnosticBundle !== 'undefined' && runDiagnosticBundle) { %>
<section class="detail-section diagnostics-section" id="run-diagnostics">
  <h2>Diagnostics</h2>
  <p class="text-muted">One copyable bundle with this run's ticket, run, failure, authority, permission, workspace, replay, model, and artifact evidence — for sharing when diagnosing an issue. Provider keys, cookies, password hashes, and secrets are excluded.<% if (typeof diagnosticsGeneratedAt !== 'undefined' && diagnosticsGeneratedAt) { %> Generated at <%= diagnosticsGeneratedAt %>.<% } %></p>
  <div class="diagnostics-actions">
    <button type="button" class="btn-secondary" data-copy-diagnostics>Copy diagnostics</button>
    <span class="diagnostics-copy-status" data-copy-diagnostics-status aria-live="polite"></span>
  </div>
  <textarea id="run-diagnostics-bundle" class="diagnostics-textarea" readonly rows="24" spellcheck="false" aria-label="Run diagnostic bundle"><%= runDiagnosticBundle %></textarea>
</section>
<script>
(function() {
  var copyBtn = document.querySelector('[data-copy-diagnostics]');
  var textarea = document.getElementById('run-diagnostics-bundle');
  var status = document.querySelector('[data-copy-diagnostics-status]');
  if (!copyBtn || !textarea) return;
  function note(msg) { if (status) { status.textContent = msg; setTimeout(function() { status.textContent = ''; }, 2500); } }
  copyBtn.addEventListener('click', function() {
    var text = textarea.value;
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(function() { note('Copied'); }).catch(function() {
        textarea.select();
        try { document.execCommand('copy'); note('Copied'); } catch (e) { note('Copy failed — select and copy manually'); }
      });
    } else {
      textarea.select();
      try { document.execCommand('copy'); note('Copied'); } catch (e) { note('Copy failed — select and copy manually'); }
    }
  });
})();
</script>
<% } %>

<script>
(function() {
  var toggleAllBtn = document.querySelector('[data-replay-toggle-all]');
  if (toggleAllBtn) {
    var allExpanded = false;
    toggleAllBtn.addEventListener('click', function() {
      allExpanded = !allExpanded;
      document.querySelectorAll('.replay-section details.collapsible').forEach(function(d) {
        d.open = allExpanded;
      });
      toggleAllBtn.textContent = allExpanded ? 'Collapse details' : 'Expand details';
    });
  }

  document.querySelectorAll('[data-replay-jump]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var jump = btn.getAttribute('data-replay-jump');
      var target = null;
      if (jump === 'workspace') {
        target = document.getElementById('replay-workspace-actions');
      } else if (jump === 'browser') {
        target = document.getElementById('replay-browser-operations');
      } else if (jump === 'failure') {
        target = document.querySelector('[data-op-failure="true"], [data-event-failure="true"]');
      } else if (jump === 'mutation') {
        target = document.querySelector('[data-op-mutation="true"]');
      }
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });
})();
</script>


<script>
(() => {
  const runId = <%= JSON.stringify(run.id) %>;
  let currentStatus = <%- serializeForInlineScript(run.status || '') %>;
  let terminalReloaded = false;
  let elapsedInterval = null;
  let eventSource = null;
  const terminalStatuses = new Set(['completed', 'failed', 'interrupted']);
  const activeStatuses = new Set(['pending', 'running']);

  const statusEl = document.getElementById('run-live-status');
  const outcomeEl = document.getElementById('run-live-outcome');
  const completedEl = document.getElementById('run-live-completed');
  const durationEl = document.getElementById('run-live-duration');
  const messageEl = document.getElementById('run-live-message');
  const eventStatusEl = document.getElementById('run-live-event-status');
  const eventErrorEl = document.getElementById('run-live-event-error');
  const leaseEl = document.getElementById('run-live-lease');
  const heartbeatEl = document.getElementById('run-live-heartbeat');

  function formatElapsed(ms) {
    const seconds = Math.max(0, Math.floor(ms / 1000));
    if (seconds < 60) return seconds + ' second' + (seconds === 1 ? '' : 's');
    const minutes = Math.floor(seconds / 60);
    const rest = seconds % 60;
    if (rest === 0) return minutes + ' minute' + (minutes === 1 ? '' : 's');
    return minutes + ' minute' + (minutes === 1 ? '' : 's') + ' ' + rest + ' second' + (rest === 1 ? '' : 's');
  }

  function updateDuration(startedAt, completedAt, status) {
    if (!durationEl) return;
    const startText = startedAt || durationEl.dataset.startedAt || '';
    const completeText = completedAt || durationEl.dataset.completedAt || '';
    const startMs = Date.parse(startText);
    if (Number.isNaN(startMs)) return;

    if (completeText) {
      const completeMs = Date.parse(completeText);
      if (!Number.isNaN(completeMs)) {
        durationEl.textContent = formatElapsed(completeMs - startMs);
        durationEl.dataset.completedAt = completeText;
        return;
      }
    }

    if (activeStatuses.has(status)) {
      durationEl.textContent = (status === 'pending' ? 'queued for ' : 'running for ') + formatElapsed(Date.now() - startMs);
    }
  }

  function setText(el, value) {
    if (!el) return;
    el.textContent = value || '-';
  }

  function updateStatus(status) {
    if (!statusEl || !status) return;
    statusEl.className = 'status-badge status-' + status;
    statusEl.textContent = status;
    currentStatus = status;
  }

  function stopPolling() {
    if (elapsedInterval) { window.clearInterval(elapsedInterval); elapsedInterval = null; }
    if (eventSource) { eventSource.close(); eventSource = null; }
  }

  async function refreshRunState() {
    if (!activeStatuses.has(currentStatus)) return;

    const response = await fetch('/api/runs/' + encodeURIComponent(runId) + '/state', {
      headers: { Accept: 'application/json' }
    });
    if (!response.ok) return;

    const state = await response.json();
    updateStatus(state.status || currentStatus);
    setText(outcomeEl, state.outcomeLabel || state.outcome);
    setText(completedEl, state.completedAt);
    setText(messageEl, state.currentMessage);
    setText(eventStatusEl, state.eventSummary && state.eventSummary.latestStatus ? state.eventSummary.latestStatus.status : null);
    setText(eventErrorEl, state.eventSummary && state.eventSummary.latestError ? state.eventSummary.latestError.message : null);
    if (state.lease) {
      setText(leaseEl, state.lease.leaseOwner
        ? state.lease.leaseOwner
          + (state.lease.leaseExpiresAt ? ' until ' + state.lease.leaseExpiresAt : '')
          + (state.lease.expired ? ' (expired)' : '')
        : null);
      setText(heartbeatEl, state.lease.lastHeartbeatAt);
    }
    updateDuration(state.startedAt || state.createdAt, state.completedAt, state.status || currentStatus);

    if (terminalStatuses.has(state.status)) {
      stopPolling();
      if (!state.completedAt && !terminalReloaded) {
        terminalReloaded = true;
        window.location.reload();
      }
    }
  }

  updateDuration(durationEl && durationEl.dataset.startedAt, durationEl && durationEl.dataset.completedAt, currentStatus);
  if (activeStatuses.has(currentStatus)) {
    if (window.EventSource) {
      eventSource = new EventSource('/api/events');
      eventSource.addEventListener('run:status-changed', function(e) {
        var data;
        try { data = JSON.parse(e.data); } catch (_) { return; }
        if (data && data.runId === runId) refreshRunState().catch(function(){});
      });
      eventSource.addEventListener('error', function() {
        if (eventSource) eventSource.close();
        eventSource = null;
      });
    }
    elapsedInterval = window.setInterval(function() {
      updateDuration(durationEl && durationEl.dataset.startedAt, durationEl && durationEl.dataset.completedAt, currentStatus);
    }, 1000);
    refreshRunState().catch(function(){});
  }
})();
</script>

<% if (canUpdateRuns) { %>
<script>
async function postRunControl(url, redirectUrl) {
  const response = await fetch(url, {
    method: 'POST',
    headers: { Accept: 'application/json' }
  });

  if (!response.ok) {
    const data = await response.json().catch(() => ({}));
    window.alert(data.error || 'Run action failed');
    window.location.reload();
    return;
  }

  if (response.ok && redirectUrl) {
    window.location.href = redirectUrl;
    return;
  }

  window.location.reload();
}

document.addEventListener('click', event => {
  const stopButton = event.target.closest('[data-stop-run-id]');
  if (stopButton) {
    stopButton.disabled = true;
    postRunControl('/api/runs/' + encodeURIComponent(stopButton.dataset.stopRunId) + '/stop');
    return;
  }

  const retryButton = event.target.closest('[data-retry-run-id]');
  if (retryButton) {
    retryButton.disabled = true;
    postRunControl('/api/runs/' + encodeURIComponent(retryButton.dataset.retryRunId) + '/retry', '/tickets');
    return;
  }

  const previewButton = event.target.closest('[data-preview-recovery-id]');
  if (previewButton) {
    previewButton.disabled = true;
    const historyId = previewButton.dataset.previewRecoveryId;
    const panel = document.getElementById('recovery-preview-' + historyId);
    fetch('/api/operations/' + encodeURIComponent(historyId) + '/recovery-preview')
      .then(response => response.json())
      .then(data => {
        if (data.error) {
          panel.className = 'recovery-preview-panel recovery-blocked';
          panel.innerHTML = '<div class="recovery-reason">' + escapeHtml(data.error) + '</div>';
        } else if (data.preview) {
          const p = data.preview;
          panel.className = p.canProceed ? 'recovery-preview-panel' : 'recovery-preview-panel recovery-blocked';
          let html = '<div class="recovery-action-text">Proposed: ' + escapeHtml(p.proposedAction.operation) + '</div>';
          if (p.proposedAction.args.path) html += '<div class="recovery-reason">Path: <code class="owned-path">' + escapeHtml(p.proposedAction.args.path) + '</code></div>';
          if (p.proposedAction.args.nextPath) html += '<div class="recovery-reason">Next Path: <code class="owned-path">' + escapeHtml(p.proposedAction.args.nextPath) + '</code></div>';
          if (p.validation && !p.validation.valid) html += '<div class="recovery-reason recovery-blocked-text">Blocked: ' + escapeHtml(p.validation.reason) + '</div>';
          if (p.canProceed) {
            html += '<div class="recovery-controls"><button type="button" class="btn-small btn-danger" data-confirm-recovery-id="' + historyId + '">Confirm Recovery</button></div>';
          }
          panel.innerHTML = html;
        }
        panel.style.display = 'block';
        previewButton.disabled = false;
      })
      .catch(err => {
        panel.className = 'recovery-preview-panel recovery-blocked';
        panel.innerHTML = '<div class="recovery-reason">Preview failed: ' + escapeHtml(err.message) + '</div>';
        panel.style.display = 'block';
        previewButton.disabled = false;
      });
    return;
  }

  const confirmButton = event.target.closest('[data-confirm-recovery-id]');
  if (confirmButton) {
    confirmButton.disabled = true;
    const historyId = confirmButton.dataset.confirmRecoveryId;
    fetch('/api/operations/' + encodeURIComponent(historyId) + '/recover', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({ confirmed: true })
    })
      .then(response => response.json())
      .then(data => {
        if (data.error) {
          alert('Recovery failed: ' + data.error);
          confirmButton.disabled = false;
        } else {
          window.location.reload();
        }
      })
      .catch(err => {
        alert('Recovery failed: ' + err.message);
        confirmButton.disabled = false;
      });
    return;
  }
});

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}
</script>
<% } %>
