<h1>Tickets</h1>
<% const viewPagination = typeof pagination === 'undefined' ? null : pagination; %>
<%
  function statusOptionLabel(status) {
    if (status === 'open') return 'open — starts run';
    if (status === 'closed') return 'closed — stops active runs';
    return status;
  }
%>

<section class="admin-block">
  <% if (viewPagination && viewPagination.total > 0) { %>
    <div class="pagination-bar">
      <span>Showing <%= viewPagination.start %>-<%= viewPagination.end %> of <%= viewPagination.total %> tickets</span>
      <div class="pagination-actions">
        <% if (viewPagination.previousHref) { %>
          <a class="btn-small" href="<%= viewPagination.previousHref %>">Previous</a>
        <% } else { %>
          <span class="btn-small btn-small--disabled">Previous</span>
        <% } %>
        <span class="text-muted">Page <%= viewPagination.page %> of <%= viewPagination.pageCount %></span>
        <% if (viewPagination.nextHref) { %>
          <a class="btn-small" href="<%= viewPagination.nextHref %>">Next</a>
        <% } else { %>
          <span class="btn-small btn-small--disabled">Next</span>
        <% } %>
      </div>
    </div>
  <% } %>
  <div id="tickets-body" class="ticket-cards">
    <% if (tickets.length === 0) { %>
      <div class="text-muted ticket-cards__empty">No tickets yet.</div>
    <% } %>

    <% tickets.forEach(ticket => { %>
      <%
        const isFailed = ticket.status === 'failed';
        const isInterrupted = ticket.lastRunStatus === 'interrupted';
        const hasPartial = (isFailed || isInterrupted) && ticket.lastRunHadPartialMutations;
        const accentClass = isFailed ? 'is-failed' : isInterrupted ? 'is-interrupted' : '';
      %>
      <div class="ticket-card <%= accentClass %>" data-ticket-id="<%= ticket.id %>">
        <div class="ticket-card__header">
          <a href="/tickets/<%= ticket.id %>" class="ticket-card__objective"><%= ticket.objective %></a>
          <div class="ticket-card__status">
            <% if (canUpdateTickets && ticketStatuses.includes(ticket.status)) { %>
              <form class="status-form" data-ticket-id="<%= ticket.id %>">
                <select name="status" class="status-select" aria-label="Ticket status">
                  <% ticketStatuses.forEach(status => { %>
                    <option value="<%= status %>" <%= ticket.status === status ? 'selected' : '' %>><%= statusOptionLabel(status) %></option>
                  <% }) %>
                </select>
              </form>
            <% } else { %>
              <span class="status-badge status-<%= ticket.status %>"><%= ticket.status %></span>
              <% if (ticket.status === 'interrupted') { %>
                <span class="status-system-note" title="System status set by the runtime; not user-selectable">system status</span>
              <% } %>
            <% } %>
            <% if (hasPartial) { %>
              <span class="partial-run-indicator" title="Last run performed <%= ticket.lastRunPartialMutationCount %> workspace mutation<%= ticket.lastRunPartialMutationCount === 1 ? '' : 's' %> before failing">&#9888;</span>
            <% } %>
          </div>
        </div>
        <%
          const metadataItems = [];
          const isOpenTicket = ticket.status === 'open';
          const hasActiveRun = ticket.activeRunIds && ticket.activeRunIds.length > 0;
          if (isOpenTicket && !ticket.assignmentTargetName) {
            metadataItems.push('Unassigned — not started');
          } else if (isOpenTicket && ticket.assignmentTargetName && !hasActiveRun && !ticket.currentRunDisplayLabel) {
            metadataItems.push('No run has been created yet; execution target is not visible from current data');
          }
          if (ticket.assignmentTargetType === 'group' && ticket.groupMemberCount != null) {
            const groupMemberCount = ticket.groupMemberCount;
            metadataItems.push('Group assignment — ' + groupMemberCount + ' group member' + (groupMemberCount === 1 ? '' : 's'));
          }
          if (ticket.executionSummaryLabel) metadataItems.push('Execution: ' + ticket.executionSummaryLabel);
          if (ticket.currentMessage || (!ticket.currentRunDisplayLabel && ticket.activeRunIds && ticket.activeRunIds.length > 0)) metadataItems.push(ticket.currentMessage || 'No current output');
          if (ticket.assignmentTargetName) metadataItems.push('Assigned to: ' + ticket.assignmentTargetName);
          if (ticket.assignmentMode) metadataItems.push(ticket.assignmentMode === 'allocated' ? 'manual folder scopes' : ticket.assignmentMode === 'dynamic' ? 'automatic folder scopes' : ticket.assignmentMode);
          if (ticket.lastRunOperationalOutcomeLabel) metadataItems.push('latest run: ' + ticket.lastRunOperationalOutcomeLabel);
          if (ticket.updatedAt) metadataItems.push(new Date(ticket.updatedAt).toLocaleString());
        %>
        <% if (metadataItems.length > 0) { %>
          <div class="ticket-card__meta">
          <% if (ticket.currentRunDisplayLabel) { %>
            <span
              data-run-state="<%= ticket.currentRunState || '' %>"
              data-run-started-at="<%= ticket.currentRunStartedAt || ticket.currentRunCreatedAt || '' %>"
              data-run-timeout-limit="<%= ticket.currentRunTimeoutLimit || '' %>"
            ><%= ticket.currentRunDisplayLabel %><%= ticket.currentRunDisplayState && ticket.currentRunDisplayState.detail ? ': ' + ticket.currentRunDisplayState.detail : '' %></span>
          <% } %>
          <% metadataItems.forEach(item => { %>
            <% if (String(item).startsWith('latest run: ')) { %>
              <span>latest run: <%= String(item).replace('latest run: ', '') %></span>
            <% } else { %>
              <span><%= item %></span>
            <% } %>
          <% }) %>
          </div>
        <% } %>
        <% if (canUpdateTickets && ticket.status === 'open') { %>
          <div class="ticket-card__actions">
            <form class="assign-form" data-ticket-id="<%= ticket.id %>">
              <select name="agentId" class="agent-assign-select" aria-label="Assign and run agent">
                <option value="">Assign &amp; run agent</option>
                <% agents.forEach(agent => { %>
                  <option value="<%= agent.id %>" <%= ticket.assignmentTargetType === 'agent' && ticket.assignmentTargetId === agent.id ? 'selected' : '' %>><%= agent.name %></option>
                <% }) %>
              </select>
            </form>
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>
</section>

<script>
const ticketsBody = document.getElementById('tickets-body');
const canUpdateTickets = <%= canUpdateTickets ? 'true' : 'false' %>;
const ticketStatuses = <%- JSON.stringify(ticketStatuses) %>;
const agents = <%- JSON.stringify(agents.map(agent => ({ id: agent.id, name: agent.name }))) %>;
const ticketsApiUrl = '/api/tickets' + window.location.search;
let liveTicketsConnected = false;
let ticketLoadPending = false;
let ticketLoadQueued = false;

function renderEmptyRow() {
  const el = document.createElement('div');
  el.className = 'text-muted ticket-cards__empty';
  el.textContent = 'No tickets yet.';
  ticketsBody.appendChild(el);
}

function statusOptionLabel(status) {
  if (status === 'open') return 'open — starts run';
  if (status === 'closed') return 'closed — stops active runs';
  return status;
}

function ticketSignature(ticket) {
  return [
    ticket.objective,
    ticket.assignmentTargetName,
    ticket.assignmentMode,
    ticket.status,
    ticket.assignmentTargetId,
    ticket.assignmentTargetType,
    ticket.groupMemberCount == null ? '' : ticket.groupMemberCount,
    ticket.executionSummaryLabel || '',
    (ticket.activeRunIds || []).join(','),
    ticket.lastRunStatus || '',
    ticket.lastRunOperationalOutcome || '',
    ticket.lastRunOperationalOutcomeLabel || '',
    ticket.lastRunHadPartialMutations || false,
    ticket.lastRunPartialMutationCount || 0,
    ticket.currentRunId || '',
    ticket.currentRunDisplayLabel || '',
    ticket.currentRunElapsedMs || '',
    ticket.currentRunState || '',
    ticket.currentRunStartedAt || '',
    ticket.currentRunCreatedAt || '',
    ticket.currentMessage || '',
    ticket.updatedAt
  ].join('|');
}

function createTicketCard(ticket) {
  const card = document.createElement('div');
  card.className = 'ticket-card';
  const isFailed = ticket.status === 'failed';
  const isInterrupted = ticket.lastRunStatus === 'interrupted';
  if (isFailed) card.classList.add('is-failed');
  if (isInterrupted) card.classList.add('is-interrupted');
  card.dataset.ticketId = ticket.id;
  card.dataset.ticketSignature = ticketSignature(ticket);

  // Header
  const header = document.createElement('div');
  header.className = 'ticket-card__header';

  const objectiveLink = document.createElement('a');
  objectiveLink.href = '/tickets/' + ticket.id;
  objectiveLink.className = 'ticket-card__objective';
  objectiveLink.textContent = ticket.objective;
  header.appendChild(objectiveLink);

  const statusWrap = document.createElement('div');
  statusWrap.className = 'ticket-card__status';

  if (canUpdateTickets && ticketStatuses.includes(ticket.status)) {
    const form = document.createElement('form');
    form.className = 'status-form';
    form.dataset.ticketId = ticket.id;

    const select = document.createElement('select');
    select.name = 'status';
    select.className = 'status-select';
    select.setAttribute('aria-label', 'Ticket status');

    ticketStatuses.forEach(status => {
      const option = document.createElement('option');
      option.value = status;
      option.textContent = statusOptionLabel(status);
      option.selected = ticket.status === status;
      select.appendChild(option);
    });

    form.appendChild(select);
    statusWrap.appendChild(form);
  } else {
    const badge = document.createElement('span');
    badge.className = 'status-badge status-' + ticket.status;
    badge.textContent = ticket.status;
    statusWrap.appendChild(badge);

    if (ticket.status === 'interrupted') {
      const systemNote = document.createElement('span');
      systemNote.className = 'status-system-note';
      systemNote.title = 'System status set by the runtime; not user-selectable';
      systemNote.textContent = 'system status';
      statusWrap.appendChild(systemNote);
    }
  }

  if ((isFailed || isInterrupted) && ticket.lastRunHadPartialMutations) {
    const indicator = document.createElement('span');
    indicator.className = 'partial-run-indicator';
    indicator.title = 'Last run performed ' + ticket.lastRunPartialMutationCount + ' workspace mutation' + (ticket.lastRunPartialMutationCount === 1 ? '' : 's') + ' before failing';
    indicator.innerHTML = '&#9888;';
    statusWrap.appendChild(indicator);
  }

  header.appendChild(statusWrap);
  card.appendChild(header);

  const activeRunIds = ticket.activeRunIds || [];

  // Meta
  const metadataItems = [];

  const isOpenTicket = ticket.status === 'open';
  const hasActiveRun = activeRunIds.length > 0;
  if (isOpenTicket && !ticket.assignmentTargetName) {
    metadataItems.push({ text: 'Unassigned — not started' });
  } else if (isOpenTicket && ticket.assignmentTargetName && !hasActiveRun && !ticket.currentRunDisplayLabel) {
    metadataItems.push({ text: 'No run has been created yet; execution target is not visible from current data' });
  }

  if (ticket.assignmentTargetType === 'group' && ticket.groupMemberCount != null) {
    const groupMemberCount = ticket.groupMemberCount;
    metadataItems.push({ text: 'Group assignment — ' + groupMemberCount + ' group member' + (groupMemberCount === 1 ? '' : 's') });
  }

  if (ticket.currentRunDisplayLabel) {
    const detail = ticket.currentRunDisplayState && ticket.currentRunDisplayState.detail
      ? ': ' + ticket.currentRunDisplayState.detail
      : '';
    metadataItems.push({ text: ticket.currentRunDisplayLabel + detail });
  }

  if (ticket.executionSummaryLabel) {
    metadataItems.push({ text: 'Execution: ' + ticket.executionSummaryLabel });
  }

  if (ticket.currentMessage || (!ticket.currentRunDisplayLabel && activeRunIds.length > 0)) {
    metadataItems.push({ text: ticket.currentMessage || 'No current output' });
  }

  if (ticket.assignmentTargetName) {
    metadataItems.push({ text: 'Assigned to: ' + ticket.assignmentTargetName });
  }

  if (ticket.assignmentMode) {
    metadataItems.push({
      text: ticket.assignmentMode === 'allocated'
        ? 'manual folder scopes'
        : ticket.assignmentMode === 'dynamic'
          ? 'automatic folder scopes'
          : ticket.assignmentMode
    });
  }

  if (ticket.lastRunOperationalOutcomeLabel) {
    metadataItems.push({ label: 'latest run: ', text: ticket.lastRunOperationalOutcomeLabel });
  }

  if (ticket.updatedAt) {
    metadataItems.push({ text: new Date(ticket.updatedAt).toLocaleString() });
  }

  if (metadataItems.length > 0) {
    const meta = document.createElement('div');
    meta.className = 'ticket-card__meta';

    metadataItems.forEach(item => {
      const span = document.createElement('span');
      if (item.code) {
        span.textContent = item.label || '';
        const code = document.createElement('code');
        code.textContent = item.code;
        span.appendChild(code);
      } else if (item.label) {
        span.textContent = item.label + item.text;
      } else {
        span.textContent = item.text;
      }
      meta.appendChild(span);
    });

    const firstSpan = meta.querySelector('span');
    if (firstSpan && ticket.currentRunDisplayLabel) {
      firstSpan.dataset.runState = ticket.currentRunState || '';
      firstSpan.dataset.runStartedAt = ticket.currentRunStartedAt || ticket.currentRunCreatedAt || '';
      firstSpan.dataset.runTimeoutLimit = ticket.currentRunTimeoutLimit || '';
    }

    card.appendChild(meta);
  }

  // Actions
  if (canUpdateTickets && ticket.status === 'open') {
    const actions = document.createElement('div');
    actions.className = 'ticket-card__actions';

    const form = document.createElement('form');
    form.className = 'assign-form';
    form.dataset.ticketId = ticket.id;

    const select = document.createElement('select');
    select.name = 'agentId';
    select.className = 'agent-assign-select';
    select.setAttribute('aria-label', 'Assign and run agent');

    const emptyOption = document.createElement('option');
    emptyOption.value = '';
    emptyOption.textContent = 'Assign & run agent';
    select.appendChild(emptyOption);

    agents.forEach(agent => {
      const option = document.createElement('option');
      option.value = agent.id;
      option.textContent = agent.name;
      option.selected = ticket.assignmentTargetType === 'agent' && ticket.assignmentTargetId === agent.id;
      select.appendChild(option);
    });

    form.appendChild(select);
    actions.appendChild(form);
    card.appendChild(actions);
  }

  return card;
}

function formatElapsed(ms) {
  const seconds = Math.max(0, Math.floor(ms / 1000));
  if (seconds < 60) return seconds + ' second' + (seconds === 1 ? '' : 's');
  const minutes = Math.floor(seconds / 60);
  const rest = seconds % 60;
  if (rest === 0) return minutes + ' minute' + (minutes === 1 ? '' : 's');
  return minutes + ' minute' + (minutes === 1 ? '' : 's') + ' ' + rest + ' second' + (rest === 1 ? '' : 's');
}

function refreshRunElapsedLabels() {
  document.querySelectorAll('[data-run-state]').forEach(el => {
    const state = el.dataset.runState;
    const startedAt = el.dataset.runStartedAt;
    if (!startedAt || !['waiting_on_local_model', 'running_actions', 'running', 'queued'].includes(state)) return;
    const startMs = Date.parse(startedAt);
    if (Number.isNaN(startMs)) return;
    const elapsed = formatElapsed(Date.now() - startMs);
    const limit = el.dataset.runTimeoutLimit || '';

    if (state === 'waiting_on_local_model') {
      el.textContent = 'waiting on model response: waiting ' + elapsed + (limit ? ' of ' + limit : '');
    } else if (state === 'queued') {
      el.textContent = document.body.dataset.schedulerRunning === 'false'
        ? 'queued — scheduler stopped (waiting ' + elapsed + ', not starting)'
        : 'queued: waiting ' + elapsed + ' to start';
    } else if (state === 'running_actions') {
      el.textContent = 'running actions: working for ' + elapsed;
    } else {
      el.textContent = 'running: running for ' + elapsed;
    }
  });
}

setInterval(refreshRunElapsedLabels, 1000);

function renderTickets(tickets) {
  if (tickets.length === 0) {
    ticketsBody.textContent = '';
    renderEmptyRow();
    return;
  }

  const existingCards = new Map(
    Array.from(ticketsBody.querySelectorAll('.ticket-card[data-ticket-id]')).map(card => [card.dataset.ticketId, card])
  );
  const fragment = document.createDocumentFragment();

  tickets.forEach(ticket => {
    const ticketId = String(ticket.id);
    const existingCard = existingCards.get(ticketId);
    const nextSignature = ticketSignature(ticket);

    if (existingCard && existingCard.dataset.ticketSignature === nextSignature) {
      fragment.appendChild(existingCard);
    } else {
      fragment.appendChild(createTicketCard(ticket));
    }

    existingCards.delete(ticketId);
  });

  ticketsBody.replaceChildren(fragment);
}

async function loadTickets() {
  if (ticketLoadPending) {
    ticketLoadQueued = true;
    return;
  }

  ticketLoadPending = true;

  try {
    const response = await fetch(ticketsApiUrl, {
      headers: { Accept: 'application/json' }
    });

    if (!response.ok) return;

    const data = await response.json();
    renderTickets(data.tickets);
  } finally {
    ticketLoadPending = false;

    if (ticketLoadQueued) {
      ticketLoadQueued = false;
      loadTickets();
    }
  }
}

async function updateTicketStatus(ticketId, status, select) {
  select.disabled = true;

  try {
    const response = await fetch('/api/tickets/' + encodeURIComponent(ticketId) + '/status', {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        Accept: 'application/json'
      },
      body: JSON.stringify({ status })
    });

    if (!response.ok) {
      await loadTickets();
      return;
    }

    if (!liveTicketsConnected) {
      await loadTickets();
    }
  } finally {
    select.disabled = false;
  }
}

ticketsBody.addEventListener('change', event => {
  if (event.target.matches('.status-select')) {
    const form = event.target.closest('.status-form');
    if (!form) return;

    updateTicketStatus(form.dataset.ticketId, event.target.value, event.target);
  }

  if (event.target.matches('.agent-assign-select') && event.target.value) {
    const form = event.target.closest('.assign-form');
    if (!form) return;

    assignTicketAgent(form.dataset.ticketId, event.target.value, event.target);
  }
});

async function assignTicketAgent(ticketId, agentId, select) {
  select.disabled = true;

  try {
    const response = await fetch('/api/tickets/' + encodeURIComponent(ticketId) + '/assignment', {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        Accept: 'application/json'
      },
      body: JSON.stringify({ agentId })
    });

    if (!response.ok || !liveTicketsConnected) {
      await loadTickets();
    }
  } finally {
    select.disabled = false;
  }
}

if (window.EventSource) {
  let ticketEvents = null;
  const connectTicketEvents = window.setTimeout(() => {
    ticketEvents = new EventSource('/api/tickets/events');
    ticketEvents.addEventListener('open', () => {
      liveTicketsConnected = true;
    });
    ticketEvents.addEventListener('tickets-changed', () => {
      loadTickets();
    });
    ticketEvents.addEventListener('error', () => {
      liveTicketsConnected = false;
    });
  }, 300);

  function closeTicketEvents() {
    window.clearTimeout(connectTicketEvents);
    liveTicketsConnected = false;
    if (ticketEvents) {
      ticketEvents.close();
      ticketEvents = null;
    }
  }

  window.addEventListener('pagehide', closeTicketEvents);
  window.addEventListener('beforeunload', closeTicketEvents);
}
</script>
