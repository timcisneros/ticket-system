<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ticket System</title>
  <% if (assets.css) { %>
    <link rel="stylesheet" href="<%= assets.css %>">
  <% } %>
  <% if (assets.js) { %>
    <script type="module" src="<%= assets.js %>"></script>
  <% } %>
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-brand">Ticket System</a>
      <ul class="nav-links">
        <% if (typeof user !== 'undefined' && user) { %>
          <li><a href="/">New Ticket</a></li>
	          <li><a href="/tickets">Tickets</a></li>
	          <% if (userPermissions.includes('ticket:read')) { %>
	            <li><a href="/triage">Triage</a></li>
	            <li><a href="/agents">Agents</a></li>
	            <li><a href="/logs">Logs</a></li>
	          <% } %>
          <% if (userPermissions.includes('processTemplate:manage')) { %>
            <li><a href="/process-templates">Templates</a></li>
          <% } %>
          <% if (userPermissions.includes('workContext:manage')) { %>
            <li><a href="/work-contexts">Work Contexts</a></li>
          <% } %>
          <% if (userPermissions.includes('watcher:manage')) { %>
            <li><a href="/watchers">Watchers</a></li>
          <% } %>
          <% if (userPermissions.includes('modelRouting:manage')) { %>
            <li><a href="/model-routing-policies">Routing</a></li>
          <% } %>
          <% if (userPermissions.includes('workspace:read')) { %>
            <li><a href="/workspace">Workspace</a></li>
          <% } %>
          <% if (userPermissions.includes('user:read')) { %>
            <li><a href="/admin">Admin</a></li>
            <li><a href="/admin/workflows">Workflows</a></li>
            <li><a href="/admin/actions">Actions</a></li>
          <% } %>
          <li><a href="/logout">Logout</a></li>
          <% if (userPermissions.includes('ticket:read')) { %>
            <li><span id="scheduler-indicator" class="scheduler-indicator" hidden></span></li>
          <% } %>
        <% } else { %>
          <li><a href="/login">Login</a></li>
        <% } %>
      </ul>
    </div>
  </nav>
  <% if (typeof user !== 'undefined' && user && userPermissions.includes('ticket:read')) { %>
  <script>
  (() => {
    const indicator = document.getElementById('scheduler-indicator');
    if (!indicator) return;
    async function refreshSchedulerStatus() {
      try {
        const response = await fetch('/api/runtime/status', { headers: { Accept: 'application/json' } });
        if (!response.ok) { indicator.hidden = true; return; }
        const data = await response.json();
        const running = Boolean(data.scheduler && data.scheduler.running);
        document.body.dataset.schedulerRunning = running ? 'true' : 'false';
        indicator.hidden = false;
        indicator.textContent = running ? 'Scheduler running' : 'Scheduler stopped';
        indicator.classList.toggle('scheduler-indicator--stopped', !running);
      } catch (error) {
        indicator.hidden = true;
      }
    }
    refreshSchedulerStatus();
    setInterval(refreshSchedulerStatus, 5000);
  })();
  </script>
  <% } %>

  <main class="container">
    <%- body %>
  </main>
</body>
</html>
