<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ticket System</title>
  <% if (assets.css) { %>
    <link rel="stylesheet" href="<%= assets.css %>">
  <% } %>
  <% if (assets.js) { %>
    <script type="module" src="<%= assets.js %>"></script>
  <% } %>
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-brand">Ticket System</a>
      <ul class="nav-links">
        <% if (typeof user !== 'undefined' && user) { %>
          <li class="dropdown">
            <a class="dropdown-toggle">Tickets</a>
            <ul class="dropdown-menu">
              <li><a href="/">New Ticket</a></li>
              <li><a href="/tickets">All Tickets</a></li>
              <% if (userPermissions.includes('ticket:read')) { %>
                <li><a href="/triage">Triage</a></li>
              <% } %>
            </ul>
          </li>
          <% if (userPermissions.includes('ticket:read') || userPermissions.includes('watcher:manage') || userPermissions.includes('ops:read')) { %>
          <li class="dropdown">
            <a class="dropdown-toggle">Monitoring</a>
            <ul class="dropdown-menu">
              <% if (userPermissions.includes('ticket:read')) { %>
                <li><a href="/agents">Agents</a></li>
                <li><a href="/logs">Logs</a></li>
              <% } %>
              <% if (userPermissions.includes('watcher:manage')) { %>
                <li><a href="/watchers">Watchers</a></li>
              <% } %>
              <% if (userPermissions.includes('ops:read')) { %>
                <li><a href="/ops">Ops</a></li>
              <% } %>
            </ul>
          </li>
          <% } %>
          <% if (userPermissions.includes('processTemplate:manage') || userPermissions.includes('workContext:manage') || userPermissions.includes('modelRouting:manage') || userPermissions.includes('connector:manage')) { %>
          <li class="dropdown">
            <a class="dropdown-toggle">Config</a>
            <ul class="dropdown-menu">
              <% if (userPermissions.includes('processTemplate:manage')) { %>
                <li><a href="/process-templates">Templates</a></li>
              <% } %>
              <% if (userPermissions.includes('workContext:manage')) { %>
                <li><a href="/work-contexts">Work Contexts</a></li>
              <% } %>
              <% if (userPermissions.includes('modelRouting:manage')) { %>
                <li><a href="/model-routing-policies">Routing</a></li>
              <% } %>
              <% if (userPermissions.includes('connector:manage')) { %>
                <li><a href="/connectors">Connectors</a></li>
              <% } %>
            </ul>
          </li>
          <% } %>
          <% if (userPermissions.includes('user:read') || userPermissions.includes('workflow:manage') || userPermissions.includes('runtimeLimits:manage')) { %>
          <li class="dropdown">
            <a class="dropdown-toggle">Admin</a>
            <ul class="dropdown-menu">
              <% if (userPermissions.includes('user:read')) { %>
                <li><a href="/admin">Dashboard</a></li>
                <li><a href="/admin/actions">Actions</a></li>
                <li><a href="/admin/browser-targets">Browser Targets</a></li>
              <% } %>
              <% if (userPermissions.includes('workflow:manage')) { %>
                <li><a href="/admin/workflows">Workflows</a></li>
              <% } %>
              <% if (userPermissions.includes('runtimeLimits:manage')) { %>
                <li><a href="/admin/runtime-limits">Runtime Limits</a></li>
              <% } %>
            </ul>
          </li>
          <% } %>
          <% if (userPermissions.includes('workspace:read')) { %>
            <li><a href="/workspace">Workspace</a></li>
          <% } %>
          <li>
            <form method="post" action="/logout" style="display:inline">
              <button type="submit" class="nav-link-button">Logout</button>
            </form>
          </li>
        <% } else { %>
          <li><a href="/login">Login</a></li>
        <% } %>
      </ul>
    </div>
  </nav>
  <% if (typeof user !== 'undefined' && user && userPermissions.includes('ticket:read')) { %>
  <script>
  (async () => {
    try {
      const response = await fetch('/api/runtime/status', { headers: { Accept: 'application/json' } });
      if (!response.ok) { delete document.body.dataset.schedulerRunning; return; }
      const data = await response.json();
      document.body.dataset.schedulerRunning = Boolean(data.scheduler && data.scheduler.running) ? 'true' : 'false';
    } catch (error) {
      delete document.body.dataset.schedulerRunning;
    }
  })();
  </script>
  <% } %>

  <main class="container">
    <%- body %>
  </main>
</body>
</html>
