<h1>Process Templates</h1>
<p class="text-muted">
  A process template stores a reusable ticket. You can create a ticket from it on demand, or
  schedule ticket creation at a fixed interval (UTC).
  <strong>Schedules create tickets only.</strong>
  A schedule creates one ordinary ticket each interval; it does not run anything in the background
  and does not execute work on its own. Every generated ticket flows through the normal run,
  triage, verification, and policy controls. This page is read-only — viewing it never creates a
  ticket or triggers a schedule.
</p>

<% if (userPermissions.includes('processTemplate:manage')) { %>
<section class="admin-block">
  <h2>Create Process Template</h2>
  <form id="create-pt-form" class="ticket-form">
    <div class="form-group">
      <label for="pt-name">Template Name *</label>
      <input type="text" id="pt-name" name="name" required>
    </div>
    <div class="form-group">
      <label for="pt-objective">Ticket Objective *</label>
      <textarea id="pt-objective" name="objective" required rows="2"></textarea>
    </div>
    <div class="form-group">
      <label for="pt-assign-type">Assignment target type</label>
      <select id="pt-assign-type" name="assignmentTargetType">
        <option value="">Select worker type</option>
        <option value="agent">One agent</option>
        <option value="group">Agent group</option>
      </select>
    </div>
    <div class="form-group" id="pt-assign-target-group" style="display:none">
      <label for="pt-assign-target">Assignment target</label>
      <select id="pt-assign-target" name="assignmentTargetId">
        <option value="">Select a target type first</option>
      </select>
    </div>
    <div class="form-group">
      <label>Capability</label>
      <label class="checkbox-label"><input type="radio" name="capabilityType" value="directAction" checked> Direct action</label>
      <label class="checkbox-label"><input type="radio" name="capabilityType" value="workflow"> Workflow</label>
    </div>
    <button type="submit" class="btn-submit">Create Template</button>
    <span id="pt-create-msg" class="text-muted"></span>
  </form>
</section>
<% } %>

<%
  var templateList = typeof templates === 'undefined' ? [] : templates;
  var allowTrigger = typeof canTrigger !== 'undefined' && canTrigger;
  function describeAssignment(tt) {
    if (!tt) return '';
    return (tt.assignmentTargetType || '?') + ' #' + (tt.assignmentTargetId == null ? '?' : tt.assignmentTargetId);
  }
  function describeSchedule(s) {
    if (!s || s.enabled !== true || s.kind !== 'interval') return 'Off';
    return 'Creates a ticket every ' + s.everySeconds + ' seconds in UTC';
  }
  function dueLabel(d) {
    return ({
      template_disabled: 'Template disabled', unscheduled: 'Not scheduled',
      schedule_paused: 'Schedule paused', schedule_disabled: 'Schedule off',
      invalid_schedule: 'Invalid schedule', not_due: 'Not due', due: 'Due for ticket creation'
    })[d] || d || '';
  }
  function healthLabel(h) {
    return ({
      disabled: 'Disabled', invalid_schedule: 'Invalid schedule',
      attention_needed: 'Needs operator attention', paused: 'Paused',
      no_recent_triggers: 'No generated tickets yet', ok: 'OK'
    })[h] || h || '';
  }
  function hasReusableInterval(s) {
    return Boolean(s && s.kind === 'interval' && Number.isInteger(s.everySeconds) && s.everySeconds > 0);
  }
%>

<% if (templateList.length === 0) { %>
  <p class="text-muted">No process templates yet.</p>
<% } else { %>
  <table class="tickets-table">
    <thead>
      <tr>
        <th>Template</th>
        <th>State</th>
        <th>Objective</th>
        <th>Assignment</th>
        <th>Schedule</th>
        <th>Generated tickets</th>
        <th>Recent generated tickets</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% templateList.forEach(function (template) {
           var tt = template.ticketTemplate || {};
           var sch = template.schedule || null;
           var counts = template.generatedTicketCounts || { total: 0, blocked: 0, triaged: 0, pending: 0, inProgress: 0, completed: 0, failed: 0 };
           var recent = template.recentGeneratedTickets || [];
      %>
        <tr>
          <td><a href="/process-templates/<%= template.id %>"><%= template.name %></a> <span class="text-muted">v<%= template.version || 1 %></span></td>
          <td>
            <span class="badge"><%= template.enabled ? 'Enabled' : 'Disabled' %></span>
            <span class="badge badge--due-<%= template.dueStatus %>"><%= dueLabel(template.dueStatus) %></span>
            <span class="badge badge--health-<%= template.healthStatus %>"><%= healthLabel(template.healthStatus) %></span>
            <% if (template.dueStatus === 'invalid_schedule') { %>
              <div class="text-muted">⚠ Invalid schedule — this template will not create scheduled tickets until the schedule is fixed.</div>
            <% } else if (template.dueStatus === 'due') { %>
              <div class="text-muted">Due for ticket creation — the next scan creates one ticket; missed intervals are not backfilled.</div>
            <% } %>
            <div>
              <% if (template.enabled) { %>
                <button type="button" class="btn-secondary" data-template-id="<%= template.id %>" data-control="disable">Disable template</button>
              <% } else if (allowTrigger) { %>
                <button type="button" class="btn-secondary" data-template-id="<%= template.id %>" data-control="enable">Enable template</button>
              <% } else { %>
                <span class="text-muted">disabled — enabling requires ticket:create</span>
              <% } %>
            </div>
          </td>
          <td><%= tt.objective || '' %></td>
          <td><%= describeAssignment(tt) %></td>
          <td>
            <%= describeSchedule(sch) %>
            <% if (sch && sch.enabled) { %>
              <div class="text-muted">next: <%= sch.nextRunAt || '—' %> · last: <%= sch.lastScheduledTriggerAt || 'never' %></div>
            <% } %>
            <% if (sch && sch.enabled) { %>
              <div><button type="button" class="btn-secondary" data-template-id="<%= template.id %>" data-control="schedule/pause">Pause scheduled ticket creation</button></div>
            <% } else if (hasReusableInterval(sch)) { %>
              <div class="text-muted">Paused schedules do not create tickets. Manual ticket creation is still available while only the schedule is paused.</div>
              <% if (allowTrigger) { %>
                <div><button type="button" class="btn-secondary" data-template-id="<%= template.id %>" data-control="schedule/resume">Resume scheduled ticket creation</button></div>
              <% } else { %>
                <div class="text-muted">resuming requires ticket:create</div>
              <% } %>
            <% } %>
            <% if (allowTrigger) { %>
              <form class="process-template-schedule" data-template-id="<%= template.id %>">
                <input type="number" name="everySeconds" min="60" step="1"
                  value="<%= sch && sch.everySeconds ? sch.everySeconds : '' %>" placeholder="seconds (UTC)">
                <button type="submit" class="btn-small" data-action="enable">Schedule ticket creation</button>
                <% if (sch && sch.enabled) { %>
                  <button type="button" class="btn-small" data-action="disable">Disable schedule</button>
                <% } %>
              </form>
            <% } %>
          </td>
          <td>
            <%= counts.total %> total
            <div class="text-muted">
              <%= counts.pending %> pending · <%= counts.inProgress %> in progress · <%= counts.completed %> completed
              · <%= counts.failed %> failed · <%= counts.blocked %> blocked · <%= counts.triaged %> triaged
            </div>
            <% if (template.lastGeneratedTicketId != null) { %>
              <div>last: <a href="/tickets/<%= template.lastGeneratedTicketId %>">#<%= template.lastGeneratedTicketId %></a>
                — <%= template.lastGeneratedTicketStatus %><%= template.lastGeneratedTicketTriageReason ? ' (' + template.lastGeneratedTicketTriageReason + ')' : '' %></div>
            <% } %>
          </td>
          <td>
            <% if (recent.length === 0) { %>
              <span class="text-muted">none</span>
            <% } else { %>
              <% recent.forEach(function (entry) { %>
                <div>
                  <a href="/tickets/<%= entry.ticketId %>">#<%= entry.ticketId %></a>
                  <%= entry.triggerType === 'schedule' ? '(scheduled)' : '(manual)' %><% if (entry.templateVersion) { %> v<%= entry.templateVersion %><% } %>
                  — <%= entry.status %><%= entry.triageReason ? ' · ' + entry.triageReason : '' %><% if (entry.scheduledFor) { %> · for <%= entry.scheduledFor %><% } %>
                </div>
              <% }); %>
            <% } %>
          </td>
          <td>
            <% if (allowTrigger && template.enabled) { %>
              <form class="process-template-trigger" data-template-id="<%= template.id %>" method="post" action="/api/process-templates/<%= template.id %>/trigger">
                <button type="submit" class="btn-submit">Create ticket from template</button>
              </form>
            <% } else if (!template.enabled) { %>
              <span class="text-muted">disabled</span>
            <% } else { %>
              <span class="text-muted">requires ticket:create</span>
            <% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>

<script>
  // Progressive enhancement: manual trigger posts the trigger as JSON with a
  // client-generated idempotency token, then opens the generated ticket.
  document.querySelectorAll('form.process-template-trigger').forEach(function (form) {
    form.addEventListener('submit', function (event) {
      event.preventDefault();
      var token = (window.crypto && window.crypto.randomUUID) ? window.crypto.randomUUID() : String(Date.now()) + '-' + Math.random();
      var button = form.querySelector('button');
      if (button) button.disabled = true;
      fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ triggerToken: token })
      }).then(function (res) { return res.json(); }).then(function (data) {
        if (data && data.ticketId) {
          window.location.href = '/tickets/' + data.ticketId;
        } else {
          if (button) button.disabled = false;
          alert((data && data.error) ? data.error : 'Trigger failed');
        }
      }).catch(function () {
        if (button) button.disabled = false;
        alert('Trigger failed');
      });
    });
  });

  // Schedule control: enable an interval schedule (UTC) or disable it. Scheduling only
  // creates ordinary tickets at the interval; it does not execute work on its own.
  function postSchedule(id, payload) {
    return fetch('/api/process-templates/' + id + '/schedule', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    }).then(function (res) { return res.json(); });
  }
  document.querySelectorAll('form.process-template-schedule').forEach(function (form) {
    var id = form.getAttribute('data-template-id');
    form.addEventListener('submit', function (event) {
      event.preventDefault();
      var everySeconds = parseInt(form.querySelector('input[name="everySeconds"]').value, 10);
      postSchedule(id, { enabled: true, kind: 'interval', everySeconds: everySeconds }).then(function (data) {
        if (data && data.ok) { window.location.reload(); }
        else { alert((data && data.error) ? data.error : 'Schedule failed'); }
      }).catch(function () { alert('Schedule failed'); });
    });
    var disableBtn = form.querySelector('button[data-action="disable"]');
    if (disableBtn) {
      disableBtn.addEventListener('click', function () {
        postSchedule(id, { enabled: false }).then(function (data) {
          if (data && data.ok) { window.location.reload(); }
          else { alert((data && data.error) ? data.error : 'Disable failed'); }
        }).catch(function () { alert('Disable failed'); });
      });
    }
  });

  // Template enable/disable and schedule pause/resume controls. Each posts to its
  // dedicated endpoint and reloads. These stop/resume FUTURE template-created tickets
  // only — they never touch existing tickets, runs, or history.
  document.querySelectorAll('button[data-template-id]').forEach(function (button) {
    button.addEventListener('click', function () {
      var id = button.getAttribute('data-template-id');
      var control = button.getAttribute('data-control'); // disable | enable | schedule/pause | schedule/resume
      button.disabled = true;
      fetch('/api/process-templates/' + id + '/' + control, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}'
      }).then(function (res) { return res.json(); }).then(function (data) {
        if (data && data.ok) { window.location.reload(); }
        else { button.disabled = false; alert((data && data.error) ? data.error : 'Action failed'); }
      }).catch(function () { button.disabled = false; alert('Action failed'); });
    });
  });

  // Create template
  (function() {
    var form = document.getElementById('create-pt-form');
    if (!form) return;
    var agents = <%- JSON.stringify(agents || []) %>;
    var groups = <%- JSON.stringify(groups || []) %>;
    var typeSelect = document.getElementById('pt-assign-type');
    var targetSelect = document.getElementById('pt-assign-target');
    var targetGroup = document.getElementById('pt-assign-target-group');

    function populateTargets() {
      var type = typeSelect.value;
      if (!type) { targetGroup.style.display = 'none'; return; }
      var items = type === 'agent' ? agents : groups;
      targetSelect.innerHTML = '<option value="">' + (type === 'agent' ? 'Select an agent' : 'Select an agent group') + '</option>' +
        items.map(function(item) { return '<option value="' + item.id + '">' + item.name + '</option>'; }).join('');
      targetGroup.style.display = '';
    }
    typeSelect.addEventListener('change', populateTargets);

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      var msg = document.getElementById('pt-create-msg');
      btn.disabled = true;
      msg.textContent = '';
      var assignType = typeSelect.value;
      var assignId = targetSelect.value;
      try {
        var res = await fetch('/api/process-templates', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: document.getElementById('pt-name').value.trim(),
            enabled: true,
            ticketTemplate: {
              objective: document.getElementById('pt-objective').value.trim(),
              assignmentTargetType: assignType || null,
              assignmentTargetId: assignId ? parseInt(assignId, 10) : null,
              capabilityType: form.querySelector('input[name="capabilityType"]:checked').value
            }
          })
        });
        var data = await res.json().catch(function() { return null; });
        if (res.ok && data && data.template && data.template.id != null) { window.location.reload(); return; }
        msg.textContent = (data && data.error) ? data.error : 'Create failed';
      } catch (err) { msg.textContent = 'Create failed'; }
      btn.disabled = false;
    });
  })();
</script>
