<h1><%= isEdit ? 'Edit Workflow' : 'Create Workflow' %></h1>
<p class="text-muted">Define workflows as JSON using action names from the actions catalog.</p>

<% if (errors && errors.length > 0) { %>
  <div class="error-message">
    <strong>Workflow validation failed</strong>
    <ul>
      <% errors.forEach(function(error) { %>
        <li><%= error %></li>
      <% }); %>
    </ul>
  </div>
<% } %>

<form action="<%= isEdit ? '/admin/workflows/' + workflow.id : '/admin/workflows' %>" method="POST" class="ticket-form">
  <div class="form-group">
    <label for="definition">Workflow JSON *</label>
    <textarea id="definition" name="definition" rows="28" spellcheck="false" required><%= definition %></textarea>
    <p class="form-hint">Unknown actions and invalid action inputs are rejected before a workflow can be saved.</p>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn-submit"><%= isEdit ? 'Save Workflow' : 'Create Workflow' %></button>
    <a href="/admin/workflows" class="btn-secondary">Cancel</a>
  </div>
</form>
