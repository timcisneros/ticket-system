<h1>Workflow Capabilities</h1>
<p class="text-muted">Approved composed workflows backed by the workflow catalog and actions catalog.</p>

<div class="actions actions--page-header">
  <a href="/admin/workflows/new" class="btn-small">Create workflow</a>
</div>

<% if (!workflows || workflows.length === 0) { %>
  <section class="admin-block">
    <p class="text-muted">No composed workflows have been created yet.</p>
  </section>
<% } else { %>
  <table class="tickets-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>ID</th>
        <th>Status</th>
        <th>Steps</th>
        <th>Postconditions</th>
        <th>Updated</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% workflows.forEach(function(workflow) { %>
        <tr>
          <td>
            <strong><%= workflow.name %></strong>
            <% if (workflow.description) { %>
              <div class="text-muted"><%= workflow.description %></div>
            <% } %>
          </td>
          <td>
            <code><%= workflow.id %></code>
            <div class="text-muted">workflow · revision <%= workflow.revision || 1 %></div>
          </td>
          <td><%= workflow.enabled === false ? 'disabled' : 'enabled' %></td>
          <td><%= Array.isArray(workflow.actions) ? workflow.actions.length : 0 %></td>
          <td>
            <% const postconditions = Array.isArray(workflow.postconditions) ? workflow.postconditions : []; %>
            <% if (postconditions.length === 0) { %>
              <span class="text-muted">None</span>
            <% } else { %>
              <%= postconditions.length %> check<%= postconditions.length === 1 ? '' : 's' %>
              <ul class="text-muted" style="margin:4px 0 0;padding-left:18px;">
                <% postconditions.forEach(function(pc) { %>
                  <li><code><%= typeof formatPostconditionAssertion === 'function' ? formatPostconditionAssertion(pc) : (pc.type || 'unknown') %></code></li>
                <% }) %>
              </ul>
            <% } %>
          </td>
          <td><%= workflow.updatedAt || workflow.createdAt || 'Unknown' %></td>
          <td class="actions">
            <a href="/admin/workflows/<%= workflow.id %>/edit" class="btn-small">Edit JSON</a>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>
