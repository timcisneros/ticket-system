<h1>Runtime Limits</h1>
<p class="text-muted">Per-run limits for newly started agent runs. System-wide limits apply to the entire server. UI values can lower deployment caps but cannot raise above deployment caps. Leave a field empty to inherit its deployment/default cap.</p>

<div class="actions actions--page-header">
  <a href="/admin" class="btn-small">Back to Admin</a>
</div>

<% if (error) { %>
  <div class="error-message"><%= error %></div>
<% } %>
<% if (saved) { %>
  <div class="success-message">Runtime limits saved. The new values apply to newly started runs.</div>
<% } %>

<form action="/admin/runtime-limits" method="POST">
  <section class="admin-block">
    <h2>Per-Run Limits</h2>
    <table class="tickets-table">
      <thead>
        <tr>
          <th>Limit</th>
          <th>Deployment cap</th>
          <th>Configured UI value</th>
          <th>Effective value</th>
        </tr>
      </thead>
      <tbody>
        <% runtimeLimitsState.rows.forEach(function(row) { %>
          <tr>
            <td>
              <label for="<%= row.key %>"><strong><%= row.label %></strong></label>
              <div class="form-hint"><%= row.help %></div>
            </td>
            <td><code><%= row.deploymentCap %></code></td>
            <td>
              <div class="form-group form-group--compact">
                <input
                  type="number"
                  id="<%= row.key %>"
                  name="<%= row.key %>"
                  min="<%= row.minimum %>"

                  step="1"
                  placeholder="inherit"
                  value="<%= row.inputValue === null || row.inputValue === undefined ? '' : row.inputValue %>"
                >
              </div>
              <div class="form-hint"><%= row.configuredValue === null ? 'Currently inherits deployment/default.' : 'Currently configured: ' + row.configuredValue %></div>
            </td>
            <td><code><%= row.effectiveValue %></code></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </section>

  <section class="admin-block admin-block--spaced">
    <h2>System-Wide Limits</h2>
    <table class="tickets-table">
      <thead>
        <tr>
          <th>Limit</th>
          <th>Deployment cap</th>
          <th>Configured UI value</th>
          <th>Effective value</th>
        </tr>
      </thead>
      <tbody>
        <% runtimeLimitsState.systemRows.forEach(function(row) { %>
          <tr>
            <td>
              <label for="<%= row.key %>"><strong><%= row.label %></strong></label>
              <div class="form-hint"><%= row.help %></div>
            </td>
            <td><code><%= row.deploymentCap %></code></td>
            <td>
              <div class="form-group form-group--compact">
                <input
                  type="number"
                  id="<%= row.key %>"
                  name="<%= row.key %>"
                  min="<%= row.minimum %>"

                  step="1"
                  placeholder="inherit"
                  value="<%= row.inputValue === null || row.inputValue === undefined ? '' : row.inputValue %>"
                >
              </div>
              <div class="form-hint"><%= row.configuredValue === null ? 'Currently inherits deployment/default.' : 'Currently configured: ' + row.configuredValue %></div>
            </td>
            <td><code><%= row.effectiveValue %></code></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </section>

  <div class="form-actions">
    <button type="submit" class="btn-submit">Save Runtime Limits</button>
  </div>
</form>
