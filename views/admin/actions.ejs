<h1>Actions Catalog</h1>
<p class="text-muted">Actions available to direct agent work and composed workflows, with concrete inputs, outputs, and errors.</p>

<div class="action-filter-bar">
  <label class="filter-label">
    Invoker:
    <select id="filter-invoker" onchange="applyFilters()" class="filter-select">
      <option value="">All</option>
      <% invokers.forEach(function(inv) { %>
        <option value="<%= inv %>"><%= inv %></option>
      <% }); %>
    </select>
  </label>
  <label class="filter-label">
    <input type="checkbox" id="filter-mutating-only" onchange="applyFilters()">
    Mutating only
  </label>
  <span class="filter-count">Total: <strong id="action-count"><%= actions.length %></strong> actions</span>
</div>

<table class="tickets-table" id="actions-table">
  <thead>
    <tr>
      <th>Action</th>
      <th>Invoker</th>
      <th>Mutating</th>
      <th>Contract</th>
    </tr>
  </thead>
  <tbody>
    <% function renderShape(shape) {
      if (shape === null || shape === undefined) return '<span class="text-muted">No body</span>';
      return '<pre class="code-block code-block--compact">' + JSON.stringify(shape, null, 2) + '</pre>';
    } %>
    <% actions.forEach(function(action) { %>
      <tr class="action-row"
          data-invoker="<%= action.invoker %>"
          data-mutating="<%= action.mutating %>">
        <td><strong><%= action.displayName || action.name %></strong></td>
        <td><span class="status-badge status-badge--invoker"><%= action.invoker %></span></td>
        <td>
          <% if (action.mutating) { %>
            <span class="status-badge status-badge--mutating-yes">yes</span>
          <% } else { %>
            <span class="status-badge status-badge--mutating-no">no</span>
          <% } %>
        </td>
        <td>
          <details class="log-details">
            <summary>Contract</summary>
            <div class="log-json">

              <div class="contract-section">
                <div class="contract-section-header">Input</div>
                <%- renderShape(action.inputSchema) %>
              </div>

              <div class="contract-section">
                <div class="contract-section-header">Output</div>
                <%- renderShape(action.outputSchema) %>
              </div>

              <div class="contract-section">
                <div class="contract-section-header">Error</div>
                <%- renderShape(action.errorSchema) %>
              </div>

            </div>
          </details>
        </td>
      </tr>
    <% }); %>
  </tbody>
</table>

<script>
function applyFilters() {
  const invFilter = (document.getElementById('filter-invoker').value || '').toLowerCase();
  const mutOnly = document.getElementById('filter-mutating-only').checked;
  const rows = document.querySelectorAll('.action-row');
  let visible = 0;

  rows.forEach(function(row) {
    const inv = (row.getAttribute('data-invoker') || '').toLowerCase();
    const mut = row.getAttribute('data-mutating') === 'true';

    const invMatch = !invFilter || inv === invFilter;
    const mutMatch = !mutOnly || mut;

    row.style.display = invMatch && mutMatch ? '' : 'none';
    if (invMatch && mutMatch) visible++;
  });

  document.getElementById('action-count').textContent = visible;
}
</script>
