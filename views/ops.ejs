<h1>Operational Transparency</h1>
<p class="text-muted">
  A <strong>read-only</strong> snapshot of what exists, what is active, what is blocked, and what is
  unresolved across the substrate. It is derived live from existing stores and runtime state — it
  creates no new source of truth, writes nothing, and offers no remediation/rerun/mutation controls. Generated
  <%= summary.generatedAt %>.
</p>

<section class="admin-block">
  <h2>Warnings</h2>
  <% var w = summary.warnings; var anyWarn = Object.keys(w).some(function (k) { return w[k]; }); %>
  <% if (!anyWarn) { %>
    <p class="text-muted">No warning flags.</p>
  <% } else { %>
    <ul class="item-list">
      <% if (w.unresolvedTriageExists) { %><li>Unresolved triage exists — <a href="/inbox">/inbox</a></li><% } %>
      <% if (w.blockedTicketsExist) { %><li>Blocked tickets exist — <a href="/tickets">/tickets</a></li><% } %>
      <% if (w.failedRunsExist) { %><li>Failed runs exist</li><% } %>
      <% if (w.connectorReadRefusalsExist) { %><li>Connector read refusals recorded — <a href="/connectors">/connectors</a></li><% } %>
      <% if (w.watcherFailedOrRefusedExist) { %><li>Watcher failed/refused observations recorded — <a href="/watchers">/watchers</a></li><% } %>
      <% if (w.noActiveWorkContexts) { %><li>No active Work Contexts — <a href="/work-contexts">/work-contexts</a></li><% } %>
      <% if (w.noRoutingPolicies) { %><li>No model routing policies — <a href="/model-routing-policies">/model-routing-policies</a></li><% } %>
      <% if (w.noConnectors) { %><li>No connectors configured</li><% } %>
      <% if (w.eventJournalPressureExists) { %><li>Event append pressure or backpressure rejection detected — inspect Event append admission below</li><% } %>
      <% if (w.versionConsistencyUnresolved) { %><li>Process-template version consistency unresolved — see <a href="/logs">/logs</a></li><% } %>
    </ul>
  <% } %>
</section>

<section class="admin-block">
  <h2>Event append admission</h2>
  <% var journal = summary.eventJournal; %>
  <p class="text-muted">Live, process-local admission pressure. Durable acknowledgement still occurs only after the committed batch is synced. These metrics do not cap or report total events.jsonl growth. Browse the recorded events themselves at <a href="/event-journal">/event-journal</a>.</p>
  <table class="tickets-table">
    <tbody>
      <tr><th>Status</th><td><%= journal.status %></td></tr>
      <tr><th>Admitted producers</th><td><%= journal.current.admittedProducers %> / <%= journal.config.maxOutstandingEntries %> record slots · <%= journal.current.availableProducerSlots %> slots available</td></tr>
      <tr><th>Reserved capacity</th><td><%= journal.current.admissionReservedBytes %> / <%= journal.config.maxOutstandingBytes %> bytes · <%= journal.current.availableReservationBytes %> bytes available · <%= journal.config.maxWorstCaseProducers %> simultaneous maximum-record scopes</td></tr>
      <tr><th>Outstanding</th><td><%= journal.current.outstandingEntries %> / <%= journal.config.maxOutstandingEntries %> entries · <%= journal.current.outstandingBytes %> / <%= journal.config.maxOutstandingBytes %> bytes · <%= Math.round(journal.current.utilization * 1000) / 10 %>% utilized</td></tr>
      <tr><th>High-water mark</th><td><%= journal.highWatermarks.outstandingEntries %> outstanding entries · <%= journal.highWatermarks.outstandingBytes %> outstanding bytes · <%= journal.highWatermarks.admittedProducers %> admitted producers · <%= journal.highWatermarks.admissionReservedBytes %> reserved bytes</td></tr>
      <tr><th>Committed</th><td><%= journal.totals.committedEntries %> entries · <%= journal.totals.committedBytes %> bytes · <%= journal.totals.commitBatches %> batches</td></tr>
      <tr><th>Admission outcomes</th><td><%= journal.totals.admissionAcquired %> acquired · <%= journal.totals.admissionReleased %> released · <%= journal.totals.admissionRejected %> refused · <%= journal.totals.oversizedRejections %> oversized</td></tr>
      <tr><th>Commit latency</th><td>last <%= journal.commitTiming.lastCommitDurationMs === null ? 'unavailable' : journal.commitTiming.lastCommitDurationMs.toFixed(2) + ' ms' %> · max <%= journal.commitTiming.maxCommitDurationMs.toFixed(2) %> ms</td></tr>
      <tr><th>Batch configuration</th><td>up to <%= journal.config.maxBatchEntries %> entries / <%= journal.config.maxBatchBytes %> bytes · record maximum <%= journal.config.maxRecordBytes %> bytes</td></tr>
    </tbody>
  </table>
</section>

<section class="admin-block">
  <h2>Summary</h2>
  <table class="tickets-table">
    <tbody>
      <tr><th>Tickets</th><td>total <%= summary.tickets.total %> · open <%= summary.tickets.open %> · blocked <%= summary.tickets.blocked %> · completed <%= summary.tickets.completed %> · failed <%= summary.tickets.failed %></td></tr>
      <tr><th>Runs</th><td>total <%= summary.runs.total %> · running/pending <%= summary.runs.running %> · completed <%= summary.runs.completed %> · failed <%= summary.runs.failed %> · interrupted <%= summary.runs.interrupted %></td></tr>
      <tr><th>Unresolved triage</th><td>tickets <%= summary.triage.unresolvedTicketCount %> · runs <%= summary.triage.unresolvedRunCount %> — <a href="/inbox">/inbox</a></td></tr>
      <tr><th>Work Contexts</th><td>active <%= summary.workContexts.active %> · archived <%= summary.workContexts.archived %> — <a href="/work-contexts">/work-contexts</a></td></tr>
      <tr><th>Watchers</th><td>active <%= summary.watchers.active %> · paused <%= summary.watchers.paused %> · archived <%= summary.watchers.archived %> — <a href="/watchers">/watchers</a></td></tr>
      <tr><th>Connectors</th><td>active <%= summary.connectors.active %> · paused <%= summary.connectors.paused %> · archived <%= summary.connectors.archived %> — <a href="/connectors">/connectors</a></td></tr>
      <tr><th>Model routing policies</th><td>active <%= summary.modelRoutingPolicies.active %> · archived <%= summary.modelRoutingPolicies.archived %> — <a href="/model-routing-policies">/model-routing-policies</a></td></tr>
      <tr><th>Process templates</th><td>total <%= summary.processTemplates.total %> · enabled <%= summary.processTemplates.enabled %> · disabled <%= summary.processTemplates.disabled %> · scheduled <%= summary.processTemplates.scheduled %> · paused <%= summary.processTemplates.pausedSchedule %> — <a href="/process-templates">/process-templates</a></td></tr>
      <tr><th>Schedules</th><td>enabled <%= summary.schedules.enabled %> · disabled <%= summary.schedules.disabled %></td></tr>
    </tbody>
  </table>
</section>

<section class="admin-block">
  <h2>Recent failed runs</h2>
  <% if (summary.recentFailedRuns.length === 0) { %><p class="text-muted">None.</p><% } else { %>
    <ul class="item-list"><% summary.recentFailedRuns.forEach(function (r) { %><li>Run <a href="/runs/<%= r.runId %>">#<%= r.runId %></a> (ticket <a href="/tickets/<%= r.ticketId %>">#<%= r.ticketId %></a>)</li><% }); %></ul>
  <% } %>
</section>

<section class="admin-block">
  <h2>Recent connector refusals</h2>
  <% if (summary.connectors.recentRefusals.length === 0) { %><p class="text-muted">None.</p><% } else { %>
    <ul class="item-list"><% summary.connectors.recentRefusals.forEach(function (r) { %><li>Connector #<%= r.connectorId %> — <%= r.operation %><% if (r.reason) { %> (<%= r.reason %>)<% } %></li><% }); %></ul>
  <% } %>
</section>

<section class="admin-block">
  <h2>Recent watcher failures</h2>
  <% if (summary.watchers.recentFailures.length === 0) { %><p class="text-muted">None.</p><% } else { %>
    <ul class="item-list"><% summary.watchers.recentFailures.forEach(function (o) { %><li>Watcher #<%= o.watcherId %> — <%= o.status %><% if (o.error) { %> (<%= o.error %>)<% } %></li><% }); %></ul>
  <% } %>
</section>

<section class="admin-block">
  <h2>Recent authority/refusal signals</h2>
  <% if (summary.recentAuthorityDenials.length === 0) { %><p class="text-muted">None.</p><% } else { %>
    <ul class="item-list"><% summary.recentAuthorityDenials.forEach(function (d) { %><li><%= d.type %>: <%= d.message %></li><% }); %></ul>
  <% } %>
</section>
