<h1>Create New Ticket</h1>

<% if (error) { %>
  <div class="error-message"><%= error %></div>
<% } %>

<form action="/tickets" method="POST" class="ticket-form">
  <div class="form-group">
    <label for="objective">Objective *</label>
    <textarea
      id="objective"
      name="objective"
      rows="5"
      placeholder="Describe the concrete result you want. Avoid vague requests like: &quot;improve the project&quot;"
      required
    ></textarea>
    <div class="ticket-shape-assist">
      <button type="button" class="btn-small" id="shapeObjectiveButton">Suggest bounded version</button>
    </div>
    <div class="ticket-shape-panel" id="ticketShapePanel" hidden aria-live="polite"></div>
  </div>

  <div class="form-group">
    <label for="capabilityType">Execution Path *</label>
    <select id="capabilityType" name="capabilityType" required>
      <option value="directAction" selected>Direct agent action</option>
      <option value="workflow">Workflow</option>
    </select>
  </div>

  <div class="form-group" id="workflowGroup" hidden>
    <label for="workflowId">Workflow *</label>
    <select id="workflowId" name="workflowId">
      <option value="">Select workflow</option>
      <% (typeof workflows === 'undefined' ? [] : workflows).forEach(workflow => { %>
        <option value="<%= workflow.id %>" data-input-schema="<%= JSON.stringify(workflow.inputSchema || {}) %>"><%= workflow.name %></option>
      <% }); %>
    </select>
    <p class="form-hint">Inputs are JSON. File and folder actions are recorded for replay and recovery.</p>
  </div>

  <div class="form-group" id="workflowInputGroup" hidden>
    <label for="workflowInput">Input JSON</label>
    <textarea id="workflowInput" name="workflowInput" rows="7" spellcheck="false" placeholder="{&quot;path&quot;:&quot;notes/demo.txt&quot;,&quot;instruction&quot;:&quot;Write a short note.&quot;}"></textarea>
  </div>

  <div class="form-group">
    <label for="assignmentTargetType">Who should work on this? *</label>
    <select id="assignmentTargetType" name="assignmentTargetType" required>
      <option value="">Select worker type</option>
      <option value="agent" <%= agents && agents.length > 0 ? 'selected' : '' %>>One agent</option>
      <option value="group">Agent group</option>
    </select>
  </div>

  <div class="form-group">
    <label for="assignmentTargetId">Worker *</label>
    <select id="assignmentTargetId" name="assignmentTargetId" required disabled>
      <option value="">Select a target type first</option>
      <% agents.forEach(agent => { %>
        <option value="<%= agent.id %>" data-target-type="agent"><%= agent.name %></option>
      <% }); %>
      <% agentGroups.forEach(group => { %>
        <option value="<%= group.id %>" data-target-type="group"><%= group.name %></option>
      <% }); %>
    </select>
  </div>

  <div class="form-group" id="assignmentModeGroup" hidden>
    <label for="assignmentMode">How should the group split the work? *</label>
    <select id="assignmentMode" name="assignmentMode">
      <option value="">Select work split</option>
      <option value="allocated">Manual folder scopes</option>
      <option value="dynamic">Automatic folder scopes</option>
    </select>
    <p class="form-hint">
      Manual scopes use folders you choose for each agent. Automatic scopes assign agents to existing top-level workspace folders.
      Group tickets work best when each agent can produce an independent additive output inside its own scope.
    </p>
  </div>

  <div class="form-group" id="ownedPathsGroup" hidden>
    <label>Allowed Folders *</label>
    <p class="form-hint">Enter one existing workspace directory per agent. The system will not create these folders for you.</p>
    <div id="ownedPathsContainer"></div>
    <input type="hidden" name="ownedOutputPaths" id="ownedOutputPathsInput" value="">
  </div>

  <p class="form-hint" id="createRunHint">Creating a ticket with a worker selected starts a run immediately.</p>
  <button type="submit" class="btn-submit" id="createTicketSubmit">Create Ticket</button>
</form>

<script>
const targetTypeSelect = document.getElementById('assignmentTargetType');
const targetSelect = document.getElementById('assignmentTargetId');
const assignmentModeGroup = document.getElementById('assignmentModeGroup');
const assignmentModeSelect = document.getElementById('assignmentMode');
const targetOptions = Array.from(targetSelect.querySelectorAll('option[data-target-type]'));
const capabilityTypeSelect = document.getElementById('capabilityType');
const workflowGroup = document.getElementById('workflowGroup');
const workflowInputGroup = document.getElementById('workflowInputGroup');
const workflowSelect = document.getElementById('workflowId');
const workflowInput = document.getElementById('workflowInput');
const ownedPathsGroup = document.getElementById('ownedPathsGroup');
const ownedPathsContainer = document.getElementById('ownedPathsContainer');
const ownedOutputPathsInput = document.getElementById('ownedOutputPathsInput');
const objectiveInput = document.getElementById('objective');
const shapeObjectiveButton = document.getElementById('shapeObjectiveButton');
const ticketShapePanel = document.getElementById('ticketShapePanel');
const createTicketSubmit = document.getElementById('createTicketSubmit');

function updateSubmitLabel() {
  if (!createTicketSubmit) return;
  const hasWorker = Boolean(targetTypeSelect.value) && Boolean(targetSelect.value);
  createTicketSubmit.textContent = hasWorker ? 'Create & Run' : 'Create Ticket';
}

const agentGroupMembers = <%- JSON.stringify(typeof agentGroupMembers === 'undefined' ? {} : agentGroupMembers) %>;
const initialAgents = <%- JSON.stringify((agents || []).map(agent => ({ id: agent.id, name: agent.name }))) %>;
const workflowSchemas = <%- JSON.stringify((typeof workflows === 'undefined' ? [] : workflows).reduce((acc, workflow) => {
  acc[workflow.id] = workflow.inputSchema || {};
  return acc;
}, {})) %>;

function updateOwnedPaths() {
  const selectedGroupId = parseInt(targetSelect.value);
  const isAllocated = assignmentModeSelect.value === 'allocated';

  if (!selectedGroupId || !isAllocated) {
    ownedPathsGroup.hidden = true;
    return;
  }

  const members = agentGroupMembers[String(selectedGroupId)] || [];
  if (members.length === 0) {
    ownedPathsGroup.hidden = true;
    return;
  }

  ownedPathsGroup.hidden = false;
  ownedPathsContainer.innerHTML = members.map(m =>
    '<div class="owned-path-row">' +
      '<span class="owned-path-agent-name">' + m.name + ':</span>' +
      '<input type="text" class="owned-path-input" data-agent-id="' + m.id + '" placeholder="e.g. projects/feature-x/" value="">' +
    '</div>'
  ).join('');
}

function workflowInputExample(schema) {
  const example = {};
  Object.entries(schema || {}).forEach(([key, type]) => {
    if (type === 'number') example[key] = 0;
    else if (type === 'boolean') example[key] = false;
    else if (Array.isArray(type)) example[key] = [];
    else if (type && typeof type === 'object') example[key] = {};
    else example[key] = '';
  });
  return JSON.stringify(example, null, 2);
}

function updateWorkflowControls() {
  const isWorkflow = capabilityTypeSelect.value === 'workflow';
  workflowGroup.hidden = !isWorkflow;
  workflowInputGroup.hidden = !isWorkflow;
  workflowSelect.required = isWorkflow;
  workflowInput.required = isWorkflow;

  if (isWorkflow && workflowSelect.value && !workflowInput.value.trim()) {
    workflowInput.value = workflowInputExample(workflowSchemas[workflowSelect.value]);
  }
}

function updateAssignmentTargets() {
  const selectedType = targetTypeSelect.value;
  targetSelect.value = '';
  targetSelect.disabled = !selectedType;
  assignmentModeSelect.value = '';
  assignmentModeGroup.hidden = selectedType !== 'group';
  assignmentModeSelect.required = selectedType === 'group';
  assignmentModeSelect.disabled = selectedType !== 'group';
  ownedPathsGroup.hidden = true;

  targetOptions.forEach(option => {
    option.hidden = option.dataset.targetType !== selectedType;
  });

  targetSelect.querySelector('option[value=""]').textContent = selectedType
    ? 'Select ' + (selectedType === 'agent' ? 'an agent' : 'an agent group')
    : 'Select a target type first';

  updateSubmitLabel();
}

function selectSingleAvailableWorker() {
  if (targetTypeSelect.value !== 'agent' || initialAgents.length !== 1) return;
  targetSelect.value = String(initialAgents[0].id);
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function renderSuggestionList(title, items) {
  if (!items || items.length === 0) return '';
  return '<div class="ticket-shape-section"><strong>' + title + '</strong><ul>' +
    items.map(item => '<li>' + escapeHtml(item) + '</li>').join('') +
    '</ul></div>';
}

function renderTicketShapeSuggestion(data) {
  const suggestedObjective = data.suggestedObjective || '';
  const tooBroad = data.tooBroadForOneRun
    ? '<span class="ticket-shape-badge ticket-shape-badge--warn">Likely too broad for one run</span>'
    : '<span class="ticket-shape-badge">Likely bounded</span>';
  let html = '<div class="ticket-shape-header"><strong>Suggested bounded ticket</strong>' + tooBroad + '</div>';

  if (suggestedObjective) {
    html += '<textarea id="ticketShapeSuggestedObjective" class="ticket-shape-objective" rows="4">' + escapeHtml(suggestedObjective) + '</textarea>';
    html += '<button type="button" class="btn-small" id="acceptTicketShapeButton">Accept suggestion</button>';
  }

  html += renderSuggestionList('Expected outputs', data.expectedOutputs || []);
  html += renderSuggestionList('Smaller additive tickets', data.decomposition || []);
  html += renderSuggestionList('Warnings', data.warnings || []);

  if (data.groupModeFit) {
    html += '<div class="ticket-shape-section"><strong>Group/dynamic fit</strong><p>' + escapeHtml(data.groupModeFit) + '</p></div>';
  }

  ticketShapePanel.innerHTML = html;
  ticketShapePanel.hidden = false;

  const acceptButton = document.getElementById('acceptTicketShapeButton');
  if (acceptButton) {
    acceptButton.addEventListener('click', () => {
      const suggested = document.getElementById('ticketShapeSuggestedObjective');
      if (suggested) objectiveInput.value = suggested.value;
      objectiveInput.focus();
    });
  }
}

async function suggestBoundedObjective() {
  const objective = objectiveInput.value.trim();
  if (!objective) {
    ticketShapePanel.hidden = false;
    ticketShapePanel.innerHTML = '<div class="ticket-shape-error">Enter an objective before requesting a suggestion.</div>';
    objectiveInput.focus();
    return;
  }

  shapeObjectiveButton.disabled = true;
  ticketShapePanel.hidden = false;
  ticketShapePanel.innerHTML = '<div class="text-muted">Suggesting a bounded version...</div>';

  try {
    const response = await fetch('/api/tickets/shape-objective', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Accept: 'application/json'
      },
      body: JSON.stringify({
        objective,
        assignmentTargetType: targetTypeSelect.value || 'agent',
        assignmentTargetId: targetSelect.value || null,
        assignmentMode: assignmentModeSelect.value || 'individual'
      })
    });
    const data = await response.json().catch(() => ({}));

    if (!response.ok) {
      ticketShapePanel.innerHTML = '<div class="ticket-shape-error">' + escapeHtml(data.error || 'Ticket shaping failed') + '</div>';
      return;
    }

    renderTicketShapeSuggestion(data);
  } catch (error) {
    ticketShapePanel.innerHTML = '<div class="ticket-shape-error">' + escapeHtml(error.message || 'Ticket shaping failed') + '</div>';
  } finally {
    shapeObjectiveButton.disabled = false;
  }
}

targetSelect.addEventListener('change', updateSubmitLabel);
targetTypeSelect.addEventListener('change', updateAssignmentTargets);
targetSelect.addEventListener('change', updateOwnedPaths);
assignmentModeSelect.addEventListener('change', updateOwnedPaths);
capabilityTypeSelect.addEventListener('change', updateWorkflowControls);
workflowSelect.addEventListener('change', function() {
  workflowInput.value = workflowSelect.value ? workflowInputExample(workflowSchemas[workflowSelect.value]) : '';
  updateWorkflowControls();
});
shapeObjectiveButton.addEventListener('click', suggestBoundedObjective);

document.querySelector('.ticket-form').addEventListener('submit', function() {
  const inputs = ownedPathsContainer.querySelectorAll('.owned-path-input');
  const paths = {};
  let hasAny = false;
  inputs.forEach(input => {
    const val = input.value.trim();
    if (val) {
      paths[input.dataset.agentId] = val;
      hasAny = true;
    }
  });
  ownedOutputPathsInput.value = hasAny ? JSON.stringify(paths) : '';
});

updateAssignmentTargets();
updateWorkflowControls();
selectSingleAvailableWorker();
updateSubmitLabel();
</script>
