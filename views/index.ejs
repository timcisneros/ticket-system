<h1>Create New Ticket</h1>

<% if (error) { %>
  <div class="error-message"><%= error %></div>
<% } %>

<form action="/tickets" method="POST" class="ticket-form">
  <div class="form-group">
    <label for="objective">Objective *</label>
    <textarea id="objective" name="objective" rows="5" required></textarea>
    <div class="objective-guidance" aria-label="Bounded execution guidance">
      <p class="form-hint">
        Write a small, concrete output that can finish in one verified transition. One or two file changes usually complete fastest.
      </p>
      <p class="form-hint">
        Avoid vague requests like "improve the project." For larger work, split the ticket into specific additive outputs.
      </p>
      <details class="objective-examples">
        <summary>Examples</summary>
        <ul>
          <li>Good: Create <code>docs/setup.md</code> with install and test steps.</li>
          <li>Good: Add <code>docs/api.md</code> and <code>docs/errors.md</code> with short reference notes.</li>
          <li>Split up: Create 4-8 files as separate concrete tickets or expect multiple bounded transitions.</li>
        </ul>
      </details>
    </div>
  </div>

  <div class="form-group">
    <label for="assignmentTargetType">Who should work on this? *</label>
    <select id="assignmentTargetType" name="assignmentTargetType" required>
      <option value="">Select worker type</option>
      <option value="agent" <%= agents && agents.length > 0 ? 'selected' : '' %>>One agent</option>
      <option value="group">Agent group</option>
    </select>
  </div>

  <div class="form-group">
    <label for="assignmentTargetId">Worker *</label>
    <select id="assignmentTargetId" name="assignmentTargetId" required disabled>
      <option value="">Select a target type first</option>
      <% agents.forEach(agent => { %>
        <option value="<%= agent.id %>" data-target-type="agent"><%= agent.name %></option>
      <% }); %>
      <% agentGroups.forEach(group => { %>
        <option value="<%= group.id %>" data-target-type="group"><%= group.name %></option>
      <% }); %>
    </select>
  </div>

  <div class="form-group" id="assignmentModeGroup" hidden>
    <label for="assignmentMode">How should the group split the work? *</label>
    <select id="assignmentMode" name="assignmentMode">
      <option value="">Select work split</option>
      <option value="allocated">Manual folder scopes</option>
      <option value="dynamic">Automatic folder scopes</option>
    </select>
    <p class="form-hint">
      Manual scopes use folders you choose for each agent. Automatic scopes assign agents to existing top-level workspace folders.
      Group tickets work best when each agent can produce an independent additive output inside its own scope.
    </p>
  </div>

  <div class="form-group" id="ownedPathsGroup" hidden>
    <label>Allowed Folders *</label>
    <p class="form-hint">Enter one existing workspace directory per agent. The system will not create these folders for you.</p>
    <div id="ownedPathsContainer"></div>
    <input type="hidden" name="ownedOutputPaths" id="ownedOutputPathsInput" value="">
  </div>

  <button type="submit" class="btn-submit">Create Ticket</button>
</form>

<script>
const targetTypeSelect = document.getElementById('assignmentTargetType');
const targetSelect = document.getElementById('assignmentTargetId');
const assignmentModeGroup = document.getElementById('assignmentModeGroup');
const assignmentModeSelect = document.getElementById('assignmentMode');
const targetOptions = Array.from(targetSelect.querySelectorAll('option[data-target-type]'));
const ownedPathsGroup = document.getElementById('ownedPathsGroup');
const ownedPathsContainer = document.getElementById('ownedPathsContainer');
const ownedOutputPathsInput = document.getElementById('ownedOutputPathsInput');

const agentGroupMembers = <%- JSON.stringify(typeof agentGroupMembers === 'undefined' ? {} : agentGroupMembers) %>;
const initialAgents = <%- JSON.stringify((agents || []).map(agent => ({ id: agent.id, name: agent.name }))) %>;

function updateOwnedPaths() {
  const selectedGroupId = parseInt(targetSelect.value);
  const isAllocated = assignmentModeSelect.value === 'allocated';

  if (!selectedGroupId || !isAllocated) {
    ownedPathsGroup.hidden = true;
    return;
  }

  const members = agentGroupMembers[String(selectedGroupId)] || [];
  if (members.length === 0) {
    ownedPathsGroup.hidden = true;
    return;
  }

  ownedPathsGroup.hidden = false;
  ownedPathsContainer.innerHTML = members.map(m =>
    '<div class="owned-path-row">' +
      '<span class="owned-path-agent-name">' + m.name + ':</span>' +
      '<input type="text" class="owned-path-input" data-agent-id="' + m.id + '" placeholder="e.g. projects/feature-x/" value="">' +
    '</div>'
  ).join('');
}

function updateAssignmentTargets() {
  const selectedType = targetTypeSelect.value;
  targetSelect.value = '';
  targetSelect.disabled = !selectedType;
  assignmentModeSelect.value = '';
  assignmentModeGroup.hidden = selectedType !== 'group';
  assignmentModeSelect.required = selectedType === 'group';
  assignmentModeSelect.disabled = selectedType !== 'group';
  ownedPathsGroup.hidden = true;

  targetOptions.forEach(option => {
    option.hidden = option.dataset.targetType !== selectedType;
  });

  targetSelect.querySelector('option[value=""]').textContent = selectedType
    ? 'Select ' + (selectedType === 'agent' ? 'an agent' : 'an agent group')
    : 'Select a target type first';
}

function selectSingleAvailableWorker() {
  if (targetTypeSelect.value !== 'agent' || initialAgents.length !== 1) return;
  targetSelect.value = String(initialAgents[0].id);
}

targetTypeSelect.addEventListener('change', updateAssignmentTargets);
targetSelect.addEventListener('change', updateOwnedPaths);
assignmentModeSelect.addEventListener('change', updateOwnedPaths);

document.querySelector('.ticket-form').addEventListener('submit', function() {
  const inputs = ownedPathsContainer.querySelectorAll('.owned-path-input');
  const paths = {};
  let hasAny = false;
  inputs.forEach(input => {
    const val = input.value.trim();
    if (val) {
      paths[input.dataset.agentId] = val;
      hasAny = true;
    }
  });
  ownedOutputPathsInput.value = hasAny ? JSON.stringify(paths) : '';
});

updateAssignmentTargets();
selectSingleAvailableWorker();
</script>
