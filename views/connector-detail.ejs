<p><a href="/connectors">← Connectors</a></p>
<h1><%= connector.name %> <% if (connector.status !== 'active') { %><span class="text-muted">(<%= connector.status %>)</span><% } %></h1>
<p class="text-muted">
  Local/mock connector only. Reads are bounded to <code>sourceRoots</code> within this Work Context
  and produce a receipt (metadata/hash, never full content). Writes are refused in r1.30. The
  credential is shown as a reference only — never a secret value.
</p>
<table class="data-table">
  <tbody>
    <tr><th>Status</th><td><%= connector.status %></td></tr>
    <tr><th>Kind</th><td class="text-muted"><%= connector.kind %></td></tr>
    <tr><th>Work Context</th><td><a href="/work-contexts/<%= connector.workContextId %>">#<%= connector.workContextId %></a></td></tr>
    <tr><th>Credential</th><td class="text-muted"><%= connector.credentialRef ? ('ref: ' + connector.credentialRef) : 'none' %> <em>(reference only — no secret value)</em></td></tr>
    <tr><th>Allowed scopes</th><td class="text-muted"><%= (connector.allowedScopes || []).join(', ') || 'none' %></td></tr>
    <tr><th>Source roots</th><td class="text-muted"><%= (connector.sourceRoots || []).join(', ') || 'none' %></td></tr>
    <tr><th>Target roots</th><td class="text-muted"><%= (connector.targetRoots || []).join(', ') || 'none' %></td></tr>
    <tr><th>Write policy</th><td class="text-muted"><%= connector.writePolicy && connector.writePolicy.mode %> (writes refused in r1.30)</td></tr>
    <tr><th>Sync</th><td class="text-muted"><%= connector.syncPolicy && connector.syncPolicy.mode %> (no background sync)</td></tr>
  </tbody>
</table>

<h2>Recent receipts</h2>
<% if (!receipts || receipts.length === 0) { %>
  <p class="text-muted">No receipts yet. Read via <code>POST /api/connectors/<%= connector.id %>/read</code>.</p>
<% } else { %>
  <table class="data-table">
    <thead><tr><th>#</th><th>Operation</th><th>Object</th><th>Result</th><th>Hash</th><th>When</th></tr></thead>
    <tbody>
      <% receipts.forEach(function (r) { %>
        <tr>
          <td><%= r.id %></td>
          <td><%= r.operation %></td>
          <td class="text-muted"><%= r.externalObjectId || r.sourceRef || r.targetRef || '—' %></td>
          <td><%= r.result ? r.result.status : '—' %><% if (r.error) { %> <span class="text-muted">(<%= r.error %>)</span><% } %></td>
          <td class="text-muted"><%= r.result && r.result.hash ? r.result.hash.slice(0, 12) : '—' %></td>
          <td class="text-muted"><%= r.timestamp %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>
