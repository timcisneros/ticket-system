<div class="page-header">
  <div>
    <h1>Ticket #<%= ticket.id %></h1>
    <p class="text-muted">
      <span class="status-badge status-<%= ticket.status %>"><%= ticket.status %></span>
      <span><%= ticket.objective %></span>
    </p>
  </div>
  <div class="actions">
    <a class="btn-secondary" href="/tickets">Back to Tickets</a>
    <a class="btn-secondary" href="/logs?ticketId=<%= ticket.id %>">Ticket Logs</a>
    <% if (canUpdateTickets && ticket.status !== 'open') { %>
      <button type="button" class="btn-secondary" data-rerun-ticket-id="<%= ticket.id %>"><%= ticket.status === 'failed' ? 'Retry' : 'Rerun' %></button>
    <% } %>
  </div>
</div>
<% if (canUpdateTickets && ticket.status !== 'open') { %>
  <%
    const isGroupTicket = typeof executionState !== 'undefined' && executionState && executionState.isGroup;
    const rerunWord = ticket.status === 'failed' ? 'Retry' : 'Rerun';
  %>
  <p class="form-hint"><%= rerunWord %> interrupts any active run, reopens this ticket, and starts a new run from the current objective and assignment.<%= isGroupTicket ? ' For this group ticket it regenerates the work-unit allocation across group members.' : '' %></p>
<% } %>

<%
  const ticketFeasibility = ticket.feasibility || null;
  const ticketBlockedReason = ticket.blockedReason || (ticketFeasibility && ticketFeasibility.reason) || null;
%>
<% if (ticketBlockedReason || ticketFeasibility) { %>
<section class="detail-section failure-summary">
  <h2>Why this ticket is blocked</h2>
  <% if (ticketBlockedReason) { %>
    <p class="failure-reason"><%= ticketBlockedReason %></p>
  <% } %>
  <% if (ticketFeasibility) { %>
    <dl class="detail-grid">
      <div>
        <dt>Required folders</dt>
        <dd>
          <% if (ticketFeasibility.requiredWritableRoots && ticketFeasibility.requiredWritableRoots.length > 0) { %>
            <% ticketFeasibility.requiredWritableRoots.forEach(root => { %>
              <code class="owned-path"><%= root %></code>
            <% }) %>
          <% } else { %>
            -
          <% } %>
        </dd>
      </div>
      <div>
        <dt>Granted folders</dt>
        <dd>
          <% if (ticketFeasibility.grantedWritableRoots && ticketFeasibility.grantedWritableRoots.length > 0) { %>
            <% ticketFeasibility.grantedWritableRoots.forEach(root => { %>
              <code class="owned-path"><%= root %></code>
            <% }) %>
          <% } else { %>
            -
          <% } %>
        </dd>
      </div>
      <% if (ticketFeasibility.missingAuthorityGrants && ticketFeasibility.missingAuthorityGrants.length > 0) { %>
        <div>
          <dt>Missing grants</dt>
          <dd>
            <% ticketFeasibility.missingAuthorityGrants.forEach(root => { %>
              <code class="owned-path"><%= root %></code>
            <% }) %>
          </dd>
        </div>
      <% } %>
    </dl>
    <details class="collapsible">
      <summary>Technical details</summary>
      <div class="collapsible__content">
        <dl class="detail-grid">
          <div>
            <dt>Code</dt>
            <dd><code><%= ticketFeasibility.code || '-' %></code></dd>
          </div>
          <div>
            <dt>Kind</dt>
            <dd><code><%= ticketFeasibility.kind || '-' %></code></dd>
          </div>
        </dl>
      </div>
    </details>
  <% } %>
</section>
<% } %>

<% if (typeof executionState !== 'undefined' && executionState) { %>
<section class="detail-section">
  <h2>Execution State</h2>
  <dl class="detail-grid">
    <div>
      <dt>Assigned to</dt>
      <dd><%= executionState.assignmentTargetLabel %></dd>
    </div>
    <% if (executionState.isGroup && executionState.assignmentMode) { %>
      <div>
        <dt>Assignment mode</dt>
        <dd><%= executionState.assignmentModeLabel %></dd>
      </div>
    <% } %>
    <div>
      <dt>Auto-run behavior</dt>
      <dd><%= executionState.autoRun.label %></dd>
    </div>
    <div>
      <dt>Latest run</dt>
      <dd>
        <% if (executionState.latestRun) { %>
          <a href="/runs/<%= executionState.latestRun.id %>">Run #<%= executionState.latestRun.id %></a>
          <span class="status-badge status-<%= executionState.latestRun.status %>"><%= executionState.latestRun.status %></span>
        <% } else { %>
          - (no run yet)
        <% } %>
      </dd>
    </div>
    <div>
      <dt>Last outcome</dt>
      <dd><%= executionState.lastOutcomeLabel || '-' %></dd>
    </div>
    <div>
      <dt>Current message</dt>
      <dd>
        <% if (executionState.currentMessage.text) { %>
          <%= executionState.currentMessage.text %>
          <span class="message-source">(source: <%= executionState.currentMessage.source %>)</span>
        <% } else { %>
          <span class="text-muted">none (source: <%= executionState.currentMessage.source %>)</span>
        <% } %>
      </dd>
    </div>
  </dl>
  <% if (executionState.blocked && executionState.blockedReason) { %>
    <p class="failure-reason"><%= executionState.blockedReason %></p>
  <% } %>
  <% if (executionState.group) { %>
    <p class="text-muted">Group fan-out: <%= executionState.group.memberCount %> member<%= executionState.group.memberCount === 1 ? '' : 's' %> ·
      work units: <%= executionState.group.workUnitsTotal %> generated, <%= executionState.group.workUnitsCompleted %> completed<%= executionState.group.workUnitsFailed > 0 ? ', ' + executionState.group.workUnitsFailed + ' failed' : '' %>.
      Completes when all work units complete; fails if any required work unit fails.</p>
  <% } %>
  <% if (ticket.assignmentTargetType === 'group' && ticket.assignmentMode === 'dynamic') { %>
    <%
      const dynamicScopeMap = ticket.ownedOutputPaths && typeof ticket.ownedOutputPaths === 'object' && !Array.isArray(ticket.ownedOutputPaths)
        ? ticket.ownedOutputPaths : null;
    %>
    <p class="text-muted">Automatic folder scopes: group agents are assigned to existing top-level workspace folders in deterministic order (folders by name, agents by id). The ticket runs only when there are at least as many usable folders as group agents.</p>
    <% if (dynamicScopeMap && Object.keys(dynamicScopeMap).length > 0) { %>
      <ul class="text-muted">
        <% Object.keys(dynamicScopeMap).forEach(agentId => { %>
          <% const scopedAgent = agents.find(a => String(a.id) === String(agentId)); %>
          <li><%= scopedAgent ? scopedAgent.name : 'Agent #' + agentId %> → <code class="owned-path"><%= dynamicScopeMap[agentId] %></code></li>
        <% }) %>
      </ul>
    <% } %>
  <% } %>
</section>
<% } %>

<% if (ticket.triage && ticket.triage.required) { %>
<section class="detail-section failure-summary">
  <h2>Ticket-Level Triage</h2>
  <dl class="detail-grid">
    <div><dt>Reason</dt><dd><code><%= ticket.triage.reasonCode %></code></dd></div>
    <div><dt>Required decision</dt><dd><code><%= ticket.triage.requiredDecision %></code></dd></div>
    <div><dt>Summary</dt><dd><%= ticket.triage.summary %></dd></div>
    <div><dt>Allowed next actions</dt><dd><%= ticket.triage.allowedActions.length > 0 ? ticket.triage.allowedActions.join(', ') : 'none' %></dd></div>
    <div><dt>Prohibited actions</dt><dd><%= ticket.triage.prohibitedActions.length > 0 ? ticket.triage.prohibitedActions.join(', ') : 'none' %></dd></div>
  </dl>
  <% if (ticket.triage.evidenceRefs.length > 0) { %>
    <p class="text-muted">Evidence:
      <% ticket.triage.evidenceRefs.forEach(ref => { %><code class="owned-path"><%= ref %></code> <% }) %>
    </p>
  <% } %>
</section>
<% } %>

<% if (typeof latestTriage !== 'undefined' && latestTriage && latestTriage.required) { %>
<section class="detail-section failure-summary">
  <h2>Latest Run Triage</h2>
  <dl class="detail-grid">
    <div><dt>Reason</dt><dd><code><%= latestTriage.reasonCode %></code></dd></div>
    <div><dt>Required decision</dt><dd><code><%= latestTriage.requiredDecision %></code></dd></div>
    <div><dt>Summary</dt><dd><%= latestTriage.summary %></dd></div>
    <div><dt>Allowed next actions</dt><dd><%= latestTriage.allowedActions.length > 0 ? latestTriage.allowedActions.join(', ') : 'none' %></dd></div>
    <div><dt>Prohibited actions</dt><dd><%= latestTriage.prohibitedActions.length > 0 ? latestTriage.prohibitedActions.join(', ') : 'none' %></dd></div>
  </dl>
  <% if (latestTriage.evidenceRefs.length > 0) { %>
    <p class="text-muted">Evidence:
      <% latestTriage.evidenceRefs.forEach(ref => { %><code class="owned-path"><%= ref %></code> <% }) %>
    </p>
  <% } %>
</section>
<% } %>

<% if (ticket.executionPolicy) { %>
<section class="detail-section">
  <h2>Execution Policy</h2>
  <p class="text-muted">Verification is enforced when declared. Other fields below are recorded intent and are not enforced in this release unless explicitly noted.</p>
  <dl class="detail-grid">
    <div><dt>Verification</dt><dd><code><%= ticket.executionPolicy.requireVerification %></code> · enforced for declared workflow postconditions</dd></div>
    <div><dt>Workspace scope</dt><dd><code><%= ticket.executionPolicy.workspaceScope %></code> · enforced by the current workspace path</dd></div>
    <div><dt>Mode</dt><dd><code><%= ticket.executionPolicy.mode %></code> · recorded intent, not enforced</dd></div>
    <div><dt>Workspace writes</dt><dd><%= ticket.executionPolicy.allowWorkspaceWrites ? 'requested' : 'not requested' %> · recorded intent, not enforced</dd></div>
    <div><dt>Parallel runs</dt><dd><%= ticket.executionPolicy.allowParallelRuns ? 'requested' : 'not requested' %> · recorded intent, not enforced</dd></div>
    <div><dt>Child tickets</dt><dd><%= ticket.executionPolicy.allowChildTickets ? 'requested' : 'not requested' %> · recorded intent, not enforced</dd></div>
    <div><dt>Max attempts</dt><dd><%= ticket.executionPolicy.maxAttempts === null ? 'unlimited · enforced for manual rerun-from-start when set' : ticket.executionPolicy.maxAttempts + ' · enforced for manual rerun-from-start' %></dd></div>
    <div><dt>Max runtime</dt><dd><%= ticket.executionPolicy.maxRuntimeMs === null ? 'unspecified' : ticket.executionPolicy.maxRuntimeMs + 'ms' %> · recorded intent, not enforced</dd></div>
    <div><dt>Max model requests</dt><dd><%= ticket.executionPolicy.maxModelRequests === null ? 'unspecified' : ticket.executionPolicy.maxModelRequests %> · recorded intent, not enforced</dd></div>
    <div><dt>Max workspace operations</dt><dd><%= ticket.executionPolicy.maxWorkspaceOperations === null ? 'unspecified' : ticket.executionPolicy.maxWorkspaceOperations %> · recorded intent, not enforced</dd></div>
  </dl>
</section>
<% } %>

<% if (typeof reviewStatus !== 'undefined' && reviewStatus && reviewStatus.applicable) { %>
<section class="detail-section">
  <h2>Review status</h2>
  <% if (reviewStatus.needsReview) { %>
    <p><strong>Needs review</strong> — the latest run finished, but its result should be checked.</p>
    <p class="text-muted">Why:</p>
    <ul class="text-muted">
      <% reviewStatus.reasons.forEach(reason => { %>
        <li><%= reason %></li>
      <% }) %>
    </ul>
  <% } else { %>
    <p><strong>No review flag</strong> — no evidence warnings were detected for the latest run.</p>
  <% } %>
</section>
<% } %>

<section class="detail-section">
  <details class="collapsible">
    <summary>Ticket Details</summary>
    <dl class="detail-grid">
      <div>
        <dt>Worker</dt>
        <dd><%= ticket.assignmentTargetType === 'group' ? 'Group' : 'Agent' %> #<%= ticket.assignmentTargetId %></dd>
      </div>
      <div>
        <dt>Work Split</dt>
        <dd><%= ticket.assignmentMode === 'allocated' ? 'Manual folder scopes' : ticket.assignmentMode === 'dynamic' ? 'Automatic folder scopes' : ticket.assignmentMode %></dd>
      </div>
      <div>
        <dt>Created</dt>
        <dd><%= ticket.createdAt ? new Date(ticket.createdAt).toLocaleString() : '-' %></dd>
      </div>
      <div>
        <dt>Updated</dt>
        <dd><%= ticket.updatedAt ? new Date(ticket.updatedAt).toLocaleString() : '-' %></dd>
      </div>
      <div>
        <dt>Changed By</dt>
        <dd><%= ticket.changedBy || '-' %></dd>
      </div>
      <div>
        <dt>Changed At</dt>
        <dd><%= ticket.changedAt ? new Date(ticket.changedAt).toLocaleString() : '-' %></dd>
      </div>
    </dl>
  </details>
</section>

<%
  const activeRuntimeRun = ticketRuns
    .filter(run => ['pending', 'running'].includes(run.status))
    .sort((a, b) => new Date(b.updatedAt || b.startedAt || b.createdAt || 0) - new Date(a.updatedAt || a.startedAt || a.createdAt || 0))[0] || null;
  const latestRuntimeRun = ticketRuns
    .slice()
    .sort((a, b) => new Date(b.updatedAt || b.completedAt || b.startedAt || b.createdAt || 0) - new Date(a.updatedAt || a.completedAt || a.startedAt || a.createdAt || 0))[0] || null;
  const visibleRuntimeRun = activeRuntimeRun || latestRuntimeRun;
  const initialRuntimeStart = visibleRuntimeRun ? (visibleRuntimeRun.startedAt || visibleRuntimeRun.createdAt || '') : '';
  const initialRuntimeComplete = visibleRuntimeRun ? (visibleRuntimeRun.completedAt || '') : '';
  const initialLeaseState = visibleRuntimeRun && visibleRuntimeRun.leaseOwner
    ? (visibleRuntimeRun.leaseOwner + (visibleRuntimeRun.leaseExpiresAt ? ' until ' + visibleRuntimeRun.leaseExpiresAt : ''))
    : '-';
%>
<section class="detail-section" id="ticket-runtime-section" data-ticket-runtime-id="<%= ticket.id %>" data-ticket-runtime-active="<%= activeRuntimeRun ? 'true' : 'false' %>">
  <h2>Runtime</h2>
  <dl class="detail-grid">
    <div>
      <dt>Ticket Status</dt>
      <dd><span id="ticket-live-status" class="status-badge status-<%= ticket.status %>"><%= ticket.status %></span></dd>
    </div>
    <div>
      <dt>Run</dt>
      <dd id="ticket-live-run">
        <% if (visibleRuntimeRun) { %>
          <a href="/runs/<%= visibleRuntimeRun.id %>">Run #<%= visibleRuntimeRun.id %></a>
        <% } else { %>
          -
        <% } %>
      </dd>
    </div>
    <div>
      <dt>Run Status</dt>
      <dd><span id="ticket-live-run-status" class="status-badge <%= visibleRuntimeRun ? 'status-' + visibleRuntimeRun.status : '' %>"><%= visibleRuntimeRun ? visibleRuntimeRun.status : '-' %></span></dd>
    </div>
    <div>
      <dt>Current Message</dt>
      <dd id="ticket-live-message"><%= ticket.currentMessage || '-' %></dd>
    </div>
    <div>
      <dt>Current Step</dt>
      <dd id="ticket-live-step"><%= visibleRuntimeRun && visibleRuntimeRun.currentStepId ? visibleRuntimeRun.currentStepId : '-' %></dd>
    </div>
    <div>
      <dt>Lease State</dt>
      <dd id="ticket-live-lease"><%= initialLeaseState %></dd>
    </div>
    <div>
      <dt>Elapsed Time</dt>
      <dd id="ticket-live-elapsed" data-started-at="<%= initialRuntimeStart %>" data-completed-at="<%= initialRuntimeComplete %>">-</dd>
    </div>
    <div>
      <dt>Latest Outcome</dt>
      <dd id="ticket-live-outcome"><%= visibleRuntimeRun && visibleRuntimeRun.operationalOutcome ? visibleRuntimeRun.operationalOutcome : '-' %></dd>
    </div>
  </dl>
  <% if (typeof runStateInconsistency !== 'undefined' && runStateInconsistency) { %>
    <div class="state-inconsistency-warning state-inconsistency-warning--inline" id="ticket-runtime-state-warning">
      <strong>State Warning</strong>
      <p><%= runStateInconsistency.message %></p>
      <% if (runStateInconsistency.reasons && runStateInconsistency.reasons.length > 0) { %>
        <ul>
          <% runStateInconsistency.reasons.forEach(reason => { %>
            <li><%= reason %></li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  <% } %>
  <%
    const detailIsOpen = ticket.status === 'open';
    const detailHasAssignment = Boolean(ticket.assignmentTargetId);
    let openStateNote = null;
    if (detailIsOpen && !detailHasAssignment) {
      openStateNote = 'Unassigned — not started.';
    } else if (detailIsOpen && detailHasAssignment && ticketRuns.length === 0 && ticket.assignmentTargetType === 'group' && ticket.assignmentMode === 'dynamic') {
      openStateNote = 'No run started yet. Automatic folder scopes need at least one usable top-level workspace folder per group agent.';
    } else if (detailIsOpen && detailHasAssignment && ticketRuns.length === 0) {
      openStateNote = 'No run started yet for the assigned target. Check the agent or group configuration.';
    }
  %>
  <% if (openStateNote) { %>
    <p class="text-muted"><%= openStateNote %></p>
  <% } %>
</section>

<% if (allocationPlan) { %>
<section class="detail-section">
  <details class="collapsible">
    <summary>Work Split Details</summary>
    <dl class="detail-grid">
      <div>
        <dt>Plan</dt>
        <dd>#<%= allocationPlan.id %></dd>
      </div>
      <div>
        <dt>Status</dt>
        <dd><span class="status-badge status-<%= allocationPlan.status %>"><%= allocationPlan.status %></span></dd>
      </div>
      <div>
        <dt>Created</dt>
        <dd><%= allocationPlan.createdAt ? new Date(allocationPlan.createdAt).toLocaleString() : '-' %></dd>
      </div>
      <div>
        <dt>Ticket Opened At</dt>
        <dd><%= allocationPlan.ticketOpenedAt ? new Date(allocationPlan.ticketOpenedAt).toLocaleString() : '-' %></dd>
      </div>
    </dl>
  </details>
</section>

<section class="detail-section">
  <% const workUnitCount = allocationPlan.items ? allocationPlan.items.length : 0; %>
  <h2>Work Units<%= workUnitCount > 0 ? ' (' + workUnitCount + ')' : '' %></h2>
  <p class="text-muted">Group work — one work unit per assigned agent. Completes when all work units complete; fails if any required work unit fails.</p>
  <% if (!allocationPlan.items || allocationPlan.items.length === 0) { %>
    <p class="text-muted">No work units.</p>
  <% } else { %>
    <div class="allocation-items">
      <% allocationPlan.items.forEach(item => { %>
        <%
          const itemRuns = ticketRuns.filter(run =>
            run.allocationPlanId === allocationPlan.id &&
            run.allocationItemId === item.allocationItemId
          );
          const assignedAgent = agents.find(agent => agent.id === item.assignedAgentId);
        %>
        <div class="allocation-item">
          <div class="allocation-item-header">
            <div class="allocation-item-id">Work Unit #<%= item.allocationItemId %></div>
            <div class="allocation-item-status">
              <span class="status-badge status-<%= item.status %>"><%= item.status %></span>
            </div>
          </div>
          <div class="allocation-item-body">
            <div class="allocation-item-row">
              <span class="allocation-item-label">Agent</span>
              <span class="allocation-item-value">
                <% if (assignedAgent) { %>
                  <%= assignedAgent.name %> (Agent #<%= item.assignedAgentId %>)
                <% } else { %>
                  Agent #<%= item.assignedAgentId %>
                <% } %>
              </span>
            </div>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Subtask</span>
              <span class="allocation-item-value"><%= item.allocationSubtask || '-' %></span>
            </div>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Allowed Folders</span>
              <span class="allocation-item-value">
                <% if (item.ownedOutputPaths && item.ownedOutputPaths.length > 0) { %>
                  <code class="owned-path"><%= item.ownedOutputPaths.join(', ') %></code>
                <% } else { %>
                  -
                <% } %>
              </span>
            </div>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Runs</span>
              <span class="allocation-item-value">
                <% if (itemRuns.length === 0) { %>
                  -
                <% } else { %>
                  <span class="run-links">
                    <% itemRuns.forEach((run, idx) => { %>
                      <a href="/runs/<%= run.id %>" class="run-link run-status-<%= run.status %>">Run #<%= run.id %></a><% if (idx < itemRuns.length - 1) { %>, <% } %>
                    <% }) %>
                  </span>
                <% } %>
              </span>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>
<% } %>

<% if (typeof attemptSummary !== 'undefined' && attemptSummary && attemptSummary.attemptCount > 0) { %>
<section class="detail-section">
  <h2>Execution Attempts (<%= attemptSummary.attemptCount %>)</h2>
  <p class="text-muted">Each run on this ticket is one attempt. Measurement only — no retry is triggered and no limit is enforced. "unavailable" means a metric was not observable for that run.</p>
  <table class="tickets-table">
    <thead>
      <tr>
        <th>Attempt</th>
        <th>Run #</th>
        <th>Outcome</th>
        <th>Duration</th>
        <th>Model reqs</th>
        <th>Workspace ops</th>
        <th>Mutating ops</th>
        <th>Verification</th>
        <th>Triage</th>
      </tr>
    </thead>
    <tbody>
      <% attemptSummary.attempts.forEach(a => { %>
        <tr>
          <td><%= a.attemptNumber === null ? '-' : a.attemptNumber %></td>
          <td><a href="/runs/<%= a.runId %>">Run #<%= a.runId %></a></td>
          <td><code><%= a.outcome || 'unavailable' %></code></td>
          <td><%= a.durationMs === null ? 'unavailable' : a.durationMs + 'ms' %></td>
          <td><%= a.modelRequestCount === null ? 'unavailable' : a.modelRequestCount %></td>
          <td><%= a.workspaceOperationCount === null ? 'unavailable' : a.workspaceOperationCount %></td>
          <td><%= a.mutatingWorkspaceOperationCount === null ? 'unavailable' : a.mutatingWorkspaceOperationCount %></td>
          <td><%= a.verificationRequired ? 'required · ' + a.verificationOutcome : 'not required' %></td>
          <td><%= a.triageRequired ? 'required' : 'none' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<% } %>

<section class="detail-section">
  <h2>Runs</h2>
  <% if (ticketRuns.length === 0) { %>
    <p class="text-muted">No runs yet.</p>
  <% } else { %>
    <% const hasScopedRuns = ticketRuns.some(run => run.allocationPlanId || run.allocationItemId); %>
    <table class="tickets-table">
      <thead>
        <tr>
          <th>Run #</th>
          <th>Agent</th>
          <th>Status</th>
          <th>Run Outcome</th>
          <th>Mutations</th>
          <% if (hasScopedRuns) { %>
            <th>Work Split</th>
            <th>Work Unit</th>
          <% } %>
          <th>Created</th>
        </tr>
      </thead>
      <tbody>
        <% ticketRuns.forEach(run => { %>
          <tr>
            <td><a href="/runs/<%= run.id %>">Run #<%= run.id %></a></td>
            <td><%= run.agentName %></td>
            <td>
              <span class="status-badge status-<%= run.status %>"><%= run.status %></span>
            </td>
            <td><code><%= run.operationalOutcome || '-' %></code></td>
            <td>
              <% if (run.partialMutationCount > 0) { %>
                <%= run.partialMutationCount %>
              <% } else { %>
                -
              <% } %>
            </td>
            <% if (hasScopedRuns) { %>
              <td><%= run.allocationPlanId || '-' %></td>
              <td><%= run.allocationItemId || '-' %></td>
            <% } %>
            <td><%= run.createdAt ? new Date(run.createdAt).toLocaleString() : '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<section class="detail-section">
  <h2>Artifacts</h2>
  <% const ticketArtifacts = typeof artifacts === 'undefined' ? [] : artifacts; %>
  <% if (ticketArtifacts.length === 0) { %>
    <p class="text-muted">No artifacts produced yet.</p>
  <% } else { %>
    <table class="tickets-table">
      <thead>
        <tr>
          <th>Type</th>
          <th>Artifact</th>
          <th>Status</th>
          <th>Run</th>
          <th>Source</th>
          <th>Timestamp</th>
        </tr>
      </thead>
      <tbody>
        <% ticketArtifacts.forEach(artifact => { %>
          <tr>
            <td><%= artifact.type %></td>
            <td><code class="owned-path"><%= artifact.artifact %></code></td>
            <td><span class="status-badge"><%= artifact.status %></span></td>
            <td>
              <% if (artifact.runId) { %>
                <a href="/runs/<%= artifact.runId %>">Run #<%= artifact.runId %></a>
              <% } else { %>
                -
              <% } %>
            </td>
            <td><%= artifact.source || '-' %></td>
            <td><%= artifact.timestamp ? new Date(artifact.timestamp).toLocaleString() : '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<% const ticketRecentLogs = typeof recentLogs === 'undefined' ? [] : recentLogs; %>
<% if (ticketRecentLogs.length > 0) { %>
<section class="detail-section">
  <h2>Recent Activity</h2>
  <div class="inline-log-list">
    <% ticketRecentLogs.forEach(log => { %>
      <div class="inline-log-item">
        <span class="inline-log-type"><%= log.displayType || log.type %></span>
        <span class="inline-log-message"><%= log.displayMessage || log.message %></span>
        <% if (log.changedBy || log.requestedBy) { %>
          <span class="audit-meta">Changed by <%= log.changedBy || log.requestedBy %> at <%= log.changedAt || log.timestamp || '-' %></span>
        <% } %>
        <% if (log.runId !== null && log.runId !== undefined) { %>
          <a href="/runs/<%= log.runId %>">Run #<%= log.runId %></a>
        <% } %>
      </div>
    <% }) %>
  </div>
</section>
<% } %>

<% if (operationHistory && operationHistory.length > 0) { %>
<section class="detail-section">
  <h2>Operation History</h2>
  <div class="operation-history">
    <% operationHistory.forEach((record, index) => { %>
      <div class="operation-history-item <%= record.isRecovery ? 'is-recovery' : '' %>">
        <div class="operation-history-header">
          <span class="operation-history-number">#<%= record.id %></span>
          <span class="operation-history-type"><%= record.operation %></span>
          <span class="operation-history-step">run <%= record.runId %> · step <%= record.step %></span>
          <% if (record.isRecovery) { %>
            <span class="badge badge--recovery-action">RECOVERY</span>
          <% } else if (record.recoveryStatus) { %>
            <% if (record.recoveryStatus.status === 'recoverable') { %>
              <span class="badge badge--recovery-recoverable">RECOVERABLE</span>
            <% } else if (record.recoveryStatus.status === 'unrecoverable') { %>
              <span class="badge badge--recovery-unrecoverable">UNRECOVERABLE</span>
            <% } else if (record.recoveryStatus.status === 'recovery_available') { %>
              <span class="badge badge--recovery-available">RECOVERY AVAILABLE</span>
            <% } %>
          <% } %>
          <% if (record.error) { %>
            <span class="badge badge--outcome-error">ERROR</span>
          <% } else if (record.result && record.result.status === 'already_exists_noop') { %>
            <span class="badge badge--outcome-noop">NO-OP</span>
          <% } else { %>
            <span class="badge badge--outcome-success">OK</span>
          <% } %>
        </div>
        <div class="operation-history-body">
          <div class="allocation-item-row">
            <span class="allocation-item-label">Path</span>
            <span class="allocation-item-value"><code class="owned-path"><%= record.args.path %></code></span>
          </div>
          <% if (record.args.nextPath) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Next Path</span>
              <span class="allocation-item-value"><code class="owned-path"><%= record.args.nextPath %></code></span>
            </div>
          <% } %>
          <% if (record.isRecovery && record.recoveredHistoryId) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Recovered</span>
              <span class="allocation-item-value">History #<%= record.recoveredHistoryId %></span>
            </div>
          <% } %>
          <% if (record.preState) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">State diff</span>
              <span class="allocation-item-value">
                <details class="collapsible">
                  <summary>View diff</summary>
                  <div class="diff-container">
                    <div class="diff-panel">
                      <div class="diff-panel-label">Before</div>
                      <pre class="code-block code-block--diff"><%= JSON.stringify(record.preState, null, 2) %></pre>
                    </div>
                    <div class="diff-panel">
                      <div class="diff-panel-label">After</div>
                      <pre class="code-block code-block--diff"><%= JSON.stringify(record.postState, null, 2) %></pre>
                    </div>
                  </div>
                </details>
              </span>
            </div>
          <% } else if (record.postState) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Post-State</span>
              <span class="allocation-item-value">
                <details class="collapsible">
                  <summary>View Post-State</summary>
                  <pre class="code-block"><%= JSON.stringify(record.postState, null, 2) %></pre>
                </details>
              </span>
            </div>
          <% } %>
          <% if (record.error) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Error</span>
              <span class="allocation-item-value"><span class="failure-reason"><%= record.error %></span></span>
            </div>
          <% } %>
          <% if (canUpdateTickets && !record.isRecovery && record.recoveryStatus && record.recoveryStatus.status === 'recoverable') { %>
            <div class="recovery-controls">
              <button type="button" class="btn-small btn-secondary" data-preview-recovery-id="<%= record.id %>">Preview Recovery</button>
            </div>
            <div class="recovery-preview-panel" id="recovery-preview-<%= record.id %>" style="display: none;"></div>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</section>
<% } %>

<script>
(() => {
  const section = document.getElementById('ticket-runtime-section');
  if (!section) return;

  const ticketId = section.dataset.ticketRuntimeId;
  const activeStatuses = new Set(['pending', 'running']);
  const terminalStatuses = new Set(['completed', 'failed', 'interrupted']);
  let hadActiveRun = section.dataset.ticketRuntimeActive === 'true';
  let currentRunStatus = document.getElementById('ticket-live-run-status')?.textContent || '';
  let polling = null;
  let terminalReloaded = false;

  const ticketStatusEl = document.getElementById('ticket-live-status');
  const runEl = document.getElementById('ticket-live-run');
  const runStatusEl = document.getElementById('ticket-live-run-status');
  const messageEl = document.getElementById('ticket-live-message');
  const stepEl = document.getElementById('ticket-live-step');
  const leaseEl = document.getElementById('ticket-live-lease');
  const elapsedEl = document.getElementById('ticket-live-elapsed');
  const outcomeEl = document.getElementById('ticket-live-outcome');

  function formatElapsed(ms) {
    const seconds = Math.max(0, Math.floor(ms / 1000));
    if (seconds < 60) return seconds + ' second' + (seconds === 1 ? '' : 's');
    const minutes = Math.floor(seconds / 60);
    const rest = seconds % 60;
    if (rest === 0) return minutes + ' minute' + (minutes === 1 ? '' : 's');
    return minutes + ' minute' + (minutes === 1 ? '' : 's') + ' ' + rest + ' second' + (rest === 1 ? '' : 's');
  }

  function setText(el, value) {
    if (!el) return;
    el.textContent = value || '-';
  }

  function updateBadge(el, status) {
    if (!el) return;
    el.className = 'status-badge' + (status ? ' status-' + status : '');
    el.textContent = status || '-';
  }

  function updateRunLink(run) {
    if (!runEl) return;
    if (!run || !run.id) {
      runEl.textContent = '-';
      return;
    }
    runEl.innerHTML = '';
    const link = document.createElement('a');
    link.href = '/runs/' + encodeURIComponent(run.id);
    link.textContent = 'Run #' + run.id;
    runEl.appendChild(link);
  }

  function formatStep(step, run) {
    if (step && step.stepId) {
      const detail = [step.action, step.status].filter(Boolean).join(' ');
      return detail ? step.stepId + ' (' + detail + ')' : step.stepId;
    }
    return run && run.currentStepId ? run.currentStepId : '-';
  }

  function formatLease(lease) {
    if (!lease || !lease.leaseOwner) return '-';
    const parts = [lease.leaseOwner];
    if (lease.expired) parts.push('expired');
    else if (lease.heldByCurrentProcess) parts.push('held');
    if (lease.leaseExpiresAt) parts.push('until ' + lease.leaseExpiresAt);
    return parts.join(' · ');
  }

  function updateElapsed(startedAt, completedAt, status) {
    if (!elapsedEl) return;
    const startText = startedAt || elapsedEl.dataset.startedAt || '';
    const completeText = completedAt || elapsedEl.dataset.completedAt || '';
    const startMs = Date.parse(startText);
    if (Number.isNaN(startMs)) {
      elapsedEl.textContent = '-';
      return;
    }

    elapsedEl.dataset.startedAt = startText;
    if (completeText) {
      const completeMs = Date.parse(completeText);
      if (!Number.isNaN(completeMs)) {
        elapsedEl.dataset.completedAt = completeText;
        elapsedEl.textContent = formatElapsed(completeMs - startMs);
        return;
      }
    }

    if (activeStatuses.has(status)) {
      elapsedEl.textContent = (status === 'pending' ? 'queued for ' : 'running for ') + formatElapsed(Date.now() - startMs);
    } else {
      elapsedEl.textContent = formatElapsed(Date.now() - startMs);
    }
  }

  function applyRuntimeState(state) {
    const ticket = state.ticket || {};
    const run = state.currentRun || state.latestRun || null;

    updateBadge(ticketStatusEl, ticket.status);
    updateRunLink(run);
    updateBadge(runStatusEl, run && run.status);
    currentRunStatus = run && run.status ? run.status : '';
    setText(messageEl, state.currentMessage || (run && run.currentMessage));
    setText(stepEl, formatStep(state.currentStep, run));
    setText(leaseEl, formatLease(state.leaseState || (run && run.lease)));
    setText(outcomeEl, state.outcomeLabel || (run && run.outcomeLabel) || state.outcome);
    updateElapsed(run && (run.startedAt || run.createdAt), run && run.completedAt, run && run.status);

    const activeRun = state.currentRun && activeStatuses.has(state.currentRun.status);
    if (activeRun) {
      hadActiveRun = true;
      return;
    }

    if (polling) {
      window.clearInterval(polling);
      polling = null;
    }
    if (hadActiveRun && run && terminalStatuses.has(run.status) && !terminalReloaded) {
      terminalReloaded = true;
      window.location.reload();
    }
  }

  async function refreshTicketRuntime() {
    if (!hadActiveRun && !activeStatuses.has(currentRunStatus)) return;
    const response = await fetch('/api/tickets/' + encodeURIComponent(ticketId) + '/runtime', {
      headers: { Accept: 'application/json' }
    });
    if (!response.ok) return;
    applyRuntimeState(await response.json());
  }

  updateElapsed(elapsedEl && elapsedEl.dataset.startedAt, elapsedEl && elapsedEl.dataset.completedAt, currentRunStatus);
  if (hadActiveRun || activeStatuses.has(currentRunStatus)) {
    polling = window.setInterval(() => {
      updateElapsed(elapsedEl && elapsedEl.dataset.startedAt, elapsedEl && elapsedEl.dataset.completedAt, currentRunStatus);
      refreshTicketRuntime().catch(() => {});
    }, 1000);
    refreshTicketRuntime().catch(() => {});
  }
})();
</script>

<% if (canUpdateTickets) { %>
<script>
document.addEventListener('click', event => {
  const rerunButton = event.target.closest('[data-rerun-ticket-id]');
  if (rerunButton) {
    rerunButton.disabled = true;
    fetch('/api/tickets/' + encodeURIComponent(rerunButton.dataset.rerunTicketId) + '/rerun', {
      method: 'POST',
      headers: { Accept: 'application/json' }
    }).then(response => {
      if (!response.ok) {
        return response.json().catch(() => ({})).then(data => {
          window.alert(data.error || 'Ticket rerun failed');
          window.location.reload();
        });
      }
      window.location.reload();
    });
    return;
  }

  const previewButton = event.target.closest('[data-preview-recovery-id]');
  if (previewButton) {
    previewButton.disabled = true;
    const historyId = previewButton.dataset.previewRecoveryId;
    const panel = document.getElementById('recovery-preview-' + historyId);
    fetch('/api/operations/' + encodeURIComponent(historyId) + '/recovery-preview')
      .then(response => response.json())
      .then(data => {
        if (data.error) {
          panel.className = 'recovery-preview-panel recovery-blocked';
          panel.innerHTML = '<div class="recovery-reason">' + escapeHtml(data.error) + '</div>';
        } else if (data.preview) {
          const p = data.preview;
          panel.className = p.canProceed ? 'recovery-preview-panel' : 'recovery-preview-panel recovery-blocked';
          let html = '<div class="recovery-action-text">Proposed: ' + escapeHtml(p.proposedAction.operation) + '</div>';
          if (p.proposedAction.args.path) html += '<div class="recovery-reason">Path: <code class="owned-path">' + escapeHtml(p.proposedAction.args.path) + '</code></div>';
          if (p.proposedAction.args.nextPath) html += '<div class="recovery-reason">Next Path: <code class="owned-path">' + escapeHtml(p.proposedAction.args.nextPath) + '</code></div>';
          if (p.validation && !p.validation.valid) html += '<div class="recovery-reason" style="color:#991b1b;margin-top:6px;">Blocked: ' + escapeHtml(p.validation.reason) + '</div>';
          if (p.canProceed) {
            html += '<div class="recovery-controls"><button type="button" class="btn-small btn-danger" data-confirm-recovery-id="' + historyId + '">Confirm Recovery</button></div>';
          }
          panel.innerHTML = html;
        }
        panel.style.display = 'block';
        previewButton.disabled = false;
      })
      .catch(err => {
        panel.className = 'recovery-preview-panel recovery-blocked';
        panel.innerHTML = '<div class="recovery-reason">Preview failed: ' + escapeHtml(err.message) + '</div>';
        panel.style.display = 'block';
        previewButton.disabled = false;
      });
    return;
  }

  const confirmButton = event.target.closest('[data-confirm-recovery-id]');
  if (confirmButton) {
    confirmButton.disabled = true;
    const historyId = confirmButton.dataset.confirmRecoveryId;
    fetch('/api/operations/' + encodeURIComponent(historyId) + '/recover', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({ confirmed: true })
    })
      .then(response => response.json())
      .then(data => {
        if (data.error) {
          alert('Recovery failed: ' + data.error);
          confirmButton.disabled = false;
        } else {
          window.location.reload();
        }
      })
      .catch(err => {
        alert('Recovery failed: ' + err.message);
        confirmButton.disabled = false;
      });
    return;
  }
});

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}
</script>
<% } %>
