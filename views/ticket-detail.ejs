<%
  const hasUnresolvedTriage = ticket.triage && ticket.triage.required === true && !ticket.triage.resolvedAt;
  const activeRuntimeRun = ticketRuns
    .filter(run => ['pending', 'running'].includes(run.status))
    .sort((a, b) => new Date(b.updatedAt || b.startedAt || b.createdAt || 0) - new Date(a.updatedAt || a.startedAt || a.createdAt || 0))[0] || null;
  const latestRuntimeRun = ticketRuns
    .slice()
    .sort((a, b) => new Date(b.updatedAt || b.completedAt || b.startedAt || b.createdAt || 0) - new Date(a.updatedAt || a.completedAt || a.startedAt || a.createdAt || 0))[0] || null;
  const visibleRuntimeRun = activeRuntimeRun || latestRuntimeRun;
  const initialRuntimeStart = visibleRuntimeRun ? (visibleRuntimeRun.startedAt || visibleRuntimeRun.createdAt || '') : '';
  const initialRuntimeComplete = visibleRuntimeRun ? (visibleRuntimeRun.completedAt || '') : '';
  const initialLeaseState = visibleRuntimeRun && visibleRuntimeRun.leaseOwner
    ? (visibleRuntimeRun.leaseOwner + (visibleRuntimeRun.leaseExpiresAt ? ' until ' + visibleRuntimeRun.leaseExpiresAt : ''))
    : '-';
  const detailIsOpen = ticket.status === 'open';
  const detailHasAssignment = Boolean(ticket.assignmentTargetId);
  const isBlockedSpawnedChild = ticket.status === 'blocked' && ticket.parentTicketId != null;
  let openStateNote = null;
  if (detailIsOpen && !detailHasAssignment) {
    openStateNote = 'Unassigned — not started.';
  } else if (detailIsOpen && detailHasAssignment && ticketRuns.length === 0 && ticket.assignmentTargetType === 'group' && ticket.assignmentMode === 'dynamic') {
    openStateNote = 'No run started yet. Automatic folder scopes need at least one usable top-level workspace folder per group agent.';
  } else if (detailIsOpen && detailHasAssignment && ticketRuns.length === 0) {
    openStateNote = 'No run started yet for the assigned target. Check the agent or group configuration.';
  }
%>
<section class="zone">
  <div class="zone-head"><span class="zone-eyebrow">At a glance</span><span class="zone-q">What is this, and what's it doing right now?</span></div>
  <div class="hero" id="ticket-runtime-section" data-ticket-runtime-id="<%= ticket.id %>" data-ticket-runtime-active="<%= activeRuntimeRun ? 'true' : 'false' %>">
    <div class="hero-top">
      <div>
        <h1 style="margin:0;font-size:26px;">Ticket #<%= ticket.id %>
          <span id="ticket-live-status" class="status-badge status-<%= ticket.status %>"><%= ticket.status %></span>
        </h1>
        <p class="text-muted" style="margin:8px 0 0;max-width:62ch;"><%= ticket.objective %></p>
      </div>
      <div class="hero-actions">
        <a class="btn-secondary" href="/tickets">Back to Tickets</a>
        <a class="btn-secondary" href="/logs?ticketId=<%= ticket.id %>">Ticket Logs</a>
      <% if (canUpdateTickets && !hasUnresolvedTriage && ticket.status !== 'open' && !isBlockedSpawnedChild) { %>
          <button type="button" class="btn-secondary" data-rerun-ticket-id="<%= ticket.id %>"><%= ticket.status === 'failed' ? 'Retry' : 'Rerun' %></button>
        <% } %>
        <% if (canUpdateTickets) { %>
          <button type="button" class="btn-secondary" data-simulate-plan-id="<%= ticket.id %>" data-simulate-mode="gate">Test gate</button>
          <button type="button" class="btn-secondary" data-simulate-plan-id="<%= ticket.id %>" data-simulate-mode="model">Test agent plan (simulation)</button>
        <% } %>
      </div>
    </div>
    <dl class="live">
      <div><dt>Run</dt><dd id="ticket-live-run"><% if (visibleRuntimeRun) { %><a href="/runs/<%= visibleRuntimeRun.id %>">Run #<%= visibleRuntimeRun.id %></a><% } else { %>-<% } %></dd></div>
      <div><dt>Run Status</dt><dd><span id="ticket-live-run-status" class="status-badge <%= visibleRuntimeRun ? 'status-' + visibleRuntimeRun.status : '' %>"><%= visibleRuntimeRun ? visibleRuntimeRun.status : '-' %></span></dd></div>
      <div><dt>Assigned to</dt><dd><%= executionState ? executionState.assignmentTargetLabel : '-' %></dd></div>
      <div><dt>Latest Outcome</dt><dd id="ticket-live-outcome"><%= (executionState && executionState.lastOutcomeLabel) ? executionState.lastOutcomeLabel : (visibleRuntimeRun && visibleRuntimeRun.operationalOutcome ? visibleRuntimeRun.operationalOutcome : '-') %></dd></div>
      <div><dt>Current Step</dt><dd id="ticket-live-step"><%= visibleRuntimeRun && visibleRuntimeRun.currentStepId ? visibleRuntimeRun.currentStepId : '-' %></dd></div>
      <div><dt>Elapsed Time</dt><dd id="ticket-live-elapsed" data-started-at="<%= initialRuntimeStart %>" data-completed-at="<%= initialRuntimeComplete %>">-</dd></div>
      <div><dt>Lease State</dt><dd id="ticket-live-lease"><%= initialLeaseState %></dd></div>
      <div style="grid-column:1/-1;"><dt>Current Message</dt><dd id="ticket-live-message"><%= ticket.currentMessage || '-' %></dd></div>
    </dl>
    <% if (openStateNote) { %><p class="text-muted"><%= openStateNote %></p><% } %>
  </div>
  <% if (canUpdateTickets && hasUnresolvedTriage) { %>
  <p class="form-hint">Rerun disabled: unresolved ticket-level triage must be resolved or the ticket objective must be changed first.</p>
<% } else if (canUpdateTickets && isBlockedSpawnedChild) { %>
  <p class="form-hint">Rerun disabled: this child ticket was created by executeTicketPlan and is blocked by default. Change status to Open to enable execution.</p>
<% } else if (canUpdateTickets && ticket.status !== 'open') { %>
  <%
    const isGroupTicket = typeof executionState !== 'undefined' && executionState && executionState.isGroup;
    const rerunWord = ticket.status === 'failed' ? 'Retry' : 'Rerun';
  %>
  <p class="form-hint"><%= rerunWord %> interrupts any active run, reopens this ticket, and starts a new run from the current objective and assignment.<%= isGroupTicket ? ' For this group ticket it regenerates the work-unit allocation across group members.' : '' %></p>
<% } %>
<% if (canUpdateTickets) { %>
<p class="form-hint">Simulation tests the agent plan without creating a run or mutating the workspace. "Test agent plan" calls the model; "Test gate" returns the objective clarification verdict only.</p>
<div id="simulation-result" class="simulation-result"></div>
<% } %>
</section>

<% if (typeof parentTicket !== 'undefined' && parentTicket) { %>
<section class="detail-section">
  <h2>Parent Ticket</h2>
  <p class="text-muted">This ticket was spawned from a parent ticket/run. Parent and child statuses are independent.</p>
  <dl class="detail-grid">
    <div><dt>Ticket</dt><dd><a href="/tickets/<%= parentTicket.id %>">Ticket #<%= parentTicket.id %></a></dd></div>
    <div><dt>Objective</dt><dd><%= parentTicket.objective %></dd></div>
    <div><dt>Status</dt><dd><span class="status-badge status-<%= parentTicket.status %>"><%= parentTicket.status %></span></dd></div>
    <% if (ticket.parentRunId) { %><div><dt>Parent Run</dt><dd><a href="/runs/<%= ticket.parentRunId %>">Run #<%= ticket.parentRunId %></a></dd></div><% } %>
    <% if (ticket.spawnPlanId) { %><div><dt>Spawn Plan</dt><dd><code><%= ticket.spawnPlanId %></code></dd></div><% } %>
  </dl>
</section>
<% } %>

<%
  const ticketFeasibility = ticket.feasibility || null;
  const ticketBlockedReason = ticket.blockedReason || (ticketFeasibility && ticketFeasibility.reason) || null;
  const hasAttention = Boolean(ticketBlockedReason || ticketFeasibility)
    || (ticket.triage && (ticket.triage.required || ticket.triage.resolvedAt))
    || (typeof latestTriage !== 'undefined' && latestTriage && (latestTriage.required || latestTriage.resolvedAt))
    || (typeof reviewStatus !== 'undefined' && reviewStatus && reviewStatus.applicable && reviewStatus.needsReview)
    || (typeof runStateInconsistency !== 'undefined' && runStateInconsistency);
%>
<% if (hasAttention) { %>
<div class="zone-head" data-attn-zone><span class="zone-eyebrow">Needs your attention</span><span class="zone-q">Does it need me, and what do I decide?</span></div>

<% if (typeof runStateInconsistency !== 'undefined' && runStateInconsistency) { %>
  <div class="attn critical" id="ticket-runtime-state-warning">
    <h3><span class="sev">Critical</span> State Warning</h3>
    <p><%= runStateInconsistency.message %></p>
    <% if (runStateInconsistency.reasons && runStateInconsistency.reasons.length > 0) { %><ul><% runStateInconsistency.reasons.forEach(reason => { %><li><%= reason %></li><% }) %></ul><% } %>
  </div>
<% } %>

<% if (ticketBlockedReason || ticketFeasibility) { %>
<div class="attn critical failure-summary">
  <h3><span class="sev">Critical</span> Why this ticket is blocked</h3>
  <% if (ticketBlockedReason) { %>
    <p class="failure-reason"><%= ticketBlockedReason %></p>
  <% } %>
  <% if (ticketFeasibility) { %>
    <dl class="detail-grid">
      <div>
        <dt>Required folders</dt>
        <dd>
          <% if (ticketFeasibility.requiredWritableRoots && ticketFeasibility.requiredWritableRoots.length > 0) { %>
            <% ticketFeasibility.requiredWritableRoots.forEach(root => { %>
              <code class="owned-path"><%= root %></code>
            <% }) %>
          <% } else { %>
            -
          <% } %>
        </dd>
      </div>
      <div>
        <dt>Granted folders</dt>
        <dd>
          <% if (ticketFeasibility.grantedWritableRoots && ticketFeasibility.grantedWritableRoots.length > 0) { %>
            <% ticketFeasibility.grantedWritableRoots.forEach(root => { %>
              <code class="owned-path"><%= root %></code>
            <% }) %>
          <% } else { %>
            -
          <% } %>
        </dd>
      </div>
      <% if (ticketFeasibility.missingAuthorityGrants && ticketFeasibility.missingAuthorityGrants.length > 0) { %>
        <div>
          <dt>Missing grants</dt>
          <dd>
            <% ticketFeasibility.missingAuthorityGrants.forEach(root => { %>
              <code class="owned-path"><%= root %></code>
            <% }) %>
          </dd>
        </div>
      <% } %>
    </dl>
    <details class="collapsible">
      <summary>Technical details</summary>
      <div class="collapsible__content">
        <dl class="detail-grid">
          <div>
            <dt>Code</dt>
            <dd><code><%= ticketFeasibility.code || '-' %></code></dd>
          </div>
          <div>
            <dt>Kind</dt>
            <dd><code><%= ticketFeasibility.kind || '-' %></code></dd>
          </div>
        </dl>
      </div>
    </details>
  <% } %>
</div>
<% } %>

<% if (ticket.triage && ticket.triage.required) { %>
  <div class="attn critical">
  <h3><span class="sev">Critical</span> Ticket-Level Triage</h3>
  <dl class="detail-grid">
    <div><dt>Reason</dt><dd><code><%= ticket.triage.reasonCode %></code></dd></div>
    <div><dt>Required decision</dt><dd><code><%= ticket.triage.requiredDecision %></code></dd></div>
    <div><dt>Summary</dt><dd><%= ticket.triage.summary %></dd></div>
    <div><dt>Allowed next actions</dt><dd><%= ticket.triage.allowedActions.length > 0 ? ticket.triage.allowedActions.join(', ') : 'none' %></dd></div>
    <div><dt>Prohibited actions</dt><dd><%= ticket.triage.prohibitedActions.length > 0 ? ticket.triage.prohibitedActions.join(', ') : 'none' %></dd></div>
  </dl>
  <% if (ticket.triage.evidenceRefs.length > 0) { %>
    <p class="text-muted">Evidence:
      <% ticket.triage.evidenceRefs.forEach(ref => { %><code class="owned-path"><%= ref %></code> <% }) %>
    </p>
  <% } %>
  <% if (typeof canUpdateTickets !== 'undefined' && canUpdateTickets) { %>
  <form class="triage-resolve" data-resolve-url="/api/tickets/<%= ticket.id %>/triage/resolve">
    <p class="text-muted">Resolving records an operator acknowledgement only — it does not rerun, complete, or change status.</p>
    <input type="text" class="triage-resolution-input" placeholder="Resolution note (required)">
    <button type="button" class="btn-small">Resolve triage</button>
    <span class="triage-resolve-msg text-muted"></span>
  </form>
  <% } %>
</div>
<% } else if (ticket.triage && ticket.triage.resolvedAt) { %>
<div class="attn">
  <h3><span class="sev">Resolved</span> Ticket-Level Triage (resolved)</h3>
  <dl class="detail-grid">
    <div><dt>Reason</dt><dd><code><%= ticket.triage.reasonCode %></code></dd></div>
    <div><dt>Required decision</dt><dd><code><%= ticket.triage.requiredDecision %></code></dd></div>
    <div><dt>Summary</dt><dd><%= ticket.triage.summary %></dd></div>
    <div><dt>Resolved by</dt><dd><%= ticket.triage.resolvedBy || '-' %></dd></div>
    <div><dt>Resolved at</dt><dd><%= ticket.triage.resolvedAt || '-' %></dd></div>
    <div><dt>Resolution</dt><dd><%= ticket.triage.resolution || '-' %></dd></div>
  </dl>
</div>
<% } %>

<% if (typeof latestTriage !== 'undefined' && latestTriage && latestTriage.required) { %>
<div class="attn critical">
  <h3><span class="sev">Critical</span> Latest Run Triage</h3>
  <dl class="detail-grid">
    <div><dt>Reason</dt><dd><code><%= latestTriage.reasonCode %></code></dd></div>
    <div><dt>Required decision</dt><dd><code><%= latestTriage.requiredDecision %></code></dd></div>
    <div><dt>Summary</dt><dd><%= latestTriage.summary %></dd></div>
    <div><dt>Allowed next actions</dt><dd><%= latestTriage.allowedActions.length > 0 ? latestTriage.allowedActions.join(', ') : 'none' %></dd></div>
    <div><dt>Prohibited actions</dt><dd><%= latestTriage.prohibitedActions.length > 0 ? latestTriage.prohibitedActions.join(', ') : 'none' %></dd></div>
  </dl>
  <% if (latestTriage.evidenceRefs.length > 0) { %>
    <p class="text-muted">Evidence:
      <% latestTriage.evidenceRefs.forEach(ref => { %><code class="owned-path"><%= ref %></code> <% }) %>
    </p>
  <% } %>
  <% if (typeof canUpdateTickets !== 'undefined' && canUpdateTickets && typeof latestRuntimeRunId !== 'undefined' && latestRuntimeRunId) { %>
  <form class="triage-resolve" data-resolve-url="/api/runs/<%= latestRuntimeRunId %>/triage/resolve">
    <p class="text-muted">Resolving records an operator acknowledgement only — it does not rerun, complete, or change status.</p>
    <input type="text" class="triage-resolution-input" placeholder="Resolution note (required)">
    <button type="button" class="btn-small">Resolve triage</button>
    <span class="triage-resolve-msg text-muted"></span>
  </form>
  <% } %>
</div>
<% } else if (typeof latestTriage !== 'undefined' && latestTriage && latestTriage.resolvedAt) { %>
<div class="attn">
  <h3><span class="sev">Resolved</span> Latest Run Triage (resolved)</h3>
  <dl class="detail-grid">
    <div><dt>Reason</dt><dd><code><%= latestTriage.reasonCode %></code></dd></div>
    <div><dt>Required decision</dt><dd><code><%= latestTriage.requiredDecision %></code></dd></div>
    <div><dt>Summary</dt><dd><%= latestTriage.summary %></dd></div>
    <div><dt>Resolved by</dt><dd><%= latestTriage.resolvedBy || '-' %></dd></div>
    <div><dt>Resolved at</dt><dd><%= latestTriage.resolvedAt || '-' %></dd></div>
    <div><dt>Resolution</dt><dd><%= latestTriage.resolution || '-' %></dd></div>
  </dl>
</div>
<% } %>

<% if (typeof reviewStatus !== 'undefined' && reviewStatus && reviewStatus.applicable && reviewStatus.needsReview) { %>
<div class="attn">
  <h3><span class="sev"><%= reviewStatus.needsReview ? 'Needs review' : 'Reviewed' %></span> Review status</h3>
  <% if (reviewStatus.needsReview) { %>
    <p><strong>Needs review</strong> — the latest run finished, but its result should be checked.</p>
    <p class="text-muted">Why:</p>
    <ul class="text-muted">
      <% reviewStatus.reasons.forEach(reason => { %>
        <li><%= reason %></li>
      <% }) %>
    </ul>
  <% } else { %>
    <p><strong>No review flag</strong> — no evidence warnings were detected for the latest run.</p>
  <% } %>
</div>
<% } %>
<% } %>

<script>
  document.querySelectorAll('.triage-resolve').forEach(function (form) {
    var url = form.getAttribute('data-resolve-url');
    var input = form.querySelector('.triage-resolution-input');
    var msg = form.querySelector('.triage-resolve-msg');
    form.querySelector('button').addEventListener('click', async function () {
      msg.textContent = '';
      var value = input.value.trim();
      if (!value) { msg.textContent = 'Resolution note is required.'; return; }
      try {
        var res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ resolution: value }) });
        var payload = await res.json().catch(function () { return null; });
        if (!res.ok) { msg.textContent = (payload && payload.error) ? payload.error : 'Resolve rejected.'; return; }
        window.location.reload();
      } catch (e) { msg.textContent = 'Resolve failed.'; }
    });
  });
</script>

<div class="zone-head"><span class="zone-eyebrow">How it's set up</span><span class="zone-q">How is this ticket configured?</span></div>
<details class="disclosure" open>
  <summary>Acceptance Criteria <span class="sub"><%= ticket.acceptanceCriteria ? 'Declared' : 'None declared' %></span></summary>
  <div class="body">
    <% if (ticket.acceptanceCriteria) { %>
      <p style="white-space:pre-wrap;"><%= ticket.acceptanceCriteria %></p>
    <% } else { %>
      <p class="text-muted">None declared.</p>
    <% } %>
    <p class="text-muted">Stored for review; not automatically verified. Run completed &ne; objective verified.</p>
  </div>
</details>

<% if (typeof childTickets !== 'undefined' && childTickets && childTickets.length > 0) { %>
<details class="disclosure" open>
  <summary>Child Tickets <span class="sub"><%= childTickets.length %> spawned</span></summary>
  <div class="body">
    <p class="text-muted">Read-only lineage from this ticket. Child outcomes do not automatically complete or fail the parent ticket.</p>
    <table class="tickets-table">
      <thead>
        <tr>
          <th>Ticket</th>
          <th>Objective</th>
          <th>Status</th>
          <th>Blocked Reason</th>
          <th>Latest Run</th>
        </tr>
      </thead>
      <tbody>
        <% childTickets.forEach(child => { %>
          <tr>
            <td><a href="/tickets/<%= child.id %>">Ticket #<%= child.id %></a></td>
            <td><%= child.objective %></td>
            <td><span class="status-badge status-<%= child.status %>"><%= child.status %></span></td>
            <td><%= child.blockedReason || '-' %></td>
            <td>
              <% if (child.latestRunId) { %>
                <a href="/runs/<%= child.latestRunId %>"><span class="status-badge status-<%= child.latestRunStatus %>"><%= child.latestRunStatus %></span></a>
              <% } else { %>
                <span class="text-muted">-</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</details>
<% } %>

<details class="disclosure" open>
  <summary>Assignment &amp; work split <span class="sub"><%= ticket.assignmentTargetType === 'group' ? 'Group' : 'Agent' %> #<%= ticket.assignmentTargetId %> · <%= ticket.assignmentMode === 'allocated' ? 'Manual folder scopes' : ticket.assignmentMode === 'dynamic' ? 'Automatic folder scopes' : ticket.assignmentMode %></span></summary>
  <div class="body">
    <dl class="detail-grid">
      <div><dt>Worker</dt><dd><%= ticket.assignmentTargetType === 'group' ? 'Group' : 'Agent' %> #<%= ticket.assignmentTargetId %></dd></div>
      <div><dt>Work Split</dt><dd><%= ticket.assignmentMode === 'allocated' ? 'Manual folder scopes' : ticket.assignmentMode === 'dynamic' ? 'Automatic folder scopes' : ticket.assignmentMode %></dd></div>
      <% if (typeof executionState !== 'undefined' && executionState) { %>
      <% if (ticket.source && ticket.source.type === 'process_template') { %>
        <div>
          <dt>Created from template</dt>
          <dd>
            <a href="/process-templates"><%= ticket.source.templateName %></a><% if (ticket.source.templateVersion) { %> v<%= ticket.source.templateVersion %><% } %>
            (#<%= ticket.source.templateId %>, <%= ticket.source.triggerType === 'schedule' ? 'scheduled' : 'manual' %> trigger by <%= ticket.source.triggeredBy %>)
          </dd>
        </div>
      <% } %>
      <% if (ticket.workContextId && ticket.workContextSnapshot) { %>
        <div>
          <dt>Work Context</dt>
          <dd>
            <a href="/tickets?workContextId=<%= ticket.workContextId %>"><%= ticket.workContextSnapshot.name %></a>
            (#<%= ticket.workContextId %><% if (ticket.workContextSnapshot.status && ticket.workContextSnapshot.status !== 'active') { %>, <%= ticket.workContextSnapshot.status %><% } %>)
          </dd>
        </div>
      <% } %>
      <% if (executionState.isGroup && executionState.assignmentMode) { %>
        <div>
          <dt>Assignment mode</dt>
          <dd><%= executionState.assignmentModeLabel %></dd>
        </div>
      <% } %>
      <div>
        <dt>Auto-run behavior</dt>
        <dd><%= executionState.autoRun.label %></dd>
      </div>
      <% } %>
    </dl>
    <% if (typeof executionState !== 'undefined' && executionState) { %>
    <% if (executionState.group) { %>
      <p class="text-muted">Group fan-out: <%= executionState.group.memberCount %> member<%= executionState.group.memberCount === 1 ? '' : 's' %> ·
        work units: <%= executionState.group.workUnitsTotal %> generated, <%= executionState.group.workUnitsCompleted %> completed<%= executionState.group.workUnitsFailed > 0 ? ', ' + executionState.group.workUnitsFailed + ' failed' : '' %>.
        Completes when all work units complete; fails if any required work unit fails.</p>
    <% } %>
    <% if (ticket.assignmentTargetType === 'group' && ticket.assignmentMode === 'dynamic') { %>
      <%
        const dynamicScopeMap = ticket.ownedOutputPaths && typeof ticket.ownedOutputPaths === 'object' && !Array.isArray(ticket.ownedOutputPaths)
          ? ticket.ownedOutputPaths : null;
      %>
      <p class="text-muted">Automatic folder scopes: group agents are assigned to existing top-level workspace folders in deterministic order (folders by name, agents by id). The ticket runs only when there are at least as many usable folders as group agents.</p>
      <% if (dynamicScopeMap && Object.keys(dynamicScopeMap).length > 0) { %>
        <ul class="text-muted">
          <% Object.keys(dynamicScopeMap).forEach(agentId => { %>
            <% const scopedAgent = agents.find(a => String(a.id) === String(agentId)); %>
            <li><%= scopedAgent ? scopedAgent.name : 'Agent #' + agentId %> → <code class="owned-path"><%= dynamicScopeMap[agentId] %></code></li>
          <% }) %>
        </ul>
      <% } %>
    <% } %>
    <% } %>
    <% if (allocationPlan) { %>
    <dl class="detail-grid">
      <div>
        <dt>Plan</dt>
        <dd>#<%= allocationPlan.id %></dd>
      </div>
      <div>
        <dt>Status</dt>
        <dd><span class="status-badge status-<%= allocationPlan.status %>"><%= allocationPlan.status %></span></dd>
      </div>
      <div>
        <dt>Created</dt>
        <dd><%= allocationPlan.createdAt ? new Date(allocationPlan.createdAt).toLocaleString() : '-' %></dd>
      </div>
      <div>
        <dt>Ticket Opened At</dt>
        <dd><%= allocationPlan.ticketOpenedAt ? new Date(allocationPlan.ticketOpenedAt).toLocaleString() : '-' %></dd>
      </div>
    </dl>
    <% const workUnitCount = allocationPlan.items ? allocationPlan.items.length : 0; %>
    <h3>Work Units<%= workUnitCount > 0 ? ' (' + workUnitCount + ')' : '' %></h3>
    <p class="text-muted">Group work — one work unit per assigned agent. Completes when all work units complete; fails if any required work unit fails.</p>
    <% if (!allocationPlan.items || allocationPlan.items.length === 0) { %>
      <p class="text-muted">No work units.</p>
    <% } else { %>
      <div class="allocation-items">
        <% allocationPlan.items.forEach(item => { %>
          <%
            const itemRuns = ticketRuns.filter(run =>
              run.allocationPlanId === allocationPlan.id &&
              run.allocationItemId === item.allocationItemId
            );
            const assignedAgent = agents.find(agent => agent.id === item.assignedAgentId);
          %>
          <div class="allocation-item">
            <div class="allocation-item-header">
              <div class="allocation-item-id">Work Unit #<%= item.allocationItemId %></div>
              <div class="allocation-item-status">
                <span class="status-badge status-<%= item.status %>"><%= item.status %></span>
              </div>
            </div>
            <div class="allocation-item-body">
              <div class="allocation-item-row">
                <span class="allocation-item-label">Agent</span>
                <span class="allocation-item-value">
                  <% if (assignedAgent) { %>
                    <%= assignedAgent.name %> (Agent #<%= item.assignedAgentId %>)
                  <% } else { %>
                    Agent #<%= item.assignedAgentId %>
                  <% } %>
                </span>
              </div>
              <div class="allocation-item-row">
                <span class="allocation-item-label">Subtask</span>
                <span class="allocation-item-value"><%= item.allocationSubtask || '-' %></span>
              </div>
              <div class="allocation-item-row">
                <span class="allocation-item-label">Allowed Folders</span>
                <span class="allocation-item-value">
                  <% if (item.ownedOutputPaths && item.ownedOutputPaths.length > 0) { %>
                    <code class="owned-path"><%= item.ownedOutputPaths.join(', ') %></code>
                  <% } else { %>
                    -
                  <% } %>
                </span>
              </div>
              <div class="allocation-item-row">
                <span class="allocation-item-label">Runs</span>
                <span class="allocation-item-value">
                  <% if (itemRuns.length === 0) { %>
                    -
                  <% } else { %>
                    <span class="run-links">
                      <% itemRuns.forEach((run, idx) => { %>
                        <a href="/runs/<%= run.id %>" class="run-link run-status-<%= run.status %>">Run #<%= run.id %></a><% if (idx < itemRuns.length - 1) { %>, <% } %>
                      <% }) %>
                    </span>
                  <% } %>
                </span>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
    <% } %>
  </div>
</details>

<details class="disclosure" open>
  <summary>Execution target <span class="sub"><%= ticket.targetRef && ticket.targetRef.kind === 'browser' ? 'Browser · read-only' : 'Workspace / filesystem' %></span></summary>
  <div class="body">
    <% if (ticket.targetRef && ticket.targetRef.kind === 'browser') { %>
      <% if (!browserTarget || browserTarget.status !== 'active') { %>
        <div style="padding:8px 12px;margin-bottom:12px;background:#fff3cd;border:1px solid #ffc107;border-radius:4px;color:#856404;">
          <strong>Browser target unavailable:</strong> This ticket’s browser target is no longer active or is unavailable. Reactivate the target or choose a valid target before rerunning.
        </div>
      <% } %>
      <% const targetLimits = browserTarget && browserTarget.limits ? browserTarget.limits : {}; %>
      <dl class="detail-grid">
        <div><dt>Target</dt><dd><strong><%= browserTarget ? browserTarget.name : 'Unavailable target' %></strong> · <code><%= ticket.targetRef.browserTargetId %></code></dd></div>
        <div><dt>Current status</dt><dd><span class="status-badge status-<%= browserTarget ? browserTarget.status : 'inactive' %>"><%= browserTarget ? browserTarget.status : 'missing' %></span></dd></div>
        <div><dt>Start URL</dt><dd><code><%= browserTarget ? browserTarget.startUrl : '-' %></code></dd></div>
        <div><dt>Allowed origins</dt><dd><% if (browserTarget && browserTarget.allowedOrigins) { browserTarget.allowedOrigins.forEach(function(origin) { %><div><code><%= origin %></code></div><% }); } else { %>-<% } %></dd></div>
        <div><dt>Read-only operations</dt><dd><code>navigate</code>, <code>observe</code>, <code>readPageText</code>, <code>screenshot</code>, <code>wait</code></dd></div>
        <div><dt>maxNavigationsPerRun</dt><dd><code><%= targetLimits.maxNavigationsPerRun || '-' %></code></dd></div>
        <div><dt>maxActionsPerRun</dt><dd><code><%= targetLimits.maxActionsPerRun || '-' %></code></dd></div>
        <div><dt>navTimeoutMs</dt><dd><code><%= targetLimits.navTimeoutMs || '-' %></code></dd></div>
        <div><dt>waitTimeoutMsCap</dt><dd><code><%= targetLimits.waitTimeoutMsCap || '-' %></code></dd></div>
        <div><dt>maxPageTextBytes</dt><dd><code><%= targetLimits.maxPageTextBytes || '-' %></code></dd></div>
        <div><dt>maxScreenshotsPerRun</dt><dd><code><%= targetLimits.maxScreenshotsPerRun || '-' %></code></dd></div>
      </dl>
      <p class="text-muted">No click, fill, press, downloads, credentials, persistent sessions, or browser workflows.</p>
    <% } else { %>
      <dl class="detail-grid">
        <div><dt>Target type</dt><dd>Workspace / filesystem</dd></div>
        <div><dt>Execution scope</dt><dd><%= ticket.assignmentMode === 'individual' ? 'Shared workspace' : 'Allocated workspace paths' %></dd></div>
      </dl>
    <% } %>
  </div>
</details>

<details class="disclosure" open>
  <summary>Work Type <span class="sub"><%= ticket.workTypeSnapshot ? ticket.workTypeSnapshot.name : 'Unspecified' %></span></summary>
  <div class="body">
    <% if (ticket.workTypeSnapshot) { %>
      <dl class="detail-grid">
        <div><dt>Name</dt><dd><strong><%= ticket.workTypeSnapshot.name %></strong> · <code><%= ticket.workTypeSnapshot.id %></code></dd></div>
        <div><dt>Description</dt><dd><%= ticket.workTypeSnapshot.description %></dd></div>
        <div><dt>Status when captured</dt><dd><code><%= ticket.workTypeSnapshot.status %></code></dd></div>
        <div><dt>Allowed target kinds</dt><dd><% ticket.workTypeSnapshot.allowedTargetKinds.forEach(function(kind) { %><code><%= kind %></code> <% }); %></dd></div>
        <div><dt>Captured</dt><dd><%= ticket.workTypeSnapshot.capturedAt %></dd></div>
      </dl>
    <% } else { %>
      <p class="text-muted">Unspecified</p>
    <% } %>
    <p class="text-muted">Semantic context only. This Work Type does not grant authority or operations.</p>
  </div>
</details>

<% if (ticket.executionPolicy) { %>
<details class="disclosure">
  <summary>Execution policy <span class="sub"><%= ticket.executionPolicy.mode %></span></summary>
  <div class="body">
    <p class="text-muted">Verification is enforced when declared. Other fields below are recorded intent and are not enforced in this release unless explicitly noted.</p>
    <dl class="detail-grid">
      <div><dt>Verification</dt><dd><code><%= ticket.executionPolicy.requireVerification %></code> · enforced for declared workflow postconditions</dd></div>
      <div><dt>Workspace scope</dt><dd><code><%= ticket.executionPolicy.workspaceScope %></code> · enforced by the current workspace path</dd></div>
      <div><dt>Mode</dt><dd><code><%= ticket.executionPolicy.mode %></code> · <span class="intent">recorded intent</span></dd></div>
      <div><dt>Workspace writes</dt><dd><%= ticket.executionPolicy.allowWorkspaceWrites ? 'requested' : 'not requested' %> · <span class="intent">recorded intent</span></dd></div>
      <div><dt>Parallel runs</dt><dd><%= ticket.executionPolicy.allowParallelRuns ? 'requested' : 'not requested' %> · <span class="intent">recorded intent</span></dd></div>
      <div><dt>Child tickets</dt><dd><%= ticket.executionPolicy.allowChildTickets ? 'requested' : 'not requested' %> · <span class="intent">recorded intent</span></dd></div>
      <div><dt>Max attempts</dt><dd><%= ticket.executionPolicy.maxAttempts === null ? 'unlimited · enforced for manual rerun-from-start when set' : ticket.executionPolicy.maxAttempts + ' · enforced for manual rerun-from-start' %></dd></div>
      <div><dt>Automatic retry</dt><dd><%= !ticket.executionPolicy.autoRetry ? 'disabled' : (ticket.executionPolicy.maxAttempts === null ? 'enabled but inactive — set maxAttempts to bound automatic retry' : 'enabled · bounded by maxAttempts ' + ticket.executionPolicy.maxAttempts) %></dd></div>
      <div><dt>Max runtime</dt><dd><%= ticket.executionPolicy.maxRuntimeMs === null ? 'unspecified' : ticket.executionPolicy.maxRuntimeMs + 'ms' %> · <span class="intent">recorded intent</span></dd></div>
      <div><dt>Max model requests</dt><dd><%= ticket.executionPolicy.maxModelRequests === null ? 'unspecified' : ticket.executionPolicy.maxModelRequests %> · <span class="intent">recorded intent</span></dd></div>
      <div><dt>Max workspace operations</dt><dd><%= ticket.executionPolicy.maxWorkspaceOperations === null ? 'unspecified' : ticket.executionPolicy.maxWorkspaceOperations %> · <span class="intent">recorded intent</span></dd></div>
    </dl>
    <% if (typeof canUpdateTickets !== 'undefined' && canUpdateTickets) { %>
    <div class="max-attempts-control" data-ticket-id="<%= ticket.id %>">
      <p class="text-muted">Set the manual rerun-from-start ceiling. Leave blank to clear (unlimited). Measurement/limit applies only to manual reruns — no automatic retry.</p>
      <input type="number" id="max-attempts-input" min="1" step="1" placeholder="unlimited" value="<%= ticket.executionPolicy.maxAttempts === null ? '' : ticket.executionPolicy.maxAttempts %>">
      <button type="button" id="max-attempts-set" class="btn-small">Set</button>
      <button type="button" id="max-attempts-clear" class="btn-small">Clear (unlimited)</button>
      <span id="max-attempts-msg" class="text-muted"></span>
    </div>
    <script>
      (function () {
        var wrap = document.querySelector('.max-attempts-control');
        if (!wrap) return;
        var ticketId = wrap.getAttribute('data-ticket-id');
        var input = document.getElementById('max-attempts-input');
        var msg = document.getElementById('max-attempts-msg');
        async function submit(value) {
          msg.textContent = '';
          try {
            var res = await fetch('/api/tickets/' + ticketId + '/execution-policy/max-attempts', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ maxAttempts: value })
            });
            var payload = await res.json().catch(function () { return null; });
            if (!res.ok) {
              msg.textContent = (payload && payload.error) ? payload.error : 'Update rejected.';
              return;
            }
            window.location.reload();
          } catch (e) {
            msg.textContent = 'Update failed.';
          }
        }
        document.getElementById('max-attempts-set').addEventListener('click', function () { submit(input.value.trim() === '' ? '' : input.value.trim()); });
        document.getElementById('max-attempts-clear').addEventListener('click', function () { submit(''); });
      })();
    </script>
    <% } %>
  </div>
</details>
<% } %>

<details class="disclosure">
  <summary>Ticket details <span class="sub">Created <%= ticket.createdAt ? new Date(ticket.createdAt).toLocaleString() : '-' %></span></summary>
  <div class="body">
    <dl class="detail-grid">
      <div>
        <dt>Created</dt>
        <dd><%= ticket.createdAt ? new Date(ticket.createdAt).toLocaleString() : '-' %></dd>
      </div>
      <div>
        <dt>Updated</dt>
        <dd><%= ticket.updatedAt ? new Date(ticket.updatedAt).toLocaleString() : '-' %></dd>
      </div>
      <div>
        <dt>Changed By</dt>
        <dd><%= ticket.changedBy || '-' %></dd>
      </div>
      <div>
        <dt>Changed At</dt>
        <dd><%= ticket.changedAt ? new Date(ticket.changedAt).toLocaleString() : '-' %></dd>
      </div>
    </dl>
  </div>
</details>

<div class="zone-head"><span class="zone-eyebrow">What has happened</span><span class="zone-q">What did the system actually do?</span></div>

<section class="detail-section">
  <h2>Runs &amp; attempts</h2>
  <% if (ticketRuns.length === 0) { %>
    <p class="text-muted">No runs yet.</p>
  <% } else { %>
    <% const attemptByRun = {}; (typeof attemptSummary !== 'undefined' && attemptSummary ? attemptSummary.attempts : []).forEach(a => { attemptByRun[a.runId] = a; }); %>
    <% const showAttemptCols = typeof attemptSummary !== 'undefined' && attemptSummary && attemptSummary.attemptCount > 0; %>
    <% const hasScopedRuns = ticketRuns.some(run => run.allocationPlanId || run.allocationItemId); %>
    <table class="tickets-table">
      <thead><tr>
        <% if (showAttemptCols) { %><th>Attempt</th><% } %>
        <th>Run #</th><th>Agent</th><th>Status</th><th>Run Outcome</th><th>Verification Contract</th><th>Mutations</th>
        <% if (showAttemptCols) { %><th>Duration</th><th>Model reqs</th><th>Workspace ops</th><th>Mutating ops</th><th>Verification</th><th>Triage</th><% } %>
        <% if (hasScopedRuns) { %><th>Work Split</th><th>Work Unit</th><% } %>
        <th>Created</th>
      </tr></thead>
      <tbody>
        <% ticketRuns.forEach(run => { const a = attemptByRun[run.id]; %>
          <tr>
            <% if (showAttemptCols) { %><td><%= a && a.attemptNumber !== null && a.attemptNumber !== undefined ? a.attemptNumber : '-' %></td><% } %>
            <td><a href="/runs/<%= run.id %>">Run #<%= run.id %></a></td>
            <td><%= run.agentName %></td>
            <td><span class="status-badge status-<%= run.status %>"><%= run.status %></span></td>
            <td><code><%= run.operationalOutcome || '-' %></code></td>
            <td>
              <% const frozenPostconditions = run.verificationContractSnapshot && Array.isArray(run.verificationContractSnapshot.postconditions) ? run.verificationContractSnapshot.postconditions : []; %>
              <% if (frozenPostconditions.length === 0) { %>
                <span class="text-muted">None</span>
              <% } else { %>
                <%= frozenPostconditions.length %> check<%= frozenPostconditions.length === 1 ? '' : 's' %>
                <span class="text-muted">· frozen at run creation</span>
                <ul class="text-muted" style="margin:4px 0 0;padding-left:18px;">
                  <% frozenPostconditions.forEach(pc => { %>
                    <li><code><%= typeof formatPostconditionAssertion === 'function' ? formatPostconditionAssertion(pc) : (pc.type || 'unknown') %></code></li>
                  <% }) %>
                </ul>
              <% } %>
            </td>
            <td><%= run.partialMutationCount > 0 ? run.partialMutationCount : '-' %></td>
            <% if (showAttemptCols) { %>
              <td><%= a && a.durationMs !== null && a.durationMs !== undefined ? a.durationMs + 'ms' : 'unavailable' %></td>
              <td><%= a && a.modelRequestCount !== null && a.modelRequestCount !== undefined ? a.modelRequestCount : 'unavailable' %></td>
              <td><%= a && a.workspaceOperationCount !== null && a.workspaceOperationCount !== undefined ? a.workspaceOperationCount : 'unavailable' %></td>
              <td><%= a && a.mutatingWorkspaceOperationCount !== null && a.mutatingWorkspaceOperationCount !== undefined ? a.mutatingWorkspaceOperationCount : 'unavailable' %></td>
              <td><%= a && a.verificationRequired ? 'required · ' + a.verificationOutcome : 'not required' %></td>
              <td><%= a && a.triageRequired ? 'required' : 'none' %></td>
            <% } %>
            <% if (hasScopedRuns) { %><td><%= run.allocationPlanId || '-' %></td><td><%= run.allocationItemId || '-' %></td><% } %>
            <td><%= run.createdAt ? new Date(run.createdAt).toLocaleString() : '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <% if (typeof budgetSummary !== 'undefined' && budgetSummary && budgetSummary.runCount > 0) { %>
      <%
        function budgetRollupLabel(status) {
          if (status === 'exceeded') return 'exceeded (advisory)';
          if (status === 'unavailable') return 'unavailable';
          if (status === 'within_threshold') return 'within limit';
          return 'not configured';
        }
      %>
      <p class="text-muted">Budget advisory (no execution blocked): overall <%= budgetRollupLabel(budgetSummary.overall) %> · runtime <%= budgetRollupLabel(budgetSummary.metrics.runtimeMs) %> · model requests <%= budgetRollupLabel(budgetSummary.metrics.modelRequests) %> · workspace operations <%= budgetRollupLabel(budgetSummary.metrics.workspaceOperations) %>. Runs: <%= budgetSummary.counts.exceeded %> exceeded, <%= budgetSummary.counts.within_threshold %> within, <%= budgetSummary.counts.unavailable %> unavailable, <%= budgetSummary.counts.not_configured %> not configured.</p>
    <% } %>
    <p class="text-muted">Each run is one attempt — measurement only, no retry triggered.</p>
  <% } %>
</section>

<details class="disclosure">
  <summary>Artifacts <span class="sub"><%= (typeof artifacts === 'undefined' ? [] : artifacts).length %> item(s)</span></summary>
  <div class="body">
  <% const ticketArtifacts = typeof artifacts === 'undefined' ? [] : artifacts; %>
  <% if (ticketArtifacts.length === 0) { %>
    <p class="text-muted">No artifacts produced yet.</p>
  <% } else { %>
    <table class="tickets-table">
      <thead>
        <tr>
          <th>Type</th>
          <th>Artifact</th>
          <th>Status</th>
          <th>Run</th>
          <th>Source</th>
          <th>Timestamp</th>
        </tr>
      </thead>
      <tbody>
        <% ticketArtifacts.forEach(artifact => { %>
          <tr>
            <td><%= artifact.type %></td>
            <td><code class="owned-path"><%= artifact.artifact %></code></td>
            <td><span class="status-badge"><%= artifact.status %></span></td>
            <td>
              <% if (artifact.runId) { %>
                <a href="/runs/<%= artifact.runId %>">Run #<%= artifact.runId %></a>
              <% } else { %>
                -
              <% } %>
            </td>
            <td><%= artifact.source || '-' %></td>
            <td><%= artifact.timestamp ? new Date(artifact.timestamp).toLocaleString() : '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
  </div>
</details>

<% const ticketTimeline = typeof timeline === 'undefined' || !timeline ? { entries: [] } : timeline; %>
<details class="disclosure">
  <summary>Timeline <span class="sub"><%= ticketTimeline.entries.length %> entries</span></summary>
  <div class="body">
  <p class="text-muted">Read-only projection from ticket/run state, structured events, target receipts, replay evidence, and selected diagnostic logs.</p>
  <% if (ticketTimeline.entries.length === 0) { %>
    <p class="text-muted">No timeline evidence available.</p>
  <% } else { %>
    <table class="tickets-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Entry</th>
          <th>Source</th>
          <th>Run</th>
        </tr>
      </thead>
      <tbody>
        <% ticketTimeline.entries.forEach(entry => { %>
          <tr>
            <td><%= entry.timestamp ? new Date(entry.timestamp).toLocaleString() : '-' %></td>
            <td>
              <strong><%= entry.title %></strong>
              <% if (entry.status) { %><span class="status-badge status-<%= entry.status %>"><%= entry.status %></span><% } %>
              <% if (entry.summary) { %><div class="text-muted"><%= entry.summary %></div><% } %>
              <% if (entry.details && (entry.details.operation || entry.details.path)) { %>
                <div class="text-muted">
                  <% if (entry.details.operation) { %><code><%= entry.details.operation %></code><% } %>
                  <% if (entry.details.path) { %><code class="owned-path"><%= entry.details.path %></code><% } %>
                  <% if (entry.details.nextPath) { %> to <code class="owned-path"><%= entry.details.nextPath %></code><% } %>
                </div>
              <% } %>
            </td>
            <td>
              <code><%= entry.sourceRole %></code>
              <div class="text-muted"><%= entry.sourceRef %></div>
            </td>
            <td><% if (entry.runId) { %><a href="/runs/<%= entry.runId %>">Run #<%= entry.runId %></a><% } else { %>-<% } %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
  </div>
</details>

<% if (operationHistory && operationHistory.length > 0) { %>
<details class="disclosure">
  <summary>Operation History <span class="sub"><%= operationHistory.length %> record(s)</span></summary>
  <div class="body">
  <div class="operation-history">
    <% operationHistory.forEach((record, index) => { %>
      <div class="operation-history-item <%= record.isRecovery ? 'is-recovery' : '' %>">
        <div class="operation-history-header">
          <span class="operation-history-number">#<%= record.id %></span>
          <span class="operation-history-type"><%= record.operation %></span>
          <span class="operation-history-step">run <%= record.runId %> · step <%= record.step %></span>
          <% if (record.isRecovery) { %>
            <span class="badge badge--recovery-action">RECOVERY</span>
          <% } else if (record.recoveryStatus) { %>
            <% if (record.recoveryStatus.status === 'recoverable') { %>
              <span class="badge badge--recovery-recoverable">RECOVERABLE</span>
            <% } else if (record.recoveryStatus.status === 'unrecoverable') { %>
              <span class="badge badge--recovery-unrecoverable">UNRECOVERABLE</span>
            <% } else if (record.recoveryStatus.status === 'recovery_available') { %>
              <span class="badge badge--recovery-available">RECOVERY AVAILABLE</span>
            <% } %>
          <% } %>
          <% if (record.error) { %>
            <span class="badge badge--outcome-error">ERROR</span>
          <% } else if (record.result && record.result.status === 'already_exists_noop') { %>
            <span class="badge badge--outcome-noop">NO-OP</span>
          <% } else { %>
            <span class="badge badge--outcome-success">OK</span>
          <% } %>
        </div>
        <div class="operation-history-body">
          <div class="allocation-item-row">
            <span class="allocation-item-label">Path</span>
            <span class="allocation-item-value"><code class="owned-path"><%= record.args.path %></code></span>
          </div>
          <% if (record.args.nextPath) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Next Path</span>
              <span class="allocation-item-value"><code class="owned-path"><%= record.args.nextPath %></code></span>
            </div>
          <% } %>
          <% if (record.isRecovery && record.recoveredHistoryId) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Recovered</span>
              <span class="allocation-item-value">History #<%= record.recoveredHistoryId %></span>
            </div>
          <% } %>
          <% if (record.preState) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">State diff</span>
              <span class="allocation-item-value">
                <details class="collapsible">
                  <summary>View diff</summary>
                  <div class="diff-container">
                    <div class="diff-panel">
                      <div class="diff-panel-label">Before</div>
                      <pre class="code-block code-block--diff"><%= JSON.stringify(record.preState, null, 2) %></pre>
                    </div>
                    <div class="diff-panel">
                      <div class="diff-panel-label">After</div>
                      <pre class="code-block code-block--diff"><%= JSON.stringify(record.postState, null, 2) %></pre>
                    </div>
                  </div>
                </details>
              </span>
            </div>
          <% } else if (record.postState) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Post-State</span>
              <span class="allocation-item-value">
                <details class="collapsible">
                  <summary>View Post-State</summary>
                  <pre class="code-block"><%= JSON.stringify(record.postState, null, 2) %></pre>
                </details>
              </span>
            </div>
          <% } %>
          <% if (record.error) { %>
            <div class="allocation-item-row">
              <span class="allocation-item-label">Error</span>
              <span class="allocation-item-value"><span class="failure-reason"><%= record.error %></span></span>
            </div>
          <% } %>
          <% if (canUpdateTickets && !record.isRecovery && record.recoveryStatus && record.recoveryStatus.status === 'recoverable') { %>
            <div class="recovery-controls">
              <button type="button" class="btn-small" data-preview-recovery-id="<%= record.id %>">Preview Recovery</button>
            </div>
            <div class="recovery-preview-panel" id="recovery-preview-<%= record.id %>" style="display: none;"></div>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
  </div>
</details>
<% } %>

<script>
(() => {
  const section = document.getElementById('ticket-runtime-section');
  if (!section) return;

  const ticketId = section.dataset.ticketRuntimeId;
  const activeStatuses = new Set(['pending', 'running']);
  const terminalStatuses = new Set(['completed', 'failed', 'interrupted']);
  let hadActiveRun = section.dataset.ticketRuntimeActive === 'true';
  let currentRunStatus = document.getElementById('ticket-live-run-status')?.textContent || '';
  let elapsedInterval = null;
  let eventSource = null;
  let terminalReloaded = false;

  const ticketStatusEl = document.getElementById('ticket-live-status');
  const runEl = document.getElementById('ticket-live-run');
  const runStatusEl = document.getElementById('ticket-live-run-status');
  const messageEl = document.getElementById('ticket-live-message');
  const stepEl = document.getElementById('ticket-live-step');
  const leaseEl = document.getElementById('ticket-live-lease');
  const elapsedEl = document.getElementById('ticket-live-elapsed');
  const outcomeEl = document.getElementById('ticket-live-outcome');

  function formatElapsed(ms) {
    const seconds = Math.max(0, Math.floor(ms / 1000));
    if (seconds < 60) return seconds + ' second' + (seconds === 1 ? '' : 's');
    const minutes = Math.floor(seconds / 60);
    const rest = seconds % 60;
    if (rest === 0) return minutes + ' minute' + (minutes === 1 ? '' : 's');
    return minutes + ' minute' + (minutes === 1 ? '' : 's') + ' ' + rest + ' second' + (rest === 1 ? '' : 's');
  }

  function setText(el, value) {
    if (!el) return;
    el.textContent = value || '-';
  }

  function updateBadge(el, status) {
    if (!el) return;
    el.className = 'status-badge' + (status ? ' status-' + status : '');
    el.textContent = status || '-';
  }

  function updateRunLink(run) {
    if (!runEl) return;
    if (!run || !run.id) {
      runEl.textContent = '-';
      return;
    }
    runEl.innerHTML = '';
    const link = document.createElement('a');
    link.href = '/runs/' + encodeURIComponent(run.id);
    link.textContent = 'Run #' + run.id;
    runEl.appendChild(link);
  }

  function formatStep(step, run) {
    if (step && step.stepId) {
      const detail = [step.action, step.status].filter(Boolean).join(' ');
      return detail ? step.stepId + ' (' + detail + ')' : step.stepId;
    }
    return run && run.currentStepId ? run.currentStepId : '-';
  }

  function formatLease(lease) {
    if (!lease || !lease.leaseOwner) return '-';
    const parts = [lease.leaseOwner];
    if (lease.expired) parts.push('expired');
    else if (lease.heldByCurrentProcess) parts.push('held');
    if (lease.leaseExpiresAt) parts.push('until ' + lease.leaseExpiresAt);
    return parts.join(' · ');
  }

  function updateElapsed(startedAt, completedAt, status) {
    if (!elapsedEl) return;
    const startText = startedAt || elapsedEl.dataset.startedAt || '';
    const completeText = completedAt || elapsedEl.dataset.completedAt || '';
    const startMs = Date.parse(startText);
    if (Number.isNaN(startMs)) {
      elapsedEl.textContent = '-';
      return;
    }

    elapsedEl.dataset.startedAt = startText;
    if (completeText) {
      const completeMs = Date.parse(completeText);
      if (!Number.isNaN(completeMs)) {
        elapsedEl.dataset.completedAt = completeText;
        elapsedEl.textContent = formatElapsed(completeMs - startMs);
        return;
      }
    }

    if (activeStatuses.has(status)) {
      elapsedEl.textContent = (status === 'pending' ? 'queued for ' : 'running for ') + formatElapsed(Date.now() - startMs);
    } else {
      elapsedEl.textContent = formatElapsed(Date.now() - startMs);
    }
  }

  function applyRuntimeState(state) {
    const ticket = state.ticket || {};
    const run = state.currentRun || state.latestRun || null;

    updateBadge(ticketStatusEl, ticket.status);
    updateRunLink(run);
    updateBadge(runStatusEl, run && run.status);
    currentRunStatus = run && run.status ? run.status : '';
    setText(messageEl, state.currentMessage || (run && run.currentMessage));
    setText(stepEl, formatStep(state.currentStep, run));
    setText(leaseEl, formatLease(state.leaseState || (run && run.lease)));
    setText(outcomeEl, state.outcomeLabel || (run && run.outcomeLabel) || state.outcome);
    updateElapsed(run && (run.startedAt || run.createdAt), run && run.completedAt, run && run.status);

    const activeRun = state.currentRun && activeStatuses.has(state.currentRun.status);
    if (activeRun) {
      hadActiveRun = true;
      return;
    }

    if (elapsedInterval) {
      window.clearInterval(elapsedInterval);
      elapsedInterval = null;
    }
    if (eventSource) { eventSource.close(); eventSource = null; }
    if (hadActiveRun && run && terminalStatuses.has(run.status) && !terminalReloaded) {
      terminalReloaded = true;
      window.location.reload();
    }
  }

  async function refreshTicketRuntime() {
    if (!hadActiveRun && !activeStatuses.has(currentRunStatus)) return;
    const response = await fetch('/api/tickets/' + encodeURIComponent(ticketId) + '/runtime', {
      headers: { Accept: 'application/json' }
    });
    if (!response.ok) return;
    applyRuntimeState(await response.json());
  }

  updateElapsed(elapsedEl && elapsedEl.dataset.startedAt, elapsedEl && elapsedEl.dataset.completedAt, currentRunStatus);
  if (hadActiveRun || activeStatuses.has(currentRunStatus)) {
    if (window.EventSource) {
      eventSource = new EventSource('/api/events');
      eventSource.addEventListener('run:status-changed', function(e) {
        var data;
        try { data = JSON.parse(e.data); } catch (_) { return; }
        if (data && data.ticketId === ticketId) refreshTicketRuntime().catch(function(){});
      });
      eventSource.addEventListener('error', function() {
        if (eventSource) eventSource.close();
        eventSource = null;
      });
    }
    elapsedInterval = window.setInterval(function() {
      updateElapsed(elapsedEl && elapsedEl.dataset.startedAt, elapsedEl && elapsedEl.dataset.completedAt, currentRunStatus);
    }, 1000);
    refreshTicketRuntime().catch(function(){});
  }
})();
</script>

<% if (canUpdateTickets) { %>
<script>
document.addEventListener('click', async event => {
  const simulateButton = event.target.closest('[data-simulate-plan-id]');
  if (simulateButton) {
    simulateButton.disabled = true;
    const ticketId = simulateButton.dataset.simulatePlanId;
    const mode = simulateButton.dataset.simulateMode;
    const resultDiv = document.getElementById('simulation-result');
    if (resultDiv) resultDiv.style.display = 'block';
    try {
      const res = await fetch('/api/tickets/' + encodeURIComponent(ticketId) + '/simulate-plan', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ includeModelPlan: mode === 'model' })
      });
      const data = await res.json();
      const parts = [];
      parts.push('<strong>Gate verdict:</strong> ' + escapeHtml(data.gateVerdict));
      if (data.reasonCode) parts.push('<strong>Reason:</strong> ' + escapeHtml(data.reasonCode));
      if (data.gateSummary) parts.push('<strong>Summary:</strong> ' + escapeHtml(data.gateSummary));
      if (data.simulatedAgent) parts.push('<strong>Simulated agent:</strong> ' + escapeHtml(data.simulatedAgent));
      if (data.modelError) parts.push('<strong>Model error:</strong> ' + escapeHtml(data.modelError));
      if (data.parseError) parts.push('<strong>Parse error:</strong> ' + escapeHtml(data.parseError));
      if (Array.isArray(data.actionsProposed) && data.actionsProposed.length > 0) {
        parts.push('<strong>Proposed actions:</strong> ' + data.actionsProposed.length);
        parts.push('<pre class="code-block">' + escapeHtml(JSON.stringify(data.actionsProposed, null, 2)) + '</pre>');
      }
      if (Array.isArray(data.validationFindings) && data.validationFindings.length > 0) {
        parts.push('<strong>Validation findings:</strong> ' + data.validationFindings.length);
        parts.push('<pre class="code-block">' + escapeHtml(JSON.stringify(data.validationFindings, null, 2)) + '</pre>');
      }
      if (data.modelMessage) parts.push('<strong>Model message:</strong> ' + escapeHtml(data.modelMessage));
      if (resultDiv) resultDiv.innerHTML = parts.join('<br>');
    } catch (e) {
      if (resultDiv) resultDiv.innerHTML = '<strong>Simulation failed:</strong> ' + escapeHtml(e.message);
    }
    simulateButton.disabled = false;
    return;
  }

  const rerunButton = event.target.closest('[data-rerun-ticket-id]');
  if (rerunButton) {
    rerunButton.disabled = true;
    fetch('/api/tickets/' + encodeURIComponent(rerunButton.dataset.rerunTicketId) + '/rerun', {
      method: 'POST',
      headers: { Accept: 'application/json' }
    }).then(response => {
      if (!response.ok) {
        return response.json().catch(() => ({})).then(data => {
          window.alert(data.error || 'Ticket rerun failed');
          window.location.reload();
        });
      }
      window.location.reload();
    });
    return;
  }

  const previewButton = event.target.closest('[data-preview-recovery-id]');
  if (previewButton) {
    previewButton.disabled = true;
    const historyId = previewButton.dataset.previewRecoveryId;
    const panel = document.getElementById('recovery-preview-' + historyId);
    fetch('/api/operations/' + encodeURIComponent(historyId) + '/recovery-preview')
      .then(response => response.json())
      .then(data => {
        if (data.error) {
          panel.className = 'recovery-preview-panel recovery-blocked';
          panel.innerHTML = '<div class="recovery-reason">' + escapeHtml(data.error) + '</div>';
        } else if (data.preview) {
          const p = data.preview;
          panel.className = p.canProceed ? 'recovery-preview-panel' : 'recovery-preview-panel recovery-blocked';
          let html = '<div class="recovery-action-text">Proposed: ' + escapeHtml(p.proposedAction.operation) + '</div>';
          if (p.proposedAction.args.path) html += '<div class="recovery-reason">Path: <code class="owned-path">' + escapeHtml(p.proposedAction.args.path) + '</code></div>';
          if (p.proposedAction.args.nextPath) html += '<div class="recovery-reason">Next Path: <code class="owned-path">' + escapeHtml(p.proposedAction.args.nextPath) + '</code></div>';
          if (p.validation && !p.validation.valid) html += '<div class="recovery-reason" style="color:#991b1b;margin-top:6px;">Blocked: ' + escapeHtml(p.validation.reason) + '</div>';
          if (p.canProceed) {
            html += '<div class="recovery-controls"><button type="button" class="btn-small btn-danger" data-confirm-recovery-id="' + historyId + '">Confirm Recovery</button></div>';
          }
          panel.innerHTML = html;
        }
        panel.style.display = 'block';
        previewButton.disabled = false;
      })
      .catch(err => {
        panel.className = 'recovery-preview-panel recovery-blocked';
        panel.innerHTML = '<div class="recovery-reason">Preview failed: ' + escapeHtml(err.message) + '</div>';
        panel.style.display = 'block';
        previewButton.disabled = false;
      });
    return;
  }

  const confirmButton = event.target.closest('[data-confirm-recovery-id]');
  if (confirmButton) {
    confirmButton.disabled = true;
    const historyId = confirmButton.dataset.confirmRecoveryId;
    fetch('/api/operations/' + encodeURIComponent(historyId) + '/recover', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({ confirmed: true })
    })
      .then(response => response.json())
      .then(data => {
        if (data.error) {
          alert('Recovery failed: ' + data.error);
          confirmButton.disabled = false;
        } else {
          window.location.reload();
        }
      })
      .catch(err => {
        alert('Recovery failed: ' + err.message);
        confirmButton.disabled = false;
      });
    return;
  }
});

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}
</script>
<% } %>
