<script>document.querySelector('main.container')?.classList.add('container--wide');</script>

<div class="page-header">
  <div>
    <h1>Run #<%= run.id %> — Decision Map</h1>
    <p class="text-muted">
      Ticket <a href="/tickets/<%= run.ticketId %>">#<%= run.ticketId %></a> · <%= run.agentName %> ·
      <span id="map-run-status" class="status-badge status-<%= run.status %>"><%= run.status %></span>
    </p>
  </div>
  <div class="actions">
    <a class="btn-secondary" href="/runs/<%= run.id %>">Run Detail</a>
  </div>
</div>

<p class="text-muted">
  A read-only projection of this run's recorded evidence as the truth hierarchy: what the model
  proposed (its messages verbatim), what the runtime guards decided, what actually executed against
  the target, and how the run was verified. <strong>Horizontal = execution steps</strong> (the
  runtime's model turns, step 0 onward; the outcome chain sits in the final column), left to right
  in recorded order. Dashed red nodes are proposals that never executed — dropped by caps or
  blocked by guards. Nodes size to their content, so recorded text is shown in full; click a node
  for every recorded field. Nothing here is inferred; every node cites its evidence.
</p>

<section class="admin-block">
  <div id="map-canvas-wrap" class="map-canvas-wrap">
    <svg id="map-canvas" xmlns="http://www.w3.org/2000/svg"></svg>
  </div>
</section>

<section class="admin-block" id="map-detail-panel" hidden>
  <h2 id="map-detail-title">Node</h2>
  <dl class="detail-grid" id="map-detail-grid"></dl>
  <p class="text-muted">Evidence: <code id="map-detail-evidence"></code> — full payloads on the <a href="/runs/<%= run.id %>">run page</a>.</p>
</section>

<script>
let graph = <%- serializeForInlineScript(decisionGraph) %>;
const runId = <%- serializeForInlineScript(run.id) %>;
let currentStatus = <%- serializeForInlineScript(run.status) %>;

const LANES = [
  { id: 'model', label: 'MODEL (inference)' },
  { id: 'authority', label: 'AUTHORITY (guards)' },
  { id: 'target', label: 'TARGET (facts)' },
  { id: 'outcome', label: 'OUTCOME (verified)' }
];
const NODE_W = 210;
const MIN_NODE_H = 56;
const COL_W = 240;
const ROW_GAP = 10;
const LANE_GAP = 56;
const LANE_TOP = 96;
const MAX_SUBCOLS = 3;
const STATUS_COLORS = {
  complete_claimed: '#4f46e5', continuing: '#6366f1', recorded: '#6b7280',
  allowed: '#16a34a', blocked: '#dc2626', dropped: '#dc2626', unexecuted: '#d97706',
  created: '#16a34a', ok: '#16a34a', noop: '#d97706', error: '#dc2626',
  passed: '#16a34a', failed: '#dc2626', completed: '#16a34a', interrupted: '#7c3aed',
  required: '#dc2626', resolved: '#6b7280', annotation: '#d97706',
  pending: '#2563eb', running: '#f59e0b'
};

const svg = document.getElementById('map-canvas');
const SVG_NS = 'http://www.w3.org/2000/svg';

function el(name, attrs, parent) {
  const node = document.createElementNS(SVG_NS, name);
  for (const [key, value] of Object.entries(attrs)) node.setAttribute(key, value);
  (parent || svg).appendChild(node);
  return node;
}

// Full display text per node, composed from the untruncated detail fields
// (the projection contract guarantees them) — never from the layout-truncated
// label. Nothing recorded is hidden on the map itself.
function fullText(node) {
  const d = node.detail || {};
  if (d.message) return d.message;
  if (node.kind === 'workspace_operation') {
    return (d.operation || 'operation')
      + (d.path ? ' ' + d.path : '')
      + (d.nextPath ? ' → ' + d.nextPath : '')
      + (d.reason ? '\n' + d.reason : '');
  }
  if (node.kind === 'authority_decision') return d.reason ? 'blocked: ' + d.reason : node.label;
  if (node.kind === 'cap_dropped') return 'dropped by per-response cap: ' + (d.operation || '') + (d.path ? ' ' + d.path : '');
  if (node.kind === 'unexecuted_proposal') return 'proposed; no recorded execution: ' + (d.operation || '') + (d.path ? ' ' + d.path : '');
  if (node.kind === 'browser_operation') return (d.operation || 'browser operation') + (d.url ? ' ' + d.url : '') + (d.error ? '\n' + d.error : '');
  if (node.kind === 'terminal') return 'run ' + node.status + (d.failureReason ? ': ' + d.failureReason : '');
  if (node.kind === 'triage') return node.label + (d.summary ? '\n' + d.summary : '') + (d.resolution ? '\nresolution: ' + d.resolution : '');
  return node.label;
}

// Measurement pass: render each node's real HTML content offscreen at node
// width and take its actual height, so every node is sized to show its full
// text — no clamping, no ellipsis, no estimation.
function measureHeights(nodes) {
  const host = document.createElement('div');
  host.className = 'map-measure-host';
  host.style.width = NODE_W + 'px';
  document.body.appendChild(host);
  const heights = new Map();
  for (const n of nodes) {
    const probe = document.createElement('div');
    probe.className = 'map-node-body';
    const head = document.createElement('div');
    head.className = 'map-node-kind';
    head.textContent = 'step 0 · ' + n.kind;
    const label = document.createElement('div');
    label.className = 'map-node-label';
    label.textContent = fullText(n);
    probe.appendChild(head);
    probe.appendChild(label);
    host.appendChild(probe);
    heights.set(n.id, Math.max(MIN_NODE_H, Math.ceil(probe.offsetHeight) + 2));
    host.removeChild(probe);
  }
  document.body.removeChild(host);
  return heights;
}

// Layout with per-node heights. Pass 1: group nodes into (lane, step) cells;
// each cell stacks sub-rows of up to MAX_SUBCOLS nodes, and a row is as tall
// as its tallest node. A lane band is as tall as its tallest cell, so lanes
// can never overlap regardless of content size. Pass 2 positions nodes.
function layout(nodes, heights) {
  const steps = [...new Set(nodes.filter(n => n.step !== null && n.step !== undefined).map(n => n.step))].sort((a, b) => a - b);
  const stepCol = new Map(steps.map((step, i) => [step, i]));
  const h = id => heights.get(id) || MIN_NODE_H;

  const cells = new Map();
  const steplessNodes = { model: [], authority: [], target: [], outcome: [] };
  for (const n of nodes) {
    if (n.step !== null && n.step !== undefined) {
      const key = n.lane + ':' + n.step;
      if (!cells.has(key)) cells.set(key, []);
      cells.get(key).push(n);
    } else {
      steplessNodes[n.lane].push(n);
    }
  }
  const subCols = Math.min(MAX_SUBCOLS, Math.max(1, ...[...cells.values()].map(c => c.length), 1));
  const cellWidth = COL_W + (subCols - 1) * (NODE_W + 8);

  // Per-cell row heights → per-lane band height.
  const cellRowHeights = new Map();
  const laneHeight = { model: MIN_NODE_H, authority: MIN_NODE_H, target: MIN_NODE_H, outcome: MIN_NODE_H };
  for (const [key, cellNodes] of cells) {
    const lane = key.split(':')[0];
    const rowHeights = [];
    cellNodes.forEach((n, index) => {
      const row = Math.floor(index / MAX_SUBCOLS);
      rowHeights[row] = Math.max(rowHeights[row] || 0, h(n.id));
    });
    cellRowHeights.set(key, rowHeights);
    const total = rowHeights.reduce((sum, rh) => sum + rh + ROW_GAP, -ROW_GAP);
    laneHeight[lane] = Math.max(laneHeight[lane], total);
  }
  for (const lane of Object.keys(steplessNodes)) {
    for (const n of steplessNodes[lane]) laneHeight[lane] = Math.max(laneHeight[lane], h(n.id));
  }

  const laneY = {};
  let cursorY = LANE_TOP;
  for (const lane of LANES.map(l => l.id)) {
    laneY[lane] = cursorY;
    cursorY += laneHeight[lane] + LANE_GAP;
  }

  const positions = new Map();
  for (const [key, cellNodes] of cells) {
    const lane = key.split(':')[0];
    const step = Number(key.split(':')[1]);
    const rowHeights = cellRowHeights.get(key);
    cellNodes.forEach((n, index) => {
      const row = Math.floor(index / MAX_SUBCOLS);
      let yOffset = 0;
      for (let r = 0; r < row; r += 1) yOffset += rowHeights[r] + ROW_GAP;
      positions.set(n.id, {
        x: 140 + stepCol.get(step) * cellWidth + (index % MAX_SUBCOLS) * (NODE_W + 8),
        y: laneY[lane] + yOffset,
        h: h(n.id)
      });
    });
  }
  const steplessBase = 140 + steps.length * cellWidth + 20;
  for (const lane of Object.keys(steplessNodes)) {
    steplessNodes[lane].forEach((n, index) => {
      positions.set(n.id, { x: steplessBase + index * (NODE_W + 12), y: laneY[lane], h: h(n.id) });
    });
  }
  const maxX = Math.max(600, ...[...positions.values()].map(p => p.x + NODE_W + 40));
  const maxY = cursorY - LANE_GAP + 30;

  // Horizontal axis: one labeled column per execution step (the recorded
  // metric — model turns), plus a trailing column for outcome/unlinked nodes.
  const columns = steps.map(step => ({ x: 140 + stepCol.get(step) * cellWidth, width: cellWidth, label: 'STEP ' + step }));
  const hasStepless = Object.values(steplessNodes).some(list => list.length > 0);
  if (hasStepless) columns.push({ x: steplessBase, width: Math.max(NODE_W + 20, maxX - steplessBase), label: 'OUTCOME / UNLINKED' });

  return { positions, laneY, width: maxX, height: maxY, columns };
}

function edgePath(a, b) {
  if (Math.abs(a.y - b.y) < 1) {
    return `M ${a.x + NODE_W} ${a.y + a.h / 2} L ${b.x} ${b.y + b.h / 2}`;
  }
  const from = a.y < b.y ? { x: a.x + NODE_W / 2, y: a.y + a.h } : { x: a.x + NODE_W / 2, y: a.y };
  const to = a.y < b.y ? { x: b.x + NODE_W / 2, y: b.y } : { x: b.x + NODE_W / 2, y: b.y + b.h };
  const midY = (from.y + to.y) / 2;
  return `M ${from.x} ${from.y} C ${from.x} ${midY}, ${to.x} ${midY}, ${to.x} ${to.y}`;
}

const XHTML_NS = 'http://www.w3.org/1999/xhtml';

function render() {
  svg.replaceChildren();
  const heights = measureHeights(graph.nodes);
  const { positions, laneY, width, height, columns } = layout(graph.nodes, heights);
  svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
  svg.setAttribute('width', width);
  svg.setAttribute('height', height);

  // Axis header: execution-step columns (the recorded progression metric).
  el('text', { x: 140, y: 16, fill: '#6b7280', 'font-size': 11, 'font-weight': 600 }).textContent = 'execution steps (model turns) →';
  for (const column of columns) {
    el('line', { x1: column.x - 12, y1: 6, x2: column.x - 12, y2: height - 6, stroke: '#f3f4f6', 'stroke-width': 1 });
    el('text', { x: column.x, y: 34, fill: '#9ca3af', 'font-size': 10, 'font-weight': 700, 'letter-spacing': '0.08em' }).textContent = column.label;
  }

  for (const lane of LANES) {
    el('line', { x1: 0, y1: laneY[lane.id] - 18, x2: width, y2: laneY[lane.id] - 18, stroke: '#e5e7eb', 'stroke-width': 1 });
    el('text', { x: 8, y: laneY[lane.id] - 26, fill: '#9ca3af', 'font-size': 11, 'font-weight': 700, 'letter-spacing': '0.08em' }).textContent = lane.label;
  }

  for (const edge of graph.edges) {
    const a = positions.get(edge.from), b = positions.get(edge.to);
    if (!a || !b) continue;
    const failing = edge.kind === 'blocked' || edge.kind === 'dropped';
    el('path', {
      d: edgePath(a, b), fill: 'none',
      stroke: failing ? '#dc2626' : '#c7ccd4',
      'stroke-width': failing ? 1.6 : 1.2,
      'stroke-dasharray': edge.kind === 'dropped' ? '5 4' : (edge.kind === 'proposed' ? '2 3' : 'none')
    });
  }

  for (const node of graph.nodes) {
    const pos = positions.get(node.id);
    if (!pos) continue;
    const color = STATUS_COLORS[node.status] || '#6b7280';
    const soft = node.kind === 'cap_dropped' || node.kind === 'unexecuted_proposal';
    const group = el('g', { cursor: 'pointer' });
    el('rect', {
      x: pos.x, y: pos.y, width: NODE_W, height: pos.h, rx: 8,
      fill: node.lane === 'model' ? '#eef2ff' : '#ffffff',
      stroke: color, 'stroke-width': 1.5,
      'stroke-dasharray': soft || node.lane === 'model' ? '4 3' : 'none'
    }, group);
    // Real HTML text flow inside a node auto-sized to its measured content:
    // the FULL untruncated text (composed from detail fields) is always
    // visible on the map itself — no clamping, no ellipsis, no hover needed.
    const body = el('foreignObject', { x: pos.x, y: pos.y, width: NODE_W, height: pos.h }, group);
    const div = document.createElementNS(XHTML_NS, 'div');
    div.className = 'map-node-body';
    div.title = '(click for all recorded fields)';
    const head = document.createElementNS(XHTML_NS, 'div');
    head.className = 'map-node-kind';
    head.style.color = color;
    head.textContent = (node.step !== null && node.step !== undefined ? 'step ' + node.step + ' · ' : '') + node.kind.replace(/_/g, ' ');
    const labelDiv = document.createElementNS(XHTML_NS, 'div');
    labelDiv.className = 'map-node-label';
    labelDiv.textContent = fullText(node);
    div.appendChild(head);
    div.appendChild(labelDiv);
    body.appendChild(div);
    group.addEventListener('click', () => showDetail(node));
  }
}

function showDetail(node) {
  const panel = document.getElementById('map-detail-panel');
  panel.hidden = false;
  document.getElementById('map-detail-title').textContent = node.kind.replace(/_/g, ' ') + ' — ' + node.status;
  const grid = document.getElementById('map-detail-grid');
  grid.replaceChildren();
  // Detail fields are untruncated by contract (run-decision-graph.js); skip the
  // layout-truncated label whenever a full message field supersedes it.
  const rows = { lane: node.lane, step: node.step, ...(node.detail && node.detail.message ? {} : { label: node.label }), ...node.detail };
  for (const [key, value] of Object.entries(rows)) {
    if (value === null || value === undefined || value === '') continue;
    const wrap = document.createElement('div');
    if (typeof value === 'object' || String(value).length > 90) wrap.className = 'map-detail-wide';
    const dt = document.createElement('dt'); dt.textContent = key;
    const dd = document.createElement('dd');
    if (typeof value === 'object') {
      const pre = document.createElement('pre');
      pre.className = 'code-block';
      pre.textContent = JSON.stringify(value, null, 2);
      dd.appendChild(pre);
    } else {
      dd.textContent = String(value);
      dd.className = 'map-detail-text';
    }
    wrap.appendChild(dt); wrap.appendChild(dd); grid.appendChild(wrap);
  }
  document.getElementById('map-detail-evidence').textContent = node.evidenceRef;
  panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

async function refresh() {
  try {
    const response = await fetch('/api/runs/' + encodeURIComponent(runId) + '/decision-graph', { headers: { Accept: 'application/json' } });
    if (!response.ok) return;
    const next = await response.json();
    if (next.cursor === graph.cursor) return;
    graph = next;
    render();
    const terminal = graph.nodes.find(node => node.id === 'terminal');
    if (terminal) {
      const badge = document.getElementById('map-run-status');
      badge.className = 'status-badge status-' + terminal.status;
      badge.textContent = terminal.status;
      currentStatus = terminal.status;
    }
  } catch (_) {}
}

render();

if (['pending', 'running'].includes(currentStatus)) {
  let eventSource = null;
  if (window.EventSource) {
    eventSource = new EventSource('/api/events');
    eventSource.addEventListener('run:status-changed', event => {
      try { if (JSON.parse(event.data).runId === runId) refresh(); } catch (_) {}
    });
    eventSource.addEventListener('error', () => { if (eventSource) { eventSource.close(); eventSource = null; } });
  }
  const poll = setInterval(() => {
    refresh();
    if (!['pending', 'running'].includes(currentStatus)) {
      clearInterval(poll);
      if (eventSource) { eventSource.close(); eventSource = null; }
    }
  }, 3000);
}
</script>
