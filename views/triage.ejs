<h1>Triage Inbox</h1>
<p class="text-muted">Unresolved triage that needs operator attention. This page is read-only — open a ticket or run to resolve its triage using the existing controls.</p>

<%
  var ticketItems = typeof ticketTriageItems === 'undefined' ? [] : ticketTriageItems;
  var runItems = typeof runTriageItems === 'undefined' ? [] : runTriageItems;
  function actionsLabel(list) { return (Array.isArray(list) && list.length > 0) ? list.join(', ') : 'none'; }
%>

<% if (ticketItems.length === 0 && runItems.length === 0) { %>
  <p class="text-muted">No unresolved triage.</p>
<% } else { %>

<section class="detail-section">
  <h2>Ticket-Level Triage (<%= ticketItems.length %>)</h2>
  <% if (ticketItems.length === 0) { %>
    <p class="text-muted">No unresolved ticket-level triage.</p>
  <% } else { %>
    <table class="tickets-table">
      <thead>
        <tr>
          <th>Type</th>
          <th>Ticket</th>
          <th>Ticket status</th>
          <th>Reason</th>
          <th>Required decision</th>
          <th>Summary</th>
          <th>Created</th>
          <th>Allowed actions</th>
          <th>Prohibited actions</th>
        </tr>
      </thead>
      <tbody>
        <% ticketItems.forEach(function (item) { %>
          <tr>
            <td>ticket-level</td>
            <td><a href="/tickets/<%= item.ticketId %>">#<%= item.ticketId %> <%= item.objective %></a></td>
            <td><span class="status-badge status-<%= item.ticketStatus %>"><%= item.ticketStatus %></span></td>
            <td><code><%= item.triage.reasonCode %></code></td>
            <td><code><%= item.triage.requiredDecision %></code></td>
            <td><%= item.triage.summary %></td>
            <td><%= item.triage.createdAt || '-' %></td>
            <td><%= actionsLabel(item.triage.allowedActions) %></td>
            <td><%= actionsLabel(item.triage.prohibitedActions) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<section class="detail-section">
  <h2>Run-Level Triage (<%= runItems.length %>)</h2>
  <% if (runItems.length === 0) { %>
    <p class="text-muted">No unresolved run-level triage.</p>
  <% } else { %>
    <table class="tickets-table">
      <thead>
        <tr>
          <th>Type</th>
          <th>Run</th>
          <th>Ticket</th>
          <th>Reason</th>
          <th>Required decision</th>
          <th>Summary</th>
          <th>Created</th>
          <th>Allowed actions</th>
          <th>Prohibited actions</th>
        </tr>
      </thead>
      <tbody>
        <% runItems.forEach(function (item) { %>
          <tr>
            <td>run-level</td>
            <td><a href="/runs/<%= item.runId %>">Run #<%= item.runId %></a> <span class="status-badge status-<%= item.runStatus %>"><%= item.runStatus %></span></td>
            <td><a href="/tickets/<%= item.ticketId %>">#<%= item.ticketId %><% if (item.ticketObjective) { %> <%= item.ticketObjective %><% } %></a><% if (item.ticketStatus) { %> · <span class="status-badge status-<%= item.ticketStatus %>"><%= item.ticketStatus %></span><% } %></td>
            <td><code><%= item.triage.reasonCode %></code></td>
            <td><code><%= item.triage.requiredDecision %></code></td>
            <td><%= item.triage.summary %></td>
            <td><%= item.triage.createdAt || '-' %></td>
            <td><%= actionsLabel(item.triage.allowedActions) %></td>
            <td><%= actionsLabel(item.triage.prohibitedActions) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<% } %>
