{
  "name": "ticket-system",
  "version": "1.0.0",
  "description": "Simple server-rendered ticketing system with Fastify",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "NODE_ENV=development node server.js",
    "build": "node --check server.js",
    "preview": "NODE_ENV=production node server.js",
    "test:agent": "NODE_ENV=test node scripts/agent-regression-test.js",
    "test:runtime-budget": "NODE_ENV=test node scripts/runtime-budget-test.js",
    "test:allocated": "NODE_ENV=test node scripts/allocated-regression-test.js",
    "test:recovery": "NODE_ENV=test node scripts/recovery-regression-test.js",
    "test:live-openai": "NODE_ENV=test node --env-file=.env.test.local scripts/live-openai-test.js",
    "test:allocated-live": "NODE_ENV=test node --env-file=.env.test.local scripts/allocated-live-openai-test.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/session": "^11.1.1",
    "@fastify/view": "^11.1.1",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "fastify": "^5.8.5"
  },
  "keywords": [
    "tickets",
    "fastify",
    "node"
  ],
  "author": "",
  "license": "MIT"
}
