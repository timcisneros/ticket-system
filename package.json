{
  "name": "ticket-system",
  "version": "1.1.1",
  "description": "Simple server-rendered ticketing system with Fastify",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "NODE_ENV=development DATA_DIR=${DATA_DIR:-.local-data} WORKSPACE_ROOT=${WORKSPACE_ROOT:-.local-workspace} node server.js",
    "build": "node scripts/check-js-syntax.js",
    "preview": "NODE_ENV=production node server.js",
    "codex:bootstrap": "node scripts/codex-bootstrap.js",
    "codex:trace": "node scripts/codex-trace.js",
    "codex:verify": "node scripts/codex-verify.js",
    "demo:legal-workflow": "node scripts/demo-legal-workflow.js",
    "demo:seed": "node scripts/seed-demo-data.js",
    "demo:dev": "NODE_ENV=development DATA_DIR=${DATA_DIR:-.local-demo-data} WORKSPACE_ROOT=${WORKSPACE_ROOT:-.local-demo-workspace} node server.js",
    "test:agent": "NODE_ENV=test node scripts/agent-regression-test.js",
    "test:browser-target": "NODE_ENV=test node scripts/browser-target-regression-test.js",
    "test:runtime-budget": "NODE_ENV=test node scripts/runtime-budget-test.js",
    "test:allocated": "NODE_ENV=test node scripts/allocated-regression-test.js",
    "test:recovery": "NODE_ENV=test node scripts/recovery-regression-test.js",
    "test:live-openai": "NODE_ENV=test node --env-file=.env.test.local scripts/live-openai-test.js",
    "test:allocated-live": "NODE_ENV=test node --env-file=.env.test.local scripts/allocated-live-openai-test.js",
    "test:postcondition": "NODE_ENV=test node scripts/postcondition-completion-test.js",
    "test:workflow": "NODE_ENV=test node scripts/workflow-composition-test.js",
    "benchmark:workflow-drafts": "NODE_ENV=test node scripts/workflow-draft-quality-benchmark.js",
    "benchmark:workflow-repair": "NODE_ENV=test node scripts/workflow-repair-benchmark.js",
    "benchmark:operational-endurance": "NODE_ENV=test node scripts/operational-endurance-benchmark.js",
    "benchmark:ambiguous-operational": "NODE_ENV=test node scripts/ambiguous-operational-benchmark.js",
    "experiment:workflow-schema-teaching": "NODE_ENV=test node scripts/workflow-schema-teaching-experiment.js",
    "harvest:benchmark-cases": "node scripts/harvest-benchmark-cases.js",
    "test:truncation": "NODE_ENV=test node scripts/prefix-truncation-regression-test.js",
    "test:simulation": "node scripts/agent-behavior-simulation-test.js",
    "validate:truncation": "node scripts/tm3-replay-validation.js",
    "checkpoint:release": "NODE_PATH=./node_modules node scripts/release-checkpoint.js",
    "test": "pnpm run checkpoint:release"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/session": "^11.1.1",
    "@fastify/view": "^11.1.1",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "fastify": "^5.8.5",
    "playwright-core": "^1.61.1"
  },
  "keywords": [
    "tickets",
    "fastify",
    "node"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.8.0"
}
